{
  "name": "@cambridge-tcg/rewardspro-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "certs",
    "dist",
    "migrations"
  ],
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { force: true, recursive: true })\"",
    "db:migrate": "node dist/migrate.js",
    "db:migrate:dev": "tsx src/migrate.ts",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "worker:probe": "node dist/worker-probe.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.879.0",
    "@aws-sdk/client-sqs": "^3.879.0",
    "fastify": "^5.6.2",
    "pg": "^8.16.3",
    "pino": "^9.6.0",
    "yutabase": "0.1.0-candidate.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.5",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
