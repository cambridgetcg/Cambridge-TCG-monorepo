{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/monthly-rollover",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/discover/cardrush",
      "schedule": "0 1,7,13,19 * * *"
    },
    {
      "path": "/api/cron/ingest/cardrush",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/cardrush-hires",
      "schedule": "*/5 * * * *"
    }
  ]
}