{
  "name": "rewardspro-production",
  "private": true,
  "scripts": {
    "build": "prisma generate && remix vite:build",
    "build:migrate": "prisma generate && prisma migrate deploy && remix vite:build",
    "dev": "shopify app dev",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "remix-serve ./build/server/index.js",
    "docker-start": "npm run setup && npm run start",
    "setup": "prisma generate && prisma migrate deploy",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:data-api": "node scripts/migrate-via-data-api.mjs",
    "migrate:subscription": "node scripts/apply-subscription-migration.mjs",
    "migrate:subscription:test": "node scripts/test-subscription-migration.mjs",
    "migrate:usage-summary": "node scripts/apply-usage-summary-migration.mjs",
    "migrate:test-connection": "node scripts/test-aurora-connection.mjs",
    "migrate:test-tier": "node scripts/test-tier-table-structure.mjs",
    "migrate:add-tier-updated-at": "node scripts/apply-tier-updated-at-migration.mjs",
    "migrate:credit-sync": "node scripts/apply-credit-sync-migration-data-api.mjs",
    "migrate:test-credit-sync": "node scripts/test-aurora-connection.mjs",
    "migrate:apply-schema-fixes": "node scripts/apply-schema-fixes.mjs",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "tunnel:setup": "./scripts/setup-aurora-tunnel.sh",
    "lambda:build": "cd lambda && npm install --production",
    "lambda:zip": "cd lambda && zip -r ../lambda-deployment.zip .",
    "lambda:deploy": "npm run lambda:build && npm run lambda:zip && echo 'Upload lambda-deployment.zip to AWS Lambda'",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run --dir test/unit",
    "test:integration": "vitest run --dir test/integration",
    "test:e2e": "playwright test",
    "test:security": "vitest run test/security",
    "test:security:webhooks": "vitest run test/security/webhook-hmac.test.ts",
    "test:security:jwt": "vitest run test/security/jwt-session-token.test.ts",
    "test:security:oauth": "vitest run test/security/oauth-flow-comprehensive.test.ts",
    "test:security:multitenant": "vitest run test/security/multi-tenant-isolation.test.ts",
    "test:security:input": "vitest run test/security/input-validation.test.ts",
    "test:security:rate": "vitest run test/security/rate-limiting.test.ts",
    "test:security:financial": "vitest run test/security/financial-security.test.ts",
    "test:security:watch": "vitest watch test/security",
    "test:security:coverage": "vitest run --coverage test/security",
    "test:performance": "k6 run test/performance/load-test.js",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
