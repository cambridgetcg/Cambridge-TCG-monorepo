{
  "name": "rewardspro-production",
  "private": true,
  "scripts": {
    "build": "prisma generate && remix vite:build",
    "build:migrate": "prisma generate && prisma migrate deploy && remix vite:build",
    "dev": "shopify app dev",
    "config:link": "shopify app config link",
    "generate": "shopify app generate",
    "deploy": "shopify app deploy",
    "config:use": "shopify app config use",
    "env": "shopify app env",
    "start": "remix-serve ./build/server/index.js",
    "docker-start": "npm run setup && npm run start",
    "setup": "prisma generate && prisma migrate deploy",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "prisma": "prisma",
    "graphql-codegen": "graphql-codegen",
    "vite": "vite",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:data-api": "node scripts/migrate-via-data-api.mjs",
    "migrate:subscription": "node scripts/apply-subscription-migration.mjs",
    "migrate:subscription:test": "node scripts/test-subscription-migration.mjs",
    "migrate:usage-summary": "node scripts/apply-usage-summary-migration.mjs",
    "migrate:test-connection": "node scripts/test-aurora-connection.mjs",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "tunnel:setup": "./scripts/setup-aurora-tunnel.sh",
    "lambda:build": "cd lambda && npm install --production",
    "lambda:zip": "cd lambda && zip -r ../lambda-deployment.zip .",
    "lambda:deploy": "npm run lambda:build && npm run lambda:zip && echo 'Upload lambda-deployment.zip to AWS Lambda'"
  },
