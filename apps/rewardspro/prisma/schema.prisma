generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  // We use AWS Aurora Data API for all connections
  // This URL is only for Prisma schema validation and client generation
  // Actual database operations go through app/utils/aurora-data-api.ts
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)

  @@index([shop]) // Add index for faster lookups by shop
}

model ShopSettings {
  id   String @id @default(uuid())
  shop String @unique // Shop domain (e.g., store.myshopify.com)

  // Store details
  storeName String // Name of store
  storeUrl  String // Store URL

  // Currency settings
  storeCurrency       Currency            @default(USD) // Store currency
  currencyDisplayType CurrencyDisplayType @default(SYMBOL) // Currency display type

  // Localization
  timezone String @default("America/New_York") // Time zone

  // White Label Email Settings (Max & Ultra plans only)
  emailEnabled      Boolean @default(false) // Email notifications enabled
  emailProvider     String? // Email provider (sendgrid, mailgun, ses, smtp)
  emailFromName     String? // From name for emails
  emailFromAddress  String? // From email address
  emailReplyTo      String? // Reply-to email address
  emailLogo         String? // URL to custom logo for emails
  emailPrimaryColor String? // Primary brand color for emails (hex)
  emailFooterText   String? // Custom footer text for emails
  emailDomain       String? // Custom email domain (for white label)

  // Email Brand Kit (for template builder)
  emailSecondaryColor  String? // Secondary brand color for emails (hex)
  emailBackgroundColor String? @default("#f4f4f4") // Email outer background color
  emailContentBgColor  String? @default("#ffffff") // Email content area background
  emailLinkColor       String? // Link color in emails (hex)
  emailFontFamily      String? @default("Arial, sans-serif") // Font family for emails
  brandKitEnabled      Boolean @default(false) // Use brand kit for new templates

  // Email API Configuration (encrypted in production)
  emailApiKey       String? // API key for email provider (encrypted)
  emailApiSecret    String? // API secret if needed (encrypted)
  emailSmtpHost     String? // SMTP host for custom SMTP
  emailSmtpPort     Int? // SMTP port
  emailSmtpUsername String? // SMTP username
  emailSmtpPassword String? // SMTP password (encrypted)

  // Email Usage Tracking
  emailsSentThisMonth Int       @default(0) // Count of emails sent this month
  emailQuotaLimit     Int       @default(0) // Monthly email quota based on plan
  lastEmailResetDate  DateTime? // Last date email count was reset

  // Email Templates (JSON)
  emailTemplates Json? // Custom email templates configuration

  // Billing (simplified - using billing.check() as source of truth)
  billingStatus String? @default("INACTIVE") // ACTIVE, INACTIVE, TRIAL (legacy)
  currentPlan   String? @default("free") // free, pro, max, ultra (legacy)

  // NEW: Simplified billing fields (Phase 1)
  subscriptionStatus    String? // ACTIVE, CANCELLED, EXPIRED, PENDING (from webhook)
  subscriptionUpdatedAt DateTime? // When webhook last updated subscription
  currentPlanName       String? // Plan name for display only (optional)
  usageCapReached       Boolean?  @default(false) // Flag when usage cap reached
  usageCapReachedAt     DateTime? // Timestamp when cap was reached

  // Initial Data Sync Status
  customersInitialSynced  Boolean @default(false) // Has initial customer sync completed
  customersSyncInProgress Boolean @default(false) // Is customer sync currently running

  // Widget Detection (Theme-based)
  widgetIsActive       Boolean @default(false) // Cache of last known widget status from theme detection
  widgetSetupDismissed Boolean @default(false) // Has merchant clicked "Enable widget" button

  // Review Request Banner
  reviewBannerDismissed Boolean   @default(false) // Has merchant dismissed the review request banner
  reviewClickedAt       DateTime? // When merchant clicked "I've left my review"

  // Customer Account Block Detection (Cache-based)
  customerAccountBlockDismissed Boolean @default(false) // Has merchant clicked "Enable customer account block" button
  customerAccountBlockIsActive  Boolean @default(false) // Cache of last known block status

  currencySelected Boolean @default(false) // Has merchant selected cashback currency

  // Tier Recalculation Settings
  tierRecalculationFrequency RecalculationFrequency @default(WEEKLY) // How often to recalculate tiers
  tierRecalculationEnabled   Boolean                @default(true) // Enable/disable automatic recalculation
  tierRecalculationLastRun   DateTime? // Track last run for frequency logic

  // Store Business Metrics (for analytics calculations)
  averageProfitMargin   Decimal?  @db.Decimal(5, 2) // Average profit margin % (e.g., 45.00 for 45%)
  averageCogsPercent    Decimal?  @db.Decimal(5, 2) // Average COGS as % of revenue (e.g., 55.00 for 55%)
  averageShippingCost   Decimal?  @db.Decimal(10, 2) // Average shipping cost per order
  averageTransactionFee Decimal?  @db.Decimal(5, 2) // Average transaction fee % (e.g., 2.90 for 2.9%)
  averageReturnRate     Decimal?  @db.Decimal(5, 2) // Average return rate % (e.g., 5.00 for 5%)
  averageOrderValue     Decimal?  @db.Decimal(10, 2) // Historical average order value
  targetRoiPercent      Decimal?  @db.Decimal(5, 2) // Target ROI % for loyalty program
  metricsLastUpdated    DateTime? // When merchant last updated these metrics

  // Feature Toggles (enable/disable specific features)
  advancedAnalyticsEnabled      Boolean @default(true) // Advanced analytics features
  autoCashbackProcessingEnabled Boolean @default(false) // Automatic cashback processing
  emailMarketingEnabled         Boolean @default(false) // Email marketing campaigns
  tierProductsEnabled           Boolean @default(true) // Tier products module

  // Base Tier Configuration (for new customers)
  autoAssignBaseTier Boolean @default(true) // Enable automatic base tier assignment for new customers
  defaultBaseTierId  String? // Specific tier to assign (if null, uses lowest minSpend tier)
  defaultBaseTier    Tier?   @relation("DefaultBaseTier", fields: [defaultBaseTierId], references: [id], onDelete: SetNull)

  // Widget Theme Settings
  widgetThemeMode          WidgetThemeMode @default(LIGHT) // Light, Dark, or Custom
  widgetPrimaryColor       String?         @default("#5C6AC4") // Primary brand color
  widgetBackgroundColor    String?         @default("#FFFFFF") // Widget background
  widgetTextColor          String?         @default("#212B36") // Main text color
  widgetAccentColor        String?         @default("#008060") // Success/highlight color
  widgetSecondaryTextColor String? // Secondary/muted text color (null = auto-derive from mode)
  widgetBorderRadius       Int?            @default(12) // Border radius in pixels
  widgetFontFamily         String?         @default("inherit") // Font family

  // Tier Trial Abuse Prevention Settings
  maxLifetimeTrialDays    Int     @default(30) // Maximum total trial days a customer can use
  minDaysBetweenTrials    Int     @default(30) // Minimum days between trial attempts
  allowMultipleTierTrials Boolean @default(false) // Whether to allow trials on different tiers

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([tierRecalculationEnabled, tierRecalculationLastRun]) // Index for cron job queries
}

// ============================================
// SHOP ENTITLEMENTS (Single Source of Truth for Feature Access)
// ============================================

model ShopEntitlements {
  id   String @id @default(uuid())
  shop String @unique

  // Resolved plan (single source of truth)
  effectivePlan String            @default("free") // free, pro, max, ultra, enterprise
  planSource    EntitlementSource @default(DEFAULT)

  // Feature flags (boolean) - Core features
  featureApiAccess         Boolean @default(false)
  featureWebhooks          Boolean @default(false)
  featureWhiteLabel        Boolean @default(false)
  featureAdvancedReport    Boolean @default(true)
  featureCustomEmail       Boolean @default(false)
  featureAnnualEval        Boolean @default(false)
  featureBulkOps           Boolean @default(false)
  featureCustomBranding    Boolean @default(false)
  featurePrioritySupport   Boolean @default(false)
  featureSubscriptionTiers Boolean @default(false)
  featurePurchasableTiers  Boolean @default(false)
  featureExportData        Boolean @default(false)
  featureCustomRewards     Boolean @default(false)

  // Feature flags (boolean) - Integrations (P1)
  featureIntegrationKlaviyo  Boolean @default(false) // Pro+
  featureIntegrationSendgrid Boolean @default(false) // Pro+
  featureIntegrationJudgeme  Boolean @default(false) // Pro+
  featureIntegrationSlack    Boolean @default(false) // Pro+
  featureIntegrationRecharge Boolean @default(false) // Max+
  featureIntegrationGorgias  Boolean @default(false) // Max+
  featureIntegrationZapier   Boolean @default(false) // Max+

  // Feature flags (boolean) - Gamification (P2)
  featureRaffles      Boolean @default(false) // Pro+
  featureMysteryBoxes Boolean @default(false) // Max+
  featureChallenges   Boolean @default(false) // Pro+

  // Feature flags (boolean) - Marketing (P3)
  featureMarketingCampaigns  Boolean @default(false) // Pro+
  featureMarketingAutomation Boolean @default(false) // Max+
  featureAiRecommendations   Boolean @default(false) // Max+

  // Feature flags (boolean) - Analytics (P4)
  featureRfmSegmentation   Boolean @default(false) // Max+
  featureProgramImpact     Boolean @default(false) // Pro+
  featureRealtimeAnalytics Boolean @default(false) // Max+
  featureCohortAnalysis    Boolean @default(false) // Ultra

  // Numeric limits - Core
  limitMaxTiers  Int @default(2)
  limitMaxOrders Int @default(50)
  limitMaxEmails Int @default(0)

  // Numeric limits - Sync with plan-limits.ts (P0)
  limitMaxAutomations    Int @default(1) // Free: 1, Pro: 5, Max: 20, Ultra: 999999
  limitMaxCustomersSync  Int @default(1000) // Free: 1K, Pro: 10K, Max: 50K, Ultra: 999999
  limitMaxTierProducts   Int @default(2) // Free: 2, Pro: 5, Max: 10, Ultra: 999999
  limitMaxHistoricalDays Int @default(30) // Free: 30, Pro: 90, Max: 365, Ultra: 999999

  // Numeric limits - Gamification (P2)
  // IMPORTANT: All plans get at least 1 (rate-based gating model)
  // See app/constants/plan-limits.ts for canonical values
  limitMaxActiveRaffles      Int @default(1) // Free: 1, Pro: 3, Max: 10, Ultra: 999999
  limitMaxActiveMysteryBoxes Int @default(1) // Free: 1, Pro: 2, Max: 5, Ultra: 999999
  limitMaxActiveChallenges   Int @default(1) // Free: 1, Pro: 5, Max: 15, Ultra: 999999

  // Numeric limits - Marketing (P3)
  // IMPORTANT: All plans get at least 1 (rate-based gating model)
  limitMaxCampaigns       Int @default(1) // Free: 1, Pro: 5, Max: 25, Ultra: 999999
  limitMaxAutomationFlows Int @default(1) // Free: 1, Pro: 3, Max: 10, Ultra: 999999

  // Override support (for custom deals / grandfathered plans)
  hasOverride    Boolean   @default(false)
  overrideExpiry DateTime?
  overrideNote   String?
  overrideBy     String? // Admin who set the override

  // Timestamps
  lastResolvedAt DateTime @default(now())
  resolvedFrom   String? // Source that triggered last resolution (webhook, manual, etc.)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([shop])
  @@index([effectivePlan])
  @@index([hasOverride])
}

enum EntitlementSource {
  DEFAULT // No subscription, using free defaults
  SUBSCRIPTION // From active Shopify subscription
  OVERRIDE // Manual override by admin
  LEGACY // Grandfathered from old billing system
}

model Tier {
  id               String           @id
  shop             String
  name             String
  description      String? // Tier description
  minSpend         Int
  cashbackPercent  Int
  evaluationPeriod EvaluationPeriod @default(ANNUAL)
  sortOrder        Int              @default(0) // Display order for UI
  benefits         Json? // Array of benefit strings
  isActive         Boolean          @default(true) // Whether tier is active

  // Display properties for storefront widgets
  icon      String? @default("⭐") // Emoji or icon identifier
  color     String? @default("#FFD700") // Hex color code
  threshold Int? // Alternative field for progress tracking (can map to minSpend)

  // Points Engagement System multipliers
  pointsMultiplier      Decimal? @default(1.0) @db.Decimal(3, 2) // Points earning multiplier (1.0 = 1x, 1.5 = 1.5x)
  pointsLuckBonus       Decimal? @default(0) @db.Decimal(5, 2) // Luck bonus % for mystery boxes/raffles
  raffleEntryMultiplier Decimal? @default(1.0) @db.Decimal(3, 2) // Raffle entry bonus multiplier

  // Subscription pricing
  monthlyPrice       Decimal?         @db.Decimal(10, 2) // Monthly subscription price
  billingInterval    BillingInterval? // Billing interval for subscriptions
  discountPercentage Decimal?         @db.Decimal(5, 2) // Discount for subscriptions

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  customers      Customer[] // Customers currently in this tier
  subscriptions  TierSubscription[] // Subscriptions for this tier
  pricingHistory SubscriptionPricingHistory[] // Pricing change history
  tierProducts   TierProduct[] // Products for purchasing this tier
  tierPurchases  TierPurchase[] // One-time purchases of this tier

  // CustomerTierState relations
  tierStateEffective      CustomerTierState[] @relation("EffectiveTier")
  tierStateSpendingBased  CustomerTierState[] @relation("SpendingBasedTier")
  tierStateManualOverride CustomerTierState[] @relation("ManualOverrideTier")
  tierStateNextTier       CustomerTierState[] @relation("NextTier")

  // Shop settings using this as default base tier
  shopsUsingAsDefault ShopSettings[] @relation("DefaultBaseTier")

  // Gift card system relations
  giftCardSettings TierGiftCardSettings?
  giftCardBundles  GiftCardBundle[]

  // Constraints
  @@unique([shop, name]) // Combination must be unique
  @@index([shop]) // Speed up queries by shop
  @@index([cashbackPercent]) // Speed up sorting by cashback
}

// ============================================
// TIER PRODUCT MODEL - Links tiers to Shopify products
// ============================================

model TierProduct {
  id     String @id @default(uuid())
  shop   String
  tierId String
  tier   Tier   @relation(fields: [tierId], references: [id], onDelete: Cascade)

  // Shopify Product Information
  shopifyProductId String
  shopifyVariantId String
  productHandle    String
  sku              String

  // Purchase Options
  purchaseType PurchaseType // ONE_TIME, SUBSCRIPTION, or BOTH
  duration     ProductDuration? // For one-time purchases

  // Subscription Configuration
  hasSubscription           Boolean @default(false)
  sellingPlanGroupId        String? // @deprecated Use shopifySellingPlanGroupId instead. Legacy field kept for data migration.
  shopifySellingPlanGroupId String? // CANONICAL: Shopify's GraphQL ID for the selling plan group (gid://shopify/SellingPlanGroup/xxx)
  subscriptionPlanIds       Json? // Array of selling plan IDs

  // Pricing
  price          Decimal  @db.Decimal(10, 2) // Current price
  currency       Currency @default(USD) // Product currency
  oneTimePrice   Decimal? @db.Decimal(10, 2)
  monthlyPrice   Decimal? @db.Decimal(10, 2)
  quarterlyPrice Decimal? @db.Decimal(10, 2)
  annualPrice    Decimal? @db.Decimal(10, 2)

  // Features & Description
  features    Json? // Array of feature strings
  description String?

  // Status
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft Delete
  deletedAt      DateTime? // Null = not deleted, timestamp = soft deleted
  deletedBy      String? // Email or identifier of who deleted
  deletionReason String? // Optional reason for deletion

  // Relations
  subscriptions TierSubscription[]
  tierPurchases TierPurchase[]
  auditLogs     TierProductAuditLog[]

  @@unique([shop, shopifyProductId])
  @@unique([shop, shopifyVariantId])
  @@index([shop, tierId])
  @@index([shop, isActive])
  @@index([shop, deletedAt])
}

// Audit log for tier product changes
model TierProductAuditLog {
  id            String      @id @default(uuid())
  shop          String
  tierProductId String
  tierProduct   TierProduct @relation(fields: [tierProductId], references: [id], onDelete: Cascade)

  // Action tracking
  action      String // CREATE, UPDATE, DELETE, RESTORE, PERMANENT_DELETE
  performedBy String? // Email or identifier of who performed the action

  // Change details
  previousState Json? // Snapshot of state before change
  newState      Json? // Snapshot of state after change
  metadata      Json? // Additional context (e.g., deletion reason, affected records)

  createdAt DateTime @default(now())

  @@index([shop, tierProductId])
  @@index([shop, action])
  @@index([createdAt])
}

model Customer {
  id                String @id @default(uuid())
  shop              String
  shopifyCustomerId String @db.VarChar(255)

  // Storefront widget authentication
  shopifyCustomerMetafieldId String? @db.VarChar(255) // Metafield ID for storefront API auth

  email       String    @db.VarChar(255)
  firstName   String?   @db.VarChar(255) // Added for Shopify sync
  lastName    String?   @db.VarChar(255) // Added for Shopify sync
  phone       String?   @db.VarChar(50) // Customer phone number
  tags        String?   @db.Text // Added for customer tagging
  birthday    DateTime? // Customer birthday (Phase 1 Gap Fill)
  storeCredit Decimal   @default(0) @db.Decimal(10, 2)

  // Points tracking for loyalty widgets
  pointsBalance  Decimal @default(0) @db.Decimal(10, 2) // Current available points
  lifetimePoints Decimal @default(0) @db.Decimal(10, 2) // Total points ever earned

  // Spending tracking fields
  totalSpent          Decimal   @default(0) @db.Decimal(10, 2) // Total order value (all-time)
  annualSpent         Decimal   @default(0) @db.Decimal(10, 2) // Spending in last 12 months (for tier calculation)
  totalCashbackEarned Decimal   @default(0) @db.Decimal(10, 2) // Total cashback earned
  totalRefunded       Decimal   @default(0) @db.Decimal(10, 2) // Total refunds received
  netSpent            Decimal   @default(0) @db.Decimal(10, 2) // totalSpent - totalRefunded
  orderCount          Int       @default(0) // Number of orders
  lastOrderDate       DateTime? // Date of most recent order

  // Email marketing consent and suppression
  acceptsMarketing  Boolean   @default(true) // Opt-in to marketing emails (campaigns)
  emailSuppressed   Boolean   @default(false) // Hard bounce or spam complaint — suppress all marketing
  suppressedAt      DateTime? // When suppression was applied
  suppressionReason String?   @db.VarChar(255) // bounce, spam_report, unsubscribe

  // Shopify timestamps for sync tracking
  shopifyCreatedAt DateTime? // When customer was created in Shopify
  shopifyUpdatedAt DateTime? // Last update in Shopify

  // Current tier relationship
  currentTierId String?
  currentTier   Tier?   @relation(fields: [currentTierId], references: [id], onDelete: SetNull)

  // Current subscription relationship
  currentSubscriptionId String?           @unique
  currentSubscription   TierSubscription? @relation("CurrentSubscription", fields: [currentSubscriptionId], references: [id], onDelete: SetNull)

  // Subscription fields
  hasActiveSubscription Boolean @default(false) // Quick check for active subscription
  subscriptionTier      String? // Current subscription tier name

  // Tier Trial Abuse Prevention (mirrors AppSubscription trial fields)
  hasUsedTierTrial        Boolean   @default(false) // Has customer ever used a tier trial
  firstTierTrialStartedAt DateTime? // When first tier trial was activated
  totalTierTrialDaysUsed  Int       @default(0) // Accumulated trial days across all tiers
  lastTierTrialTierId     String? // Last tier that granted a trial
  tierTrialHistory        Json? // Array of {tierId, tierName, daysUsed, startedAt}

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  creditLedger       StoreCreditLedger[]
  tierChangeLogs     TierChangeLog[]
  subscriptions      TierSubscription[] // Customer's tier subscriptions
  tierPurchases      TierPurchase[] // One-time tier purchases
  orders             Order[] // Customer's order history
  subscriptionEvents SubscriptionEvent[] // Subscription event history
  appSubscriptions   Subscription[] // App-level subscriptions

  // Single source of truth for tier state (new unified system)
  tierState CustomerTierState? @relation("TierState")

  // Tier trial audit logs
  tierTrialAuditLogs TierTrialAuditLog[]

  // Points Engagement System
  pointsLedger PointsLedger[] @relation("PointsLedgerEntries")

  // Raffles System
  raffleEntries RaffleEntry[]  @relation("RaffleEntries")
  raffleWins    RaffleWinner[] @relation("RaffleWins")

  // Raffle Psychology System
  raffleStreak           RaffleStreak?           @relation("RaffleStreaks")
  raffleInstantWinLogs   RaffleInstantWinLog[]   @relation("RaffleInstantWins")
  raffleActivities       RaffleActivity[]        @relation("RaffleActivities")
  raffleBonusEventUsages RaffleBonusEventUsage[] @relation("RaffleBonusEventUsages")
  raffleLuckyNumbers     RaffleLuckyNumber[]     @relation("RaffleLuckyNumbers")

  // Mystery Boxes System
  mysteryBoxOpens MysteryBoxOpen[]   @relation("MysteryBoxOpens")
  mysteryBoxWins  MysteryBoxWinner[] @relation("MysteryBoxWins")

  // Mystery Box Psychology System
  mysteryBoxStreak       MysteryBoxStreak?           @relation("MysteryBoxStreaks")
  mysteryBoxActivities   MysteryBoxActivity[]        @relation("MysteryBoxActivities")
  mysteryBoxBonusUsages  MysteryBoxBonusEventUsage[] @relation("MysteryBoxBonusUsages")

  // Challenges System
  challengeParticipants ChallengeParticipant[] @relation("ChallengeParticipants")

  // Mission System (Gamification)
  missionStats CustomerMissionStats? @relation("MissionStats")

  @@unique([shop, shopifyCustomerId]) // Prevent duplicate customers per shop
  @@index([shop]) // Speed up queries by shop
  @@index([email]) // Speed up queries by email
  @@index([shop, shopifyCustomerMetafieldId]) // Speed up storefront widget queries
  @@index([shop, currentTierId, createdAt(sort: Desc)]) // Optimize paginated tier-filtered queries
  @@index([shop, storeCredit]) // Optimize credit range filter queries on members page
  @@index([shop, createdAt, orderCount]) // Analytics: cohort queries (customers created in time range with orders)
  @@index([shop, lastOrderDate]) // Analytics: RFM recency queries (active/dormant customer counts)
}

// ============================================
// CUSTOMER TIER STATE - Single Source of Truth
// ============================================
// This model is the authoritative source for a customer's current tier.
// It replaces the need to scan TierChangeLog for manual overrides and
// consolidates tier source tracking in one place.

model CustomerTierState {
  id         String   @id @default(uuid())
  shop       String
  customerId String   @unique
  customer   Customer @relation("TierState", fields: [customerId], references: [id], onDelete: Cascade)

  // Current effective tier (the tier the customer actually has)
  effectiveTierId String?
  effectiveTier   Tier?      @relation("EffectiveTier", fields: [effectiveTierId], references: [id], onDelete: SetNull)
  tierSource      TierSource @default(NONE)
  tierSourceId    String? // ID of the source record (subscription ID, purchase ID, etc.)

  // Manual override tracking (explicit fields, no TierChangeLog scanning needed)
  hasManualOverride    Boolean   @default(false)
  manualOverrideTierId String? // The tier ID that was manually set (persists even if effectiveTierId changes)
  manualOverrideTier   Tier?     @relation("ManualOverrideTier", fields: [manualOverrideTierId], references: [id], onDelete: SetNull)
  manualOverrideAt     DateTime?
  manualOverrideBy     String? // Admin user ID who set the override
  manualOverrideExpiry DateTime? // NULL = permanent, otherwise temporary override
  manualOverrideNote   String?   @db.Text

  // Active purchase tracking
  activePurchaseId  String?
  purchaseExpiresAt DateTime?

  // Active subscription tracking
  activeSubscriptionId  String?
  subscriptionExpiresAt DateTime?

  // Spending-based tier (cached for performance)
  spendingBasedTierId    String?
  spendingBasedTier      Tier?     @relation("SpendingBasedTier", fields: [spendingBasedTierId], references: [id], onDelete: SetNull)
  spendingLastCalculated DateTime?

  // Resolution tracking
  lastResolvedAt   DateTime @default(now())
  resolutionReason String?  @db.Text // Human-readable explanation of resolution

  // ═══════════════════════════════════════════════════════════════════════
  // Pre-computed Tier Progress (cached for widget performance)
  // Updated by: updateCustomerTierState() on order/subscription/purchase events
  // ═══════════════════════════════════════════════════════════════════════
  progressPercent      Int       @default(0) // 0-100, progress towards next tier
  nextTierId           String? // Next tier customer can reach
  nextTier             Tier?     @relation("NextTier", fields: [nextTierId], references: [id], onDelete: SetNull)
  nextTierName         String? // Cached for display (denormalized)
  nextTierMinSpend     Decimal?  @db.Decimal(10, 2) // minSpend of next tier
  amountToNextTier     Decimal   @default(0) @db.Decimal(10, 2) // Amount remaining to reach next tier
  isMaxTier            Boolean   @default(false) // True if at highest tier
  progressCalculatedAt DateTime? // When progress was last calculated

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop, effectiveTierId])
  @@index([shop, tierSource])
  @@index([hasManualOverride])
  @@index([purchaseExpiresAt])
  @@index([subscriptionExpiresAt])
  @@index([isMaxTier])
}

// ============================================
// CUSTOMER SYNC JOB - Reliable Full Sync
// ============================================
// Tracks progress of customer sync operations with resume capability.
// Enables chunked processing and accurate progress display.

model CustomerSyncJob {
  id   String @id @default(uuid())
  shop String

  // Job status
  status SyncJobStatus @default(PENDING) // PENDING, IN_PROGRESS, COMPLETED, FAILED, CANCELLED

  // Customer counts from Shopify
  totalCustomers Int? // Total customers in Shopify (shop.customersCount)

  // Progress tracking
  processedCount Int @default(0) // Customers processed so far
  createdCount   Int @default(0) // New customers created
  updatedCount   Int @default(0) // Existing customers updated
  skippedCount   Int @default(0) // Customers skipped (no email, etc.)
  errorCount     Int @default(0) // Processing errors

  // Pagination for resume
  lastCursor String? // GraphQL cursor for next batch
  batchSize  Int     @default(100) // Customers per batch

  // Error tracking
  lastError    String? @db.Text // Most recent error message
  errorDetails Json? // Detailed error info

  // Timing
  startedAt      DateTime?
  completedAt    DateTime?
  lastActivityAt DateTime? // Last batch processed timestamp

  // Metadata
  triggeredBy String? // 'manual', 'install', 'cron'
  metadata    Json? // Additional job data

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop, status])
  @@index([shop, createdAt(sort: Desc)])
}

enum SyncJobStatus {
  PENDING // Job created but not started
  IN_PROGRESS // Currently processing
  COMPLETED // Successfully finished
  FAILED // Failed with error
  CANCELLED // Manually cancelled
}

// ============================================
// STORE CREDIT SYNC JOB
// ============================================
// Tracks progress of store credit import from Shopify.
// Enables merchants to sync existing Shopify credit balances
// to the local database when first installing the app.

model StoreCreditSyncJob {
  id   String @id @default(uuid())
  shop String

  // Job status
  status SyncJobStatus @default(PENDING)

  // Customer counts
  totalCustomers Int? // Total customers to process

  // Progress tracking
  processedCount Int @default(0) // Customers checked so far
  updatedCount   Int @default(0) // Customers with balance updated
  skippedCount   Int @default(0) // Customers with matching/zero balance
  errorCount     Int @default(0) // Processing errors

  // Pagination for resume
  lastCursor String? // Customer ID cursor for next batch
  batchSize  Int     @default(25) // Lower due to Shopify API calls per customer

  // Financial summary
  totalImported   Decimal @default(0) @db.Decimal(10, 2) // Sum of credits imported
  totalDifference Decimal @default(0) @db.Decimal(10, 2) // Net adjustment made

  // Error tracking
  lastError    String? @db.Text
  errorDetails Json?

  // Timing
  startedAt      DateTime?
  completedAt    DateTime?
  lastActivityAt DateTime?

  // Metadata
  triggeredBy String? // 'manual', 'install', etc.
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop, status])
  @@index([shop, createdAt(sort: Desc)])
}

// ============================================
// ORDER SYNC JOB - Reliable Full Sync
// ============================================
// Tracks progress of order sync operations with resume capability.
// Enables chunked processing and accurate progress display.

model OrderSyncJob {
  id   String @id @default(uuid())
  shop String

  // Job status
  status SyncJobStatus @default(PENDING)

  // Order counts from Shopify
  totalOrders Int? // Total orders in Shopify (shop.ordersCount)

  // Progress tracking
  processedCount Int @default(0) // Orders processed so far
  createdCount   Int @default(0) // New orders created
  updatedCount   Int @default(0) // Existing orders updated
  skippedCount   Int @default(0) // Orders skipped
  errorCount     Int @default(0) // Processing errors

  // Pagination for resume
  lastCursor String? // GraphQL cursor for next batch
  batchSize  Int     @default(50) // Orders per batch

  // Date range
  startDate DateTime? // Start of date range to sync
  endDate   DateTime? // End of date range to sync

  // Error tracking
  lastError    String? @db.Text // Most recent error message
  errorDetails Json? // Detailed error info

  // Timing
  startedAt      DateTime?
  completedAt    DateTime?
  lastActivityAt DateTime? // Last batch processed timestamp

  // Metadata
  triggeredBy String? // 'manual', 'install', 'cron'
  metadata    Json? // Additional job data

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop, status])
  @@index([shop, createdAt(sort: Desc)])
}

model StoreCreditLedger {
  id         String @id @default(uuid())
  customerId String
  shop       String

  // Core transaction data
  amount  Decimal         @db.Decimal(10, 2) // Positive for credit, negative for debit
  balance Decimal         @db.Decimal(10, 2) // Running balance - KEEP for query performance
  type    LedgerEntryType

  // Reference & deduplication
  shopifyOrderId       String? // Prevents double-crediting, links to orders
  shopifyTransactionId String? // Shopify store credit transaction ID
  syncStatus           CreditSyncStatus @default(PENDING) // Track sync with Shopify
  syncedAt             DateTime? // When synced to Shopify

  // Order relations
  orderId String?
  order   Order?  @relation("OrderLedgerEntries", fields: [orderId], references: [id])

  refundId String?      @unique
  refund   OrderRefund? @relation("RefundLedgerEntry", fields: [refundId], references: [id])

  // Flexible data field
  metadata Json? // Store everything else here (cashback %, order amount, description, etc.)

  // Point expiration (for storefront widgets)
  expiresAt DateTime? // When points expire (null = never expires)

  createdAt DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([shop, shopifyOrderId, type]) // Prevent duplicate entries
  @@index([customerId])
  @@index([type])
  @@index([createdAt])
  @@index([customerId, expiresAt]) // Speed up expiring points queries
  @@index([customerId, shop, createdAt(sort: Desc)]) // Optimize transaction history queries
}

// ============================================
// GIFT CARD SYSTEM MODELS
// ============================================

// Shop-level gift card configuration
model GiftCardConfig {
  id   String @id @default(uuid())
  shop String @unique

  // Feature toggles
  enableTierBranding    Boolean @default(true) // Use tier-specific templates
  enableTierBonuses     Boolean @default(false) // Bonus value based on purchaser tier
  enableMembershipGifts Boolean @default(true) // Allow gifting memberships

  // Defaults
  defaultTemplateSuffix String? // Fallback template if tier has none

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Tier-specific gift card settings
model TierGiftCardSettings {
  id     String @id @default(uuid())
  shop   String
  tierId String @unique // Each tier has at most one gift card setting
  tier   Tier   @relation(fields: [tierId], references: [id], onDelete: Cascade)

  // Branding - templateSuffix maps to gift_card.[suffix].liquid
  templateSuffix String? // e.g., "gold" → gift_card.gold.liquid

  // Bonuses - extra value when this tier purchases gift cards
  bonusPercent Decimal @default(0) @db.Decimal(5, 2) // e.g., 10 = 10% bonus

  // Membership bundle settings
  canBundleWithCard Boolean  @default(true) // Can this tier be gifted
  bundlePrice       Decimal? @db.Decimal(10, 2) // Special price when bundled

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

// Track issued gift cards and their tier integration
model IssuedGiftCard {
  id   String @id @default(uuid())
  shop String

  // Shopify reference
  shopifyGiftCardId String  @unique
  lastFourDigits    String? // Last 4 chars of code (for display)

  // Value
  initialValue Decimal @db.Decimal(10, 2) // Base value
  bonusValue   Decimal @default(0) @db.Decimal(10, 2) // From tier bonus
  totalValue   Decimal @db.Decimal(10, 2) // initial + bonus

  // Tier branding
  templateSuffix    String? // Template used for this card
  purchaserTierId   String? // Tier of person who bought (for tracking)
  purchaserTierName String? // Denormalized for display

  // Membership bundle (if this card grants tier access)
  bundleType      GiftCardBundleType @default(VALUE_ONLY)
  bundledTierId   String? // Tier to grant on redemption
  bundledTierName String? // Denormalized for display
  bundledDuration String? // MONTHLY, QUARTERLY, ANNUAL, LIFETIME

  // People
  purchasedByCustomerId String? // Customer who bought
  purchasedByEmail      String? // Email if no customer record
  recipientCustomerId   String? // Recipient (if known)
  recipientEmail        String? // Recipient email
  recipientName         String? // Recipient display name
  personalMessage       String? // Gift message

  // Scheduling
  scheduledSendAt DateTime? // When to send notification

  // Status tracking
  status          GiftCardStatus @default(ACTIVE)
  redeemedAt      DateTime?
  tierActivatedAt DateTime? // When bundled membership was activated

  // Conversion tracking (if created from cashback)
  convertedFromLedgerId String? // StoreCreditLedger entry ID

  // Order reference (if purchased through checkout)
  shopifyOrderId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop, status])
  @@index([recipientCustomerId])
  @@index([purchasedByCustomerId])
  @@index([shopifyOrderId])
}

// Pre-configured gift card bundles (merchant creates these)
model GiftCardBundle {
  id     String  @id @default(uuid())
  shop   String
  tierId String? // Optional: tier to bundle with
  tier   Tier?   @relation(fields: [tierId], references: [id], onDelete: SetNull)

  // Display
  name        String // e.g., "Gold Experience Gift"
  description String? // Marketing description

  // Value configuration
  bundleType    GiftCardBundleType
  giftCardValue Decimal            @db.Decimal(10, 2) // Monetary value included
  price         Decimal            @db.Decimal(10, 2) // What customer pays

  // Membership configuration (if bundleType includes membership)
  membershipDuration String? // MONTHLY, QUARTERLY, ANNUAL, LIFETIME

  // Status
  isActive  Boolean @default(true)
  sortOrder Int     @default(0) // Display order

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop, isActive])
}

model TierChangeLog {
  id         String @id @default(uuid())
  customerId String
  shop       String

  // Tier transition details
  fromTierId   String? // Null for first tier assignment
  fromTierName String? // Store name for historical reference
  toTierId     String? // Null if customer is removed from all tiers
  toTierName   String? // Store name for historical reference

  // Change context
  changeType  TierChangeType // Type of change
  triggerType TierTriggerType // What triggered the change

  // Spending data at time of change
  totalSpending  Decimal? @db.Decimal(10, 2) // Customer's total spending at this point
  periodSpending Decimal? @db.Decimal(10, 2) // Spending in evaluation period

  // Additional context
  orderId        String? // If triggered by an order
  subscriptionId String? // If triggered by subscription
  note           String? // Manual notes or system messages
  metadata       Json? // Additional data (order details, calculation breakdown, etc.)

  createdAt   DateTime @default(now())
  processedBy String? // Admin user ID if manual, "system" if automatic

  // Relations
  customer     Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  subscription TierSubscription? @relation(fields: [subscriptionId], references: [id])

  // Indexes for common queries
  @@index([customerId, createdAt(sort: Desc)]) // Customer's tier history
  @@index([shop, createdAt(sort: Desc)]) // Shop's recent changes
  @@index([changeType]) // Filter by change type
  @@index([triggerType]) // Filter by trigger type
}

// Legacy BillingPlan model removed - now using BillingSubscription for GraphQL API

// ============================================
// GRAPHQL BILLING SUBSCRIPTION MODEL
// ============================================

model BillingSubscription {
  id   String @id @default(uuid())
  shop String @unique

  // GraphQL Subscription Info
  subscriptionId     String? // Shopify AppSubscription GID
  subscriptionStatus String? // ACTIVE, CANCELLED, EXPIRED, PENDING
  currentPeriodEnd   DateTime?

  // Line Items
  recurringLineItemId String? // For recurring charge
  usageLineItemId     String? // For usage-based charges

  // Pending Charges
  pendingChargeId        String?
  pendingChargeCreatedAt DateTime?
  confirmationUrl        String?   @db.Text

  // Usage Tracking
  currentPeriodOrders   Int       @default(0)
  currentPeriodUsageFee Decimal   @default(0) @db.Decimal(10, 2)
  lastUsageReset        DateTime?
  usageCappedAmount     Decimal?  @db.Decimal(10, 2)
  lastChargedBatch      Int? // Track which batch was last charged (e.g., 1 = first 100, 2 = second 100)

  // Migration Info
  billingVersion String    @default("graphql") // "legacy" or "graphql"
  migratedAt     DateTime?

  // Plan Info
  planType    String? // "free", "starter", "growth", "enterprise"
  trialEndsAt DateTime?

  // Metadata
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([subscriptionStatus])
}

// ============================================
// APP-LEVEL SUBSCRIPTION MODEL (Shopify App Billing)
// ============================================

model AppSubscription {
  id   String @id @default(uuid())
  shop String @unique

  // Shopify Subscription Info
  shopifySubscriptionId String? @unique // Full GID: gid://shopify/AppSubscription/123
  chargeId              String? // Numeric ID from charge_id parameter

  // Plan Details
  planName String // "RewardsPro Pro", "RewardsPro Max", etc.
  status   String // ACTIVE, CANCELLED, EXPIRED, PENDING
  test     Boolean @default(false)

  // Trial Period
  trialDays   Int?
  trialEndsAt DateTime?

  // Trial Abuse Prevention
  hasUsedTrial        Boolean   @default(false) // Has merchant ever used a trial
  firstTrialStartedAt DateTime? // When first trial was activated
  totalTrialDaysUsed  Int       @default(0) // Accumulated trial days across all plans
  lastTrialPlanId     String? // Last plan that granted a trial

  // Recurring Pricing
  recurringAmount   Decimal? @db.Decimal(10, 2)
  recurringCurrency String? // USD, EUR, etc.
  recurringInterval String? // EVERY_30_DAYS, ANNUAL

  // Usage-Based Pricing
  usageCap         Decimal? @db.Decimal(10, 2)
  usageCurrency    String?
  usageTerms       String? // Description of usage pricing
  usageBalanceUsed Decimal? @db.Decimal(10, 2) // Current usage balance

  // Billing Periods
  currentPeriodEnd DateTime?
  nextBillingDate  DateTime?

  // Lifecycle Dates
  activatedAt        DateTime? // When first activated
  cancelledAt        DateTime? // When cancelled
  cancellationReason String?

  // Webhook Tracking
  lastWebhookUpdate  DateTime? // Last time webhook updated this
  webhookUpdateCount Int       @default(0)
  webhookTimestamp   DateTime? // Shopify's updated_at from webhook (for ordering)

  // Return URL Tracking
  returnUrlProcessed   Boolean   @default(false) // Has return URL been processed
  returnUrlProcessedAt DateTime?

  // Metadata
  metadata  Json? // Additional subscription data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop, status])
  @@index([shopifySubscriptionId])
  @@index([chargeId])
  @@index([status, nextBillingDate])
}

// ============================================
// TRIAL AUDIT LOG - Tracks trial grant attempts
// ============================================
model TrialAuditLog {
  id   String @id @default(uuid())
  shop String

  // Trial Details
  planId             String // Plan that was requested
  planName           String? // Human-readable plan name
  trialDaysRequested Int // Trial days that were requested
  trialDaysGranted   Int     @default(0) // Trial days actually granted (0 if blocked)

  // Previous State
  previousPlanId   String? // Plan before switch (if applicable)
  previousPlanName String?
  wasInTrial       Boolean @default(false) // Was merchant in trial before this request

  // Validation Result
  wasBlocked       Boolean @default(false) // Was the trial request blocked
  blockReason      String? // ACTIVE_TRIAL, TRIAL_ALREADY_USED, etc.
  eligibilityCheck Json? // Full eligibility check result

  // Request Context
  requestSource String? // "billing_page", "api", "webhook"
  ipAddress     String? // For abuse detection
  userAgent     String?

  createdAt DateTime @default(now())

  @@index([shop])
  @@index([shop, createdAt])
  @@index([wasBlocked])
  @@index([createdAt])
}

// ============================================
// TIER TRIAL AUDIT LOG
// ============================================
// Tracks all tier subscription trial attempts (granted and blocked)
// Used for abuse prevention and analytics on tier trials

model TierTrialAuditLog {
  id   String @id @default(uuid())
  shop String

  // Customer & Tier Details
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tierId     String
  tierName   String // Denormalized for quick access

  // Action & Result
  action      String // TRIAL_GRANTED, TRIAL_BLOCKED, TRIAL_EXPIRED, TRIAL_CONVERTED
  wasBlocked  Boolean @default(false)
  blockReason String? // ALREADY_USED, ACTIVE_TRIAL, SAME_TIER, MAX_DAYS_EXCEEDED

  // Trial Details
  trialDaysRequested Int // Trial days that were requested
  trialDaysGranted   Int @default(0) // Trial days actually granted (0 if blocked)

  // Previous State (for plan switches)
  previousTierId   String?
  previousTierName String?
  wasInTrial       Boolean @default(false) // Was customer in trial before this request

  // Subscription Context
  subscriptionId String? // The subscription that triggered this

  // Request Context
  requestSource String? // "webhook", "api", "storefront", "admin"
  ipAddress     String? // For abuse detection
  userAgent     String?

  // Additional Data
  metadata Json? // Full eligibility check result, etc.

  createdAt DateTime @default(now())

  @@index([shop])
  @@index([shop, customerId])
  @@index([customerId, tierId])
  @@index([shop, createdAt])
  @@index([wasBlocked])
  @@index([createdAt])
}

model UsageRecord {
  id   String @id @default(uuid())
  shop String

  // Shopify reference
  shopifyUsageRecordId String? // Shopify's usage record ID

  // Usage details
  description  String // Description of the usage
  amount       Decimal @db.Decimal(10, 2) // Amount charged
  currencyCode String  @default("USD")

  // Idempotency
  idempotencyKey String // Prevent duplicate charges

  // Processing details
  processedAt DateTime @default(now()) // When charge was created
  metadata    Json? // Additional data

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes for queries
  @@index([shop, processedAt(sort: Desc)]) // Recent usage by shop
  @@index([shop, idempotencyKey]) // For idempotency checks
}

model UsageSummary {
  id   String @id @default(uuid())
  shop String

  // Date and aggregation
  date            DateTime // Date for this summary (UTC midnight)
  ordersProcessed Int // Number of orders processed
  cashbackIssued  Decimal  @db.Decimal(10, 2) // Total cashback issued
  customersActive Int // Number of active customers

  // Charge details
  chargeAmount Decimal @db.Decimal(10, 2) // Calculated charge amount
  chargeId     String? // Shopify usage record ID if charged
  charged      Boolean @default(false) // Whether charge was created

  // Metadata
  metadata  Json? // Additional summary data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, date]) // One summary per shop per day
  @@index([shop, date(sort: Desc)])
  @@index([charged])
}

model BillingHistory {
  id   String @id @default(uuid())
  shop String

  // Event details
  eventType String // SUBSCRIPTION_UPDATE, APPROACHING_CAP, etc
  planName  String // Plan name at time of event
  status    String // Status at time of event
  amount    Decimal? @db.Decimal(10, 2) // Amount if applicable

  // Metadata
  metadata  Json? // Additional event data
  createdAt DateTime @default(now())

  @@index([shop, createdAt(sort: Desc)])
  @@index([eventType])
}

model Notification {
  id   String @id @default(uuid())
  shop String

  // Notification details
  type     String // USAGE_CAP_WARNING, etc
  title    String
  message  String
  severity String // INFO, WARNING, ERROR
  read     Boolean @default(false)

  // Metadata
  metadata  Json? // Additional data
  createdAt DateTime @default(now())

  @@index([shop, read])
  @@index([shop, createdAt(sort: Desc)])
}

model BillingAuditLog {
  id   String @id @default(uuid())
  shop String

  // Action details
  action       String // subscribe-free, subscribe-pro, subscribe-max, contact-enterprise
  planName     String? // The plan they're trying to subscribe to
  success      Boolean @default(false)
  errorMessage String? @db.Text

  // Request details
  ipAddress String? // For tracking suspicious activity
  userAgent String? @db.Text

  // Timestamps
  attemptedAt DateTime @default(now())

  // Metadata
  metadata Json? // Additional data like response from Shopify

  @@index([shop, attemptedAt(sort: Desc)]) // Recent attempts by shop
  @@index([shop, planName]) // Attempts by shop and plan
}

// ============================================
// USAGE CAP ALERT MODEL (Phase 1)
// ============================================

model UsageCapAlert {
  id   String @id @default(uuid())
  shop String

  // Subscription details
  subscriptionId   String // Shopify AppSubscription GID
  subscriptionName String // Plan name (e.g., "RewardsPro Pro")

  // Usage details
  cappedAmount     Decimal @db.Decimal(10, 2) // Maximum allowed usage
  balanceUsed      Decimal @db.Decimal(10, 2) // Current usage
  balanceRemaining Decimal @db.Decimal(10, 2) // Remaining before cap
  usagePercentage  Decimal @db.Decimal(5, 2) // Percentage of cap used

  // Alert level
  alertLevel String // WARNING (>80%), CRITICAL (>95%)

  // Notification tracking
  notificationSent Boolean   @default(false)
  notifiedAt       DateTime?

  // Metadata
  metadata  Json? // Additional webhook data
  createdAt DateTime @default(now())

  @@index([shop, createdAt(sort: Desc)]) // Recent alerts by shop
  @@index([shop, usagePercentage]) // Query by usage level
  @@index([alertLevel, notificationSent]) // Find unsent critical alerts
}

// ============================================
// APP-LEVEL SUBSCRIPTION MODELS
// ============================================

model Subscription {
  id                String  @id @default(uuid())
  shop              String
  customerId        String
  shopifyContractId String? @unique // Shopify subscription contract ID

  // Plan details
  planName String
  status   SubscriptionStatus @default(PENDING)
  amount   Decimal            @db.Decimal(10, 2)
  currency Currency           @default(USD)

  // Billing details
  billingInterval      String // DAY, WEEK, MONTH, YEAR
  billingIntervalCount Int       @default(1)
  nextBillingDate      DateTime?
  lastBillingDate      DateTime?

  // Trial information
  trialDays   Int       @default(0)
  trialEndsAt DateTime?

  // Payment method
  paymentMethodId    String?
  lastPaymentStatus  PaymentStatus?
  failedPaymentCount Int            @default(0)

  // Lifecycle dates
  activatedAt        DateTime?
  pausedAt           DateTime?
  resumedAt          DateTime?
  cancelledAt        DateTime?
  cancellationReason String?

  // Features and metadata
  features Json? // Array of feature strings
  metadata Json? // Additional subscription data

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  customer        Customer         @relation(fields: [customerId], references: [id])
  billingAttempts BillingAttempt[]

  @@unique([shop, customerId, planName])
  @@index([shop])
  @@index([customerId])
  @@index([status])
  @@index([nextBillingDate])
}

model BillingAttempt {
  id             String @id @default(uuid())
  subscriptionId String
  shop           String

  // Attempt details
  attemptNumber Int      @default(1)
  amount        Decimal  @db.Decimal(10, 2)
  currency      Currency

  // Status
  status       BillingAttemptStatus
  errorCode    String?
  errorMessage String?

  // Payment details
  paymentMethodId String?
  transactionId   String? // Shopify transaction ID

  // Retry information
  nextRetryAt      DateTime?
  retriesRemaining Int       @default(3)

  // Timestamps
  attemptedAt DateTime  @default(now())
  succeededAt DateTime?
  failedAt    DateTime?

  // Relations
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([status])
  @@index([attemptedAt])
}

model PaymentMethodValidation {
  id              String @id @default(uuid())
  shop            String
  customerId      String
  paymentMethodId String

  // Validation results
  isValid  Boolean
  errors   Json? // Array of error messages
  warnings Json? // Array of warning messages

  // Method details
  instrumentType String? // CREDIT_CARD, SHOP_PAY, etc.
  lastDigits     String?
  expiryMonth    Int?
  expiryYear     Int?
  brand          String?

  // Timestamps
  validatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([customerId, paymentMethodId])
  @@index([shop])
  @@index([customerId])
  @@index([isValid])
}

model MonthlyOrderUsage {
  id   String @id @default(uuid())
  shop String

  // Period tracking
  year  Int // e.g., 2025
  month Int // 1-12

  // Usage tracking
  orderCount Int    @default(0)
  planLimit  Int // 100 for free, 1000 for paid
  planName   String // Current plan name

  // Lock state (for plan enforcement)
  isLocked   Boolean   @default(false)
  lockedAt   DateTime? // When the shop was locked
  lockReason String? // Why the shop was locked

  // Metadata
  lastOrderDate DateTime? // Last order processed
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([shop, year, month])
  @@index([shop, year, month])
  @@index([shop, isLocked])
}

// Monthly email usage tracking (rate-based gating)
model MonthlyEmailUsage {
  id   String @id @default(uuid())
  shop String

  // Period tracking
  year  Int // e.g., 2025
  month Int // 1-12

  // Usage tracking
  emailCount Int    @default(0)
  planLimit  Int // 50 for free, 500 for pro, 2000 for max, unlimited for ultra
  planName   String // Current plan name

  // Breakdown by type
  campaignEmails      Int @default(0) // Marketing campaigns
  automationEmails    Int @default(0) // Triggered automations
  transactionalEmails Int @default(0) // Order confirmations, etc.

  // Lock state (for plan enforcement - soft limit)
  isLocked   Boolean   @default(false)
  lockedAt   DateTime? // When sending was blocked
  lockReason String? // Why emails were blocked

  // Metadata
  lastEmailDate DateTime? // Last email sent
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([shop, year, month])
  @@index([shop, year, month])
  @@index([shop, isLocked])
}

// ============================================
// SUBSCRIPTION MODELS
// ============================================

// Tier subscription records (recurring subscriptions)
// NOTE: tierId is nullable to allow tier deletion without blocking subscriptions
// When a tier is deleted, subscriptions become orphaned and tier resolution skips them
model TierSubscription {
  id         String   @id @default(uuid())
  shop       String
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tierId     String? // Nullable - allows tier deletion without cascade
  tier       Tier?    @relation(fields: [tierId], references: [id], onDelete: SetNull)

  // NEW: Link to tier product
  tierProductId String?
  tierProduct   TierProduct? @relation(fields: [tierProductId], references: [id], onDelete: SetNull)

  // Shopify Integration
  subscriptionContractId String @unique // Shopify's subscription contract ID
  sellingPlanId          String // Which selling plan (monthly/annual/etc)
  sellingPlanGroupId     String // Group containing all plans
  productVariantId       String // The tier product variant

  // Subscription Details
  status           SubscriptionStatus @default(PENDING)
  billingInterval  BillingInterval
  deliveryInterval BillingInterval // Usually same as billing

  // Pricing
  basePrice          Decimal  @db.Decimal(10, 2)
  discountPercentage Int      @default(0) // e.g., 15% for annual
  finalPrice         Decimal  @db.Decimal(10, 2)
  currency           Currency @default(USD)

  // Period Tracking
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  nextBillingDate    DateTime?
  lastBillingDate    DateTime?

  // Lifecycle
  trialEndsAt        DateTime? // Optional trial period
  startedAt          DateTime?
  pausedAt           DateTime?
  resumedAt          DateTime?
  cancelledAt        DateTime?
  cancellationReason String?

  // Billing
  billingAttempts    SubscriptionBillingAttempt[]
  failedPaymentCount Int                          @default(0)
  lastPaymentFailure DateTime?

  // Dunning & Retry Management
  pauseReason  String?
  skipCount    Int       @default(0)
  lastSkipDate DateTime?

  // Relations to track history
  tierChangeLogs    TierChangeLog[] // Tier changes related to this subscription
  customerAsCurrent Customer?           @relation("CurrentSubscription") // Reverse relation for currentSubscriptionId
  retryAttempts     SubscriptionRetry[] // Payment retry attempts
  events            SubscriptionEvent[] // Subscription events

  // Metadata
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop, customerId])
  @@index([shop, status])
  @@index([subscriptionContractId])
  @@index([status, nextBillingDate]) // For billing scheduler
}

model SubscriptionBillingAttempt {
  id             String           @id @default(uuid())
  subscriptionId String
  subscription   TierSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  // Attempt Details
  attemptNumber  Int    @default(1)
  idempotencyKey String @unique // Prevent duplicate charges

  // Status
  status BillingStatus @default(PENDING)

  // Financial
  amount   Decimal  @db.Decimal(10, 2)
  currency Currency @default(USD)

  // Shopify References
  shopifyOrderId          String? // Created order if successful
  shopifyBillingAttemptId String?
  shopifyInvoiceUrl       String? // For customer payment completion

  // Error Tracking
  errorCode    String?
  errorMessage String?
  errorDetails Json?

  // Timestamps
  scheduledFor DateTime
  attemptedAt  DateTime?
  succeededAt  DateTime?
  failedAt     DateTime?

  createdAt DateTime @default(now())

  @@index([subscriptionId, status])
  @@index([scheduledFor])
  @@index([idempotencyKey])
}

model SellingPlanGroup {
  id                        String @id @default(uuid())
  shop                      String
  shopifySellingPlanGroupId String @unique // Shopify's selling plan group ID (matches code references)

  // Configuration
  name         String // e.g., "Gold Tier Subscription Plans"
  merchantCode String // e.g., "tier-gold-subscription"

  // Associated Products
  tierProducts Json // Array of product/variant IDs

  // Plans in this group
  plans SellingPlan[]

  // Metadata
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([shopifySellingPlanGroupId])
}

model SellingPlan {
  id      String           @id @default(uuid())
  groupId String
  group   SellingPlanGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  shopifyPlanId String @unique // Shopify's selling plan ID

  // Plan Details
  name     String // e.g., "Monthly", "Annual"
  position Int // Display order

  // Billing Configuration
  billingInterval BillingInterval
  intervalCount   Int             @default(1) // e.g., 3 for quarterly (3 months)

  // Pricing
  discountType  DiscountType? // PERCENTAGE or FIXED_AMOUNT
  discountValue Decimal?      @db.Decimal(10, 2)

  // Options
  options Json // Customer-facing options

  // Metadata
  metadata  Json?
  createdAt DateTime @default(now())

  // Pricing management fields
  basePrice       Decimal?  @db.Decimal(10, 2)
  currentDiscount Decimal?  @db.Decimal(5, 2)
  lastPriceUpdate DateTime?

  // Relations
  pricingHistory SubscriptionPricingHistory[] // Pricing change history

  @@index([groupId])
  @@index([shopifyPlanId])
}

// ============================================
// PRICING MANAGEMENT MODELS
// ============================================

model SubscriptionPricingHistory {
  id               String          @id @default(uuid())
  shop             String
  sellingPlanId    String?
  sellingPlan      SellingPlan?    @relation(fields: [sellingPlanId], references: [id], onDelete: SetNull)
  tierId           String?
  tier             Tier?           @relation(fields: [tierId], references: [id], onDelete: SetNull)
  billingInterval  BillingInterval
  previousPrice    Decimal         @db.Decimal(10, 2)
  newPrice         Decimal         @db.Decimal(10, 2)
  previousDiscount Decimal         @db.Decimal(5, 2)
  newDiscount      Decimal         @db.Decimal(5, 2)
  changedBy        String // Admin user ID
  changeReason     String?
  effectiveDate    DateTime
  appliedToActive  Boolean         @default(false) // Whether applied to active subscriptions
  affectedCount    Int             @default(0) // Number of affected subscriptions
  revenueImpact    Decimal?        @db.Decimal(10, 2) // Estimated revenue impact
  metadata         Json?
  createdAt        DateTime        @default(now())

  @@index([shop, sellingPlanId])
  @@index([shop, tierId])
  @@index([shop, effectiveDate])
}

model SubscriptionPricingConfig {
  id                  String   @id @default(uuid())
  shop                String   @unique
  allowPriceEditing   Boolean  @default(true)
  requireApproval     Boolean  @default(false)
  minDiscountPercent  Decimal  @default(0) @db.Decimal(5, 2)
  maxDiscountPercent  Decimal  @default(50) @db.Decimal(5, 2)
  priceChangeNotice   Int      @default(30) // Days notice for price increases
  allowGrandfathering Boolean  @default(true) // Keep existing subs at old price
  autoSyncPrices      Boolean  @default(true) // Auto-sync with Shopify
  notifyCustomers     Boolean  @default(true) // Send price change notifications
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// Webhook idempotency tracking
model WebhookProcess {
  id             String   @id @default(uuid())
  shop           String
  topic          String
  idempotencyKey String   @unique
  payload        Json
  processedAt    DateTime @default(now())

  @@index([shop, topic, processedAt])
}

// Webhook error tracking
model WebhookError {
  id        String   @id @default(uuid())
  shop      String
  topic     String
  orderId   String?
  error     String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([shop, createdAt])
}

// Tier purchase records (one-time purchases)
// NOTE: tierId is nullable to allow tier deletion without cascading to purchases
// When a tier is deleted, purchases become orphaned and tier resolution skips them
model TierPurchase {
  id                String         @id @default(uuid())
  shop              String
  customerId        String
  customer          Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tierId            String? // Nullable - allows tier deletion without cascade
  tier              Tier?          @relation(fields: [tierId], references: [id], onDelete: SetNull)
  tierProductId     String
  tierProduct       TierProduct    @relation(fields: [tierProductId], references: [id])
  shopifyOrderId    String
  shopifyLineItemId String
  purchasePrice     Decimal        @db.Decimal(10, 2)
  currency          String
  startDate         DateTime
  endDate           DateTime? // NULL for lifetime
  status            PurchaseStatus @default(ACTIVE)
  metadata          Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([shop, shopifyOrderId, shopifyLineItemId])
  @@index([customerId, status])
  @@index([shop, status, endDate])
}

// Bulk operation logs
model BulkOperationLog {
  id            String   @id @default(uuid())
  shop          String
  operationType String
  report        Json
  successful    Int
  failed        Int
  total         Int
  createdAt     DateTime @default(now())

  @@index([shop, operationType, createdAt])
}

// ============================================
// SUBSCRIPTION MANAGEMENT MODELS
// ============================================

// Subscription retry tracking for failed payments
model SubscriptionRetry {
  id             String      @id @default(uuid())
  shop           String
  contractId     String // Shopify subscription contract ID
  subscriptionId String? // Local TierSubscription ID
  attemptNumber  Int
  scheduledFor   DateTime
  executedAt     DateTime?
  status         RetryStatus
  errorCode      String?
  errorMessage   String?
  billingAmount  Decimal?    @db.Decimal(10, 2)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  subscription TierSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([shop, status])
  @@index([contractId, status])
  @@index([scheduledFor])
  @@index([shop, contractId, attemptNumber])
}

// Subscription event logging
model SubscriptionEvent {
  id             String                @id @default(uuid())
  shop           String
  contractId     String // Shopify subscription contract ID
  subscriptionId String? // Local TierSubscription ID
  customerId     String?
  eventType      SubscriptionEventType
  eventData      Json? // Additional event-specific data
  processedAt    DateTime?
  createdAt      DateTime              @default(now())

  // Relations
  subscription TierSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  customer     Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([contractId])
  @@index([eventType, processedAt])
  @@index([shop, eventType, createdAt])
  @@index([customerId, eventType])
}

// Distributed lock for webhook deduplication
model SubscriptionProcessingLock {
  id         String   @id @default(uuid())
  lockKey    String   @unique // Unique identifier for the operation being locked
  operation  String // Type of operation (e.g., "webhook:CONTRACT_CREATE")
  acquiredAt DateTime @default(now())
  expiresAt  DateTime // When the lock should auto-expire
  metadata   Json? // Additional context about the lock

  @@index([expiresAt]) // For cleanup queries
  @@index([operation, acquiredAt]) // For monitoring
}

// ============================================
// ORDER TRACKING MODELS
// ============================================

model Order {
  id                 String @id @default(uuid())
  shop               String
  shopifyOrderId     String // Shopify order ID (e.g., "5843219374293")
  shopifyOrderNumber String // Order number visible to customer (e.g., "#1234")
  shopifyOrderName   String // Order name (e.g., "#1234" or "SHOP-1234")

  // Customer relationship
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Order details
  email    String
  currency String // Shop currency code (matches totalPrice currency)

  // Multi-currency tracking (for international orders)
  // When customer pays in different currency than shop, we track both
  presentmentCurrency String? // Customer's currency code (what they paid in)
  presentmentTotal    Decimal? @db.Decimal(10, 2) // Amount in customer's currency
  exchangeRate        Decimal? @db.Decimal(10, 6) // Rate: presentment / shop (for audit)

  // Financial data - stored as Decimal for precision (all in SHOP currency)
  subtotalPrice  Decimal @db.Decimal(10, 2) // Before discounts/shipping/tax
  totalDiscounts Decimal @db.Decimal(10, 2) // Total discounts applied
  totalShipping  Decimal @db.Decimal(10, 2) // Shipping cost
  totalTax       Decimal @db.Decimal(10, 2) // Tax amount
  totalPrice     Decimal @db.Decimal(10, 2) // Final total paid by customer

  // Refund tracking
  totalRefunded Decimal @default(0) @db.Decimal(10, 2) // Amount refunded
  netAmount     Decimal @db.Decimal(10, 2) // totalPrice - totalRefunded

  // Status tracking
  financialStatus   OrderFinancialStatus // paid, pending, refunded, etc.
  fulfillmentStatus String? // fulfilled, partial, unfulfilled, null

  // Cashback calculation data
  cashbackEligible       Boolean  @default(true) // Some orders may be excluded
  cashbackPercent        Int? // Cashback rate at time of order
  cashbackPercentAtOrder Int? // Exact percent used (for recalculation accuracy)
  cashbackAmount         Decimal? @db.Decimal(10, 2) // Cashback earned
  cashbackProcessed      Boolean  @default(false) // Has cashback been credited

  // Tier data at time of order
  tierIdAtOrder   String? // Customer's tier when order was placed
  tierNameAtOrder String? // Store tier name for historical reference

  // Dates
  shopifyCreatedAt DateTime // When order was created in Shopify
  shopifyUpdatedAt DateTime // Last update in Shopify
  processedAt      DateTime? // When we processed the order
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Sync tracking fields
  syncedAt    DateTime? // When this order was last synced from Shopify
  syncVersion Int       @default(1) // Track sync version for updates

  // Relations
  lineItems           OrderLineItem[]
  refunds             OrderRefund[]
  creditLedgerEntries StoreCreditLedger[] @relation("OrderLedgerEntries")

  // Indexes
  @@unique([shop, shopifyOrderId])
  @@index([shop, customerId])
  @@index([shop, shopifyCreatedAt])
  @@index([shop, financialStatus])
  @@index([customerId, shopifyCreatedAt])
  @@index([shop, shopifyUpdatedAt]) // For incremental sync queries
  @@index([shop, syncedAt]) // For tracking sync status
}

model OrderLineItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  shopifyLineItemId String // Shopify line item ID
  shopifyProductId  String? // Product ID
  shopifyVariantId  String? // Variant ID

  // Item details
  title        String // Product title
  variantTitle String? // Variant title
  sku          String? // SKU
  vendor       String? // Vendor name

  // Quantities and pricing
  quantity      Int // Quantity ordered
  price         Decimal @db.Decimal(10, 2) // Unit price
  totalPrice    Decimal @db.Decimal(10, 2) // quantity * price
  totalDiscount Decimal @db.Decimal(10, 2) // Discounts on this item

  // Flags
  requiresShipping Boolean @default(true)
  taxable          Boolean @default(true)
  giftCard         Boolean @default(false)

  // Tier product tracking
  isTierProduct Boolean @default(false)
  tierProductId String? // Link to TierProduct if applicable

  createdAt DateTime @default(now())

  @@unique([orderId, shopifyLineItemId])
  @@index([orderId])
}

model OrderRefund {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  shopifyRefundId String // Shopify refund ID

  // Refund amounts
  amount         Decimal @db.Decimal(10, 2) // Total refund amount
  shippingAmount Decimal @db.Decimal(10, 2) // Shipping refunded
  taxAmount      Decimal @db.Decimal(10, 2) // Tax refunded

  // Reason and notes
  reason String? // restock, customer, damage, other
  note   String? // Admin note

  // Cashback adjustment
  cashbackAdjustment Decimal? @db.Decimal(10, 2) // Cashback to reverse
  cashbackProcessed  Boolean  @default(false)

  shopifyCreatedAt DateTime // When refund was created in Shopify
  processedAt      DateTime? // When we processed the refund
  createdAt        DateTime  @default(now())

  // Relations
  refundLineItems   OrderRefundLineItem[]
  creditLedgerEntry StoreCreditLedger?    @relation("RefundLedgerEntry")

  @@unique([orderId, shopifyRefundId])
  @@index([orderId])
}

model OrderRefundLineItem {
  id       String      @id @default(uuid())
  refundId String
  refund   OrderRefund @relation(fields: [refundId], references: [id], onDelete: Cascade)

  shopifyLineItemId String // Original line item ID
  quantity          Int // Quantity refunded
  subtotal          Decimal @db.Decimal(10, 2) // Refund amount for this item

  createdAt DateTime @default(now())

  @@index([refundId])
}

//Enums

enum CreditSyncStatus {
  PENDING // Not yet synced to Shopify
  SYNCING // Currently syncing
  SYNCED // Successfully synced
  FAILED // Sync failed
  NOT_APPLICABLE // Doesn't need sync (e.g., manual adjustments)
}

enum Currency {
  USD // US Dollar
  EUR // Euro
  GBP // British Pound
  CAD // Canadian Dollar
  AUD // Australian Dollar
  JPY // Japanese Yen
  CHF // Swiss Franc
  CNY // Chinese Yuan
  SEK // Swedish Krona
  NZD // New Zealand Dollar
  NOK // Norwegian Krone
  MXN // Mexican Peso
  SGD // Singapore Dollar
  HKD // Hong Kong Dollar
  KRW // South Korean Won
  TRY // Turkish Lira
  INR // Indian Rupee
  RUB // Russian Ruble
  BRL // Brazilian Real
  ZAR // South African Rand
  AED // UAE Dirham
  PLN // Polish Zloty
  DKK // Danish Krone
  THB // Thai Baht
  IDR // Indonesian Rupiah
  HUF // Hungarian Forint
  CZK // Czech Koruna
  ILS // Israeli Shekel
  CLP // Chilean Peso
  PHP // Philippine Peso
  RON // Romanian Leu
  MYR // Malaysian Ringgit
}

enum CurrencyDisplayType {
  SYMBOL // Currency Symbol (£)
  CODE // Currency Code (GBP)
}

enum RecalculationFrequency {
  DAILY // Recalculate every day
  WEEKLY // Recalculate every week
  MONTHLY // Recalculate every month
  QUARTERLY // Recalculate every quarter (90 days)
}

enum WidgetThemeMode {
  LIGHT // Light theme with white background
  DARK // Dark theme with dark background
  CUSTOM // Custom colors defined by merchant
}

enum EvaluationPeriod {
  ANNUAL // 12 months rolling (default)
  LIFETIME // All-time spending, never expires
}

enum LedgerEntryType {
  CASHBACK_EARNED
  ORDER_PAYMENT
  REFUND_CREDIT
  REFUND_CLAWBACK
  MANUAL_ADJUSTMENT
  SHOPIFY_SYNC
  CONVERTED_TO_GIFT_CARD // Store credit converted to gift card
}

enum TierChangeType {
  INITIAL_ASSIGNMENT // First tier assignment
  UPGRADE // Moving to a higher tier
  DOWNGRADE // Moving to a lower tier  
}

enum TierTriggerType {
  ACCOUNT_CREATED // Initial tier on account creation
  PERIODIC_REVIEW // System periodic evaluation
  SPENDING_MILESTONE // Hit specific spending threshold
  MANUAL_ADMIN // Manual change by admin
  PRODUCT_PURCHASE // Tier assigned via product purchase
  SUBSCRIPTION_STARTED // Initial subscription activation
  SUBSCRIPTION_RENEWED // Subscription renewal
  SUBSCRIPTION_UPGRADED // Plan upgrade
  SUBSCRIPTION_DOWNGRADED // Plan downgrade
  SUBSCRIPTION_CANCELLED // Subscription cancelled
  SUBSCRIPTION_PURCHASE // Purchase of subscription tier
}

enum PurchaseStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  REFUNDED
}

// Tier source for CustomerTierState - indicates where the customer's current tier comes from
enum TierSource {
  MANUAL_OVERRIDE // Admin explicitly set this tier
  TIER_SUBSCRIPTION // Customer has active recurring subscription
  TIER_PURCHASE // Customer has active one-time purchase
  SPENDING_BASED // Automatic calculation based on spending
  DEFAULT_BASE_TIER // Shop's configured default tier for new customers
  NONE // No tier assigned
}

// ============================================
