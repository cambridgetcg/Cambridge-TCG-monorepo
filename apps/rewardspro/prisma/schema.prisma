model EmailTemplate {
  id                String              @id @default(uuid())
  shop              String

  // Template details
  name              String              // Template name (e.g., "Welcome Email", "Tier Upgrade")
  type              String              // welcome, tier_change, points_reminder, etc.
  subject           String              // Email subject line
  content           Json                // Block-based content structure
  previewText       String?             // Preview text for email clients
  bodyHtml          String?             // HTML content of email
  bodyText          String?             // Plain text content of email
  htmlContent       String?             // Full HTML content (compiled)

  // Status
  isActive          Boolean             @default(true)

  // Timestamps
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  // Relations
  campaigns         EmailCampaign[]
  automations       EmailAutomation[]

  @@index([shop, type])
  @@index([shop, isActive])
}

model EmailCampaign {
  id                String              @id @default(uuid())
  shop              String

  // Campaign details
  name              String              // Campaign name
  templateId        String              // Reference to EmailTemplate
  template          EmailTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)

  // Status
  status            String              // draft, scheduled, sending, sent, failed

  // Segmentation
  segmentRules      Json                // Segment criteria

  // Scheduling
  scheduledFor      DateTime?           // When to send
  sentAt            DateTime?           // When actually sent

  // Metrics
  metrics           Json?               // { sent, delivered, opened, clicked, revenue, orders }

  // Timestamps
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([shop, status])
  @@index([shop, scheduledFor])
  @@index([sentAt(sort: Desc)])
}

model EmailAutomation {
  id                String              @id @default(uuid())
  shop              String

  // Automation details
  name              String              // Automation name
  trigger           String              // welcome, tier_upgrade, points_expiry, etc.
  templateId        String              // Reference to EmailTemplate
  template          EmailTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)

  // Status
  isEnabled         Boolean             @default(true)

  // Conditions & Timing
  conditions        Json                // Conditional logic
  delayMinutes      Int                 @default(0)  // Delay before sending

  // Metrics
  totalSent         Int                 @default(0)
  totalOpened       Int                 @default(0)
  totalClicked      Int                 @default(0)

  // Timestamps
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([shop, trigger])
  @@index([shop, isEnabled])
}

model EmailSettings {
  shop              String              @id  // Shop domain (primary key)

  // Sender configuration
  senderName        String              @default("Store")
  senderEmail       String              // From email
  replyToEmail      String?             // Reply-to email

  // Brand customization
  brandColors       Json                @default("{\"primary\":\"#5C6AC4\",\"secondary\":\"#F4F6F8\"}")
  typography        Json                @default("{\"fontFamily\":\"Inter\"}")
  headerContent     Json?               // Logo, navigation, etc.
  footerContent     Json?               // Legal, social, etc.

  // Compliance
  suppressionList   String[]            @default([])  // Emails to never send to
  includeUnsubscribe Boolean            @default(true)
  includePhysicalAddress Boolean        @default(true)
  gdprEnabled       Boolean             @default(true)

  // Send controls
  sendTimePrefs     Json                @default("{\"preferredTime\":\"10:00\",\"timezone\":\"America/New_York\",\"dailyLimit\":1000,\"hourlyLimit\":100}")

  // SendGrid Integration
  sendingMode       SendingMode         @default(SHARED)  // SHARED or CUSTOM_DOMAIN
  customDomainId    String?             // Reference to SendGridDomain if using custom domain

  // ═══════════════════════════════════════════════════════════════════════
  // EMAIL PROVIDER SELECTION
  // ═══════════════════════════════════════════════════════════════════════
  emailProvider           EmailProvider   @default(SENDGRID)  // Which provider to use

  // ═══════════════════════════════════════════════════════════════════════
  // KLAVIYO CONFIGURATION
  // ═══════════════════════════════════════════════════════════════════════
  klaviyoEnabled          Boolean         @default(false)      // Feature flag
  klaviyoApiKey           String?         // Private API key (encrypted in production)
  klaviyoPublicKey        String?         // 6-char public key for client-side
  klaviyoDefaultListId    String?         // Default list for new subscribers
  klaviyoIntegrationId    String?         // Custom integration identifier

  // ═══════════════════════════════════════════════════════════════════════
  // KLAVIYO SYNC CONFIGURATION
  // ═══════════════════════════════════════════════════════════════════════
  klaviyoSyncProfiles     Boolean         @default(true)       // Auto-sync customer profiles
  klaviyoSyncEvents       Boolean         @default(true)       // Auto-sync order/tier events
  klaviyoSyncConsent      String          @default("EXPLICIT") // EXPLICIT or IMPLICIT
  klaviyoLastSyncAt       DateTime?       // Last successful full sync
  klaviyoSyncStatus       String?         // IDLE, SYNCING, ERROR
  klaviyoSyncError        String?         // Last sync error message

  // ═══════════════════════════════════════════════════════════════════════
  // KLAVIYO WEBHOOK CONFIGURATION (if using Advanced KDP)
  // ═══════════════════════════════════════════════════════════════════════
  klaviyoWebhookSecret    String?         // For signature verification
  klaviyoWebhookId        String?         // Registered webhook ID
  klaviyoWebhookEnabled   Boolean         @default(false)

  // ═══════════════════════════════════════════════════════════════════════
  // KLAVIYO OAUTH CONFIGURATION (Preferred over API key)
  // ═══════════════════════════════════════════════════════════════════════
  klaviyoOAuthConnected   Boolean         @default(false)  // Is OAuth connected?
  klaviyoAccessToken      String?         // OAuth access token (short-lived)
  klaviyoRefreshToken     String?         // OAuth refresh token (long-lived)
  klaviyoTokenExpiresAt   DateTime?       // When access token expires

  // Timestamps
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  // Relations
  customDomain      SendGridDomain?     @relation(fields: [customDomainId], references: [id])
}

// SendGrid Domain Authentication for branded sending
model SendGridDomain {
  id                String              @id @default(uuid())
  shop              String

  // Domain details
  domain            String              // e.g., "mail.merchantstore.com"
  subdomain         String?             // e.g., "mail" (optional prefix)

  // SendGrid IDs
  sendgridDomainId  String?             // SendGrid's domain authentication ID
  sendgridDnsRecords Json?              // DNS records from SendGrid API

  // Verification status
  status            DomainStatus        @default(PENDING)
  verifiedAt        DateTime?
  lastCheckedAt     DateTime?

  // DNS record verification status
  dkimVerified      Boolean             @default(false)
  spfVerified       Boolean             @default(false)
  dmarcConfigured   Boolean             @default(false)

  // Error tracking
  lastError         String?
  errorCount        Int                 @default(0)

  // Timestamps
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  // Relations
  emailSettings     EmailSettings[]

  @@unique([shop, domain])
  @@index([shop, status])
}

enum SendingMode {
  SHARED          // Send from rewardspro.io domain
  CUSTOM_DOMAIN   // Send from merchant's authenticated domain
}

