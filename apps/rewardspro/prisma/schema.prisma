  PAYMENT_SUCCESS
  PAYMENT_FAILED
  PAYMENT_RETRY_SCHEDULED
  DELIVERY_SKIPPED
  BILLING_UPDATED
  PLAN_CHANGED
}

enum PaymentStatus {
