enum SendingMode {
  SHARED // Send from rewardspro.io domain
  CUSTOM_DOMAIN // Send from merchant's authenticated domain
}

// ============================================
// KLAVIYO INTEGRATION ENUMS
// ============================================

enum EmailProvider {
  SENDGRID // Current default provider
  KLAVIYO // Klaviyo as primary provider
  HYBRID // SendGrid for transactional, Klaviyo for marketing
}

// Marketing Hub Mode - determines which UI/features merchants see
enum MarketingHubMode {
  UNCONFIGURED // Never made a choice - show choice modal
  INHOUSE // Using in-house SendGrid campaigns/templates
  KLAVIYO // Using Klaviyo for all marketing (simplified hub UI)
}

enum KlaviyoSyncStatus {
  PENDING // Never synced
  SYNCED // Successfully synced
  SYNCING // Currently syncing
  STALE // Needs re-sync (local data changed)
  ERROR // Sync failed
  UNSUBSCRIBED // Profile unsubscribed, no longer sync
}

enum KlaviyoConsentStatus {
  UNKNOWN // Not yet fetched from Klaviyo
  SUBSCRIBED // Opted in to receive marketing
  NEVER_SUBSCRIBED // Never subscribed (transactional only)
  UNSUBSCRIBED // Previously subscribed, now opted out
  SUPPRESSED // Manually suppressed
}

enum KlaviyoEventStatus {
  PENDING // Not yet sent
  SENDING // Currently sending
  SENT // Successfully sent to Klaviyo
  FAILED // Send failed (will retry)
  ABANDONED // Max retries exceeded
}

enum DomainStatus {
  PENDING // Domain created, waiting for DNS setup
  DNS_PENDING // DNS records provided, waiting for verification
  VERIFYING // Currently checking DNS records
  VERIFIED // Domain fully verified and ready
  FAILED // Verification failed
}

model EmailEvent {
  id   String @id @default(uuid())
  shop String

  // Event details
  campaignId    String? // Reference to campaign if applicable
  automationId  String? // Reference to automation if applicable
  customerId    String? // Shopify customer ID
  customerEmail String // Customer email

  // Event type
  eventType String // sent, delivered, opened, clicked, bounced, complained, unsubscribed

  // Metadata
  metadata Json? // Additional event data (links clicked, bounce reason, etc.)

  // Timestamps
  createdAt DateTime @default(now())

  @@index([shop, eventType, createdAt(sort: Desc)])
  @@index([campaignId, eventType])
  @@index([customerEmail, eventType])
}

// Analytics-powered marketing recommendations
model AnalyticsRecommendation {
  id               String    @id @default(uuid())
  shop             String
  slug             String // Unique identifier for the recommendation type
  type             String // e.g., 'inactive_customers', 'tier_upgrade_opportunity'
  title            String
  description      String    @db.Text
  segmentPayload   Json // Customer segment criteria and rules
  metadata         Json? // Additional recommendation data
  predictedRevenue Float?
  affectedCount    Int // Number of customers affected
  priority         Int       @default(0) // Higher number = higher priority
  status           String    @default("pending") // pending, applied, dismissed, expired
  appliedAt        DateTime?
  dismissedAt      DateTime?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([shop, slug])
  @@index([shop, status])
  @@index([shop, expiresAt])
}

// ============================================
// KLAVIYO INTEGRATION MODELS
// ============================================

// Tracks the synchronization state between RewardsPro customers and Klaviyo profiles
model KlaviyoProfile {
  id   String @id @default(uuid())
  shop String

  // Identity mapping
  customerId        String // RewardsPro Customer.id (UUID)
  klaviyoProfileId  String // Klaviyo's profile ID (e.g., "01HXYZ...")
  email             String // Denormalized for quick lookups
  shopifyCustomerId String? // Shopify customer ID (stored as external_id in Klaviyo)

  // Sync status tracking
  syncStatus     KlaviyoSyncStatus @default(PENDING)
  syncedAt       DateTime? // Last successful sync timestamp
  syncVersion    Int               @default(1) // Increment on each sync
  lastSyncError  String? // Error message if sync failed
  syncRetryCount Int               @default(0) // Failed sync attempts

  // Data freshness tracking
  profileDataHash String? // Hash of last synced profile data (for change detection)
  lastEventAt     DateTime? // When last event was tracked for this profile
  lastEventType   String? // Type of last event (e.g., "Placed Order")

  // Phase 1 Gap Fill: Segment tracking for change detection
  lastKnownSegment String? // CHAMPION, LOYAL, ENGAGED, AT_RISK, LAPSED, NEW

  // Consent & subscription status (cached from Klaviyo)
  emailConsent     KlaviyoConsentStatus @default(UNKNOWN)
  smsConsent       KlaviyoConsentStatus @default(UNKNOWN)
  consentUpdatedAt DateTime?

  // List memberships (cached)
  listIds    String[] @default([]) // Klaviyo list IDs profile belongs to
  segmentIds String[] @default([]) // Klaviyo segment IDs (cached)

  // Metadata
  metadata  Json? // Additional sync metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, customerId]) // One Klaviyo profile per customer per shop
  @@unique([shop, klaviyoProfileId]) // Klaviyo profile ID unique per shop
  @@index([shop, email]) // Fast email lookups
  @@index([shop, syncStatus]) // Find profiles needing sync
  @@index([shop, syncedAt]) // Find stale profiles
  @@index([shop, emailConsent]) // Filter by consent status
  @@index([shopifyCustomerId]) // Cross-reference with Shopify
}

// Records all events sent to Klaviyo for deduplication, audit trail, and retry
model KlaviyoEvent {
  id   String @id @default(uuid())
  shop String

  // Event identification
  eventType  String // e.g., "Placed Order", "Tier Upgraded"
  uniqueId   String // Klaviyo unique_id for deduplication
  metricName String // Klaviyo metric name

  // Profile reference
  customerId       String? // RewardsPro customer ID
  klaviyoProfileId String? // Klaviyo profile ID (if known)
  customerEmail    String // Email used in event

  // Event data
  eventValue      Decimal? @db.Decimal(10, 2) // $value for revenue tracking
  eventProperties Json // Full event properties sent to Klaviyo
  eventTime       DateTime // Timestamp of the event

  // Source references
  orderId         String? // If triggered by order
  orderRefundId   String? // If triggered by refund
  tierChangeLogId String? // If triggered by tier change

  // Sync status
  status       KlaviyoEventStatus @default(PENDING)
  sentAt       DateTime? // When sent to Klaviyo
  errorMessage String? // Error if failed
  retryCount   Int                @default(0)
  nextRetryAt  DateTime? // Scheduled retry time

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, uniqueId]) // Prevent duplicate events
  @@index([shop, eventType, createdAt(sort: Desc)])
  @@index([shop, status]) // Find events needing retry
  @@index([customerId, eventType]) // Customer's event history
  @@index([orderId]) // Events for an order
  @@index([nextRetryAt]) // Retry scheduler
}

// Caches Klaviyo lists for UI and sync operations
model KlaviyoList {
  id   String @id @default(uuid())
  shop String

  // Klaviyo list data
  klaviyoListId String // Klaviyo's list ID
  name          String // List name
  listType      String @default("list") // "list" or "segment"

  // Mapping to RewardsPro
  purpose      String? // e.g., "subscribers", "vip_customers", "tier_gold"
  segmentRules Json? // RewardsPro segment rules that map to this list
  isDefault    Boolean @default(false) // Default list for new subscribers
  isManaged    Boolean @default(false) // Managed by RewardsPro (vs user-created)

  // Cache data
  profileCount Int       @default(0) // Cached count
  lastSyncedAt DateTime? // When cache was refreshed

  // Metadata
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, klaviyoListId])
  @@index([shop, isDefault])
  @@index([shop, purpose])
}

// Merchant configuration for Klaviyo automation events
model KlaviyoAutomationSettings {
  id   String @id @default(uuid())
  shop String @unique

  // Master toggle
  automationsEnabled Boolean @default(false)

  // Event toggles - Customer lifecycle
  sendCustomerEnrolled    Boolean @default(true)
  sendCustomerBirthday    Boolean @default(true)
  sendCustomerAnniversary Boolean @default(true)

  // Event toggles - Transaction events
  sendOrderPlaced      Boolean @default(true)
  sendCashbackEarned   Boolean @default(true)
  sendCashbackRedeemed Boolean @default(true)

  // Event toggles - Tier events
  sendTierUpgraded    Boolean @default(true)
  sendTierDowngraded  Boolean @default(true)
  sendTierUpgradeNear Boolean @default(true)
  sendVipAchieved     Boolean @default(true)

  // Event toggles - Engagement events
  sendPointsExpiring  Boolean @default(true)
  sendBalanceReminder Boolean @default(true)
  sendWinBack         Boolean @default(true)

  // Phase 1 Gap Fill - New event toggles
  sendCashbackAdjusted       Boolean @default(true) // Manual adjustment notifications
  sendCustomerBecameChampion Boolean @default(true) // Champion segment achieved
  sendCustomerBecameLoyal    Boolean @default(true) // Loyal segment achieved

  // Timing configuration
  pointsExpiryWarningDays Int[] @default([30, 7, 1]) // Days before expiry
  balanceReminderDays     Int   @default(30) // Days since last order
  winBackTriggerDays      Int[] @default([60, 90]) // Inactivity triggers
  tierNudgeThreshold      Int   @default(80) // Percentage progress

  // Cooldowns (prevent over-emailing)
  expiryReminderCooldownDays  Int @default(7)
  balanceReminderCooldownDays Int @default(14)
  winBackCooldownDays         Int @default(30)
  tierNudgeCooldownDays       Int @default(14)

  // ============================================
  // Rewards Engagement Event Toggles
  // ============================================

  // Points events
  sendPointsEvents Boolean @default(true) // Points earned/spent/milestone

  // Raffle events
  sendRaffleEvents Boolean @default(true) // Raffle entry/win/ending soon

  // Mystery box events
  sendMysteryBoxEvents Boolean @default(true) // Mystery box open/win

  // General rewards engagement
  sendRewardsEngagement Boolean @default(true) // Challenges, bonus events, dormancy

  // Rewards engagement timing
  rewardsDormancyDays    Int @default(30) // Days without rewards activity
  raffleReminderHours    Int @default(24) // Hours before raffle ends
  highPointsThreshold    Int @default(500) // Points balance to trigger reminder
  highPointsDormancyDays Int @default(14) // Days without spend

  // ============================================
  // Gift Card & Store Credit Event Toggles
  // ============================================

  // Gift card events
  sendGiftCardEvents Boolean @default(true) // Gift card purchased/received/redeemed/expiring

  // Store credit events
  sendStoreCreditEvents Boolean @default(true) // Credit earned/spent/converted/milestone/reminder

  // Gift card/store credit timing
  giftCardExpiryWarningDays Int @default(7) // Days before gift card expires
  storeCreditReminderDays   Int @default(30) // Days of unused store credit

  // Scheduling
  scheduledJobTime String @default("06:00") // HH:MM in shop timezone
  timezone         String @default("America/New_York")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// POINTS ENGAGEMENT SYSTEM MODELS
// ============================================
// These models power the gamified points system that runs alongside
// the cashback rewards. Points are a separate "fun" currency used for
// raffles, mystery boxes, spin wheels, and challenges.

model PointsConfig {
  id   String @id @default(uuid())
  shop String @unique

  // System Enable/Disable
  isEnabled Boolean @default(false) // Master toggle for points system

  // Currency Branding
  currencyName       String @default("Points") // Display name (e.g., "Stars", "Gems")
  currencyNamePlural String @default("Points") // Plural form
  currencyIcon       String @default("⭐") // Emoji or icon identifier

  // Enhanced Icon System (Phase 2-3) - DISABLED: Migration not applied to production
  // To enable: Run prisma/migrations/manual/20250118_add_enhanced_icon_system.sql
  // currencyIconType  String  @default("emoji") // "emoji" | "upload" | "library"
  // currencyIconUrl   String? // URL for uploaded custom icon (SVG/PNG)
  // currencyIconId    String? // ID for icon library selection (e.g., "lucide:star")
  // currencyIconColor String? // Hex color for library icons (e.g., "#5C6AC4")

  // Earning Rules
  pointsPerDollar Int                @default(10) // Base points earned per $1 spent
  roundingMode    PointsRoundingMode @default(FLOOR) // How to round fractional points

  // Expiration Settings
  pointsExpire          Boolean @default(false) // Whether points expire
  expirationDays        Int     @default(365) // Days until points expire (if enabled)
  expirationWarningDays Int     @default(30) // Days before expiry to send warning

  // Feature Toggles
  rafflesEnabled       Boolean @default(false)
  mysteryBoxesEnabled  Boolean @default(false)
  spinWheelEnabled     Boolean @default(false)
  challengesEnabled    Boolean @default(false)
  scratchCardsEnabled  Boolean @default(false)
  givebackPoolsEnabled Boolean @default(false)

  // Daily Spin Wheel Settings
  dailySpinEnabled   Boolean @default(true) // Free daily spin
  dailySpinResetHour Int     @default(0) // Hour (0-23) when daily spin resets
  premiumSpinCost    Int     @default(500) // Points cost for premium spin

  // Streak Tracking
  streakBonusEnabled    Boolean @default(false)
  streakBonusMultiplier Decimal @default(0.1) @db.Decimal(3, 2) // +10% per day, max varies

  // ============================================
  // MISSION SYSTEM SETTINGS (Gamification)
  // ============================================

  // Master Toggle
  missionsEnabled Boolean @default(false)

  // XP Configuration
  xpEnabled      Boolean @default(true) // Enable XP system
  xpPerLevel     Int     @default(100) // Base XP required per level
  xpLevelScaling Decimal @default(1.2) @db.Decimal(3, 2) // XP multiplier per level (+20%)

  // Mission Streak Configuration (consecutive days completing missions)
  missionStreakBonusEnabled Boolean @default(true)
  missionStreakBonusPercent Int     @default(10) // +10% XP per streak day
  maxMissionStreakBonus     Int     @default(100) // Max +100% bonus

  // Mission Combo Configuration (multiple missions same day)
  comboEnabled      Boolean @default(true)
  comboBonusPercent Int     @default(25) // +25% XP per additional mission
  maxComboBonus     Int     @default(100) // Max +100% bonus

  // Mission Reset Time (shop timezone)
  missionResetHour Int @default(0) // Hour (0-23) when daily missions reset

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
}

model PointsLedger {
  id         String @id @default(uuid())
  shop       String
  customerId String

  // Transaction Details
  amount  Int // Positive = earn, negative = spend
  balance Int // Running balance after transaction
  type    PointsLedgerType

  // Source Reference (polymorphic - only one should be set)
  orderId          String? // If from order earning
  raffleEntryId    String? // If spent on raffle
  mysteryBoxOpenId String? // If spent on mystery box
  spinResultId     String? // If from spin wheel
  challengeId      String? // If from challenge completion
  scratchCardId    String? // If from scratch card
  bonusEventId     String? // If from bonus event

  // Expiration Tracking
  expiresAt DateTime? // When these points expire (null = never)
  expired   Boolean   @default(false) // True if points have been expired

  // Descriptive
  description String? // Human-readable description
  metadata    Json? // Additional context data

  createdAt DateTime @default(now())

  // Relations
  customer    Customer     @relation("PointsLedgerEntries", fields: [customerId], references: [id], onDelete: Cascade)
  raffleEntry RaffleEntry? @relation("RaffleEntryLedger", fields: [raffleEntryId], references: [id], onDelete: SetNull)

  @@index([shop, customerId])
  @@index([raffleEntryId])
  @@index([customerId, createdAt(sort: Desc)])
  @@index([type])
  @@index([expiresAt, expired]) // For expiration cron job
  @@index([shop, createdAt(sort: Desc)]) // For analytics queries
}

// Enum for points transaction types
enum PointsLedgerType {
  // Earning
  ORDER_EARNED // Points earned from purchase
  CHALLENGE_COMPLETED // Points from completing a challenge
  SPIN_WHEEL_WIN // Points won from spin wheel
  SCRATCH_CARD_WIN // Points won from scratch card
  MYSTERY_BOX_WIN // Points won from mystery box (rare)
  BONUS_EVENT // Points from multiplier events
  REFERRAL_BONUS // Points from referring friends
  MANUAL_CREDIT // Admin manual credit
  STREAK_BONUS // Daily login streak bonus

  // Spending
  RAFFLE_ENTRY // Points spent on raffle entry
  MYSTERY_BOX_OPEN // Points spent to open mystery box
  PREMIUM_SPIN // Points spent on premium spin
  GIVEBACK_DONATION // Points donated to giveback pool
  MANUAL_DEBIT // Admin manual debit

  // Adjustments
  EXPIRATION // Points expired (negative)
  REFUND_CLAWBACK // Points clawed back due to order refund
  SYSTEM_ADJUSTMENT // System correction
}

enum PointsRoundingMode {
  FLOOR // Round down (10.9 -> 10)
  CEIL // Round up (10.1 -> 11)
  ROUND // Standard rounding (10.5 -> 11, 10.4 -> 10)
}

// ============================================
// RAFFLES SYSTEM MODELS
// ============================================
// Raffles allow customers to spend points for a chance to win prizes.
// Supports multiple prize tiers, various draw types, and guaranteed winners.

model Raffle {
  id   String @id @default(uuid())
  shop String

  // Basic Info
  name        String // "Spring Giveaway", "Mystery Prize Draw"
  description String? @db.Text // Rich description for customers
  imageUrl    String? // Hero image for the raffle

  // Status & Timing
  status   RaffleStatus @default(DRAFT)
  startsAt DateTime // When entries open
  endsAt   DateTime // When entries close
  drawAt   DateTime? // When winners are drawn (null = immediate after endsAt)
  drawnAt  DateTime? // When draw actually occurred

  // Entry Rules
  entryCost             Int  @default(100) // Points per entry
  maxEntriesTotal       Int? // Max entries per raffle (null = unlimited)
  maxEntriesPerCustomer Int  @default(10) // Max entries per customer

  // Draw Configuration
  drawType     RaffleDrawType @default(RANDOM)
  totalWinners Int            @default(1) // How many winners to select

  // Entry Stats (denormalized for performance)
  totalEntries   Int @default(0)
  uniqueEntrants Int @default(0)
  totalPrizePool Int @default(0) // Accumulated points value

  // Visibility & Eligibility
  isPublic         Boolean @default(true) // Show on storefront
  tierRestrictions Json? // { "allowedTierIds": ["tier-1", "tier-2"] } or null for all
  minimumTier      String? // Minimum tier required to enter (by tier ID)

  // Psychology Features (Gamification)
  enableInstantWins     Boolean @default(false) // Allow instant-win micro-prizes
  enableActivityFeed    Boolean @default(true) // Show social proof activity feed
  enableStreakBonuses   Boolean @default(true) // Apply streak multipliers
  enableLuckyNumbers    Boolean @default(true) // Award lucky number bonuses
  dailyFreeEntries      Int     @default(0) // Free entries per day (0 = disabled)
  earlyBirdBonusPercent Int     @default(0) // % bonus for first N entries
  earlyBirdEntryLimit   Int     @default(0) // First N entries get early bird bonus

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  prizes  RafflePrize[]
  entries RaffleEntry[]
  winners RaffleWinner[]

  // Psychology relations
  instantWins  RaffleInstantWin[]  @relation("RaffleInstantWins")
  activities   RaffleActivity[]    @relation("RaffleActivities")
  bonusEvents  RaffleBonusEvent[]  @relation("RaffleBonusEvents")
  luckyNumbers RaffleLuckyNumber[] @relation("RaffleLuckyNumbers")

  @@index([shop])
  @@index([shop, status])
  @@index([status, startsAt])
  @@index([status, endsAt])
}

model RafflePrize {
  id       String @id @default(uuid())
  raffleId String

  // Prize Details
  name        String // "Grand Prize", "Runner-up Prize"
  description String? // What the prize includes
  imageUrl    String? // Prize image

  // Prize Type & Value
  prizeType  RafflePrizeType
  prizeValue Json // Type-specific value configuration
  // DISCOUNT: { "type": "percentage" | "fixed", "value": 20, "maxUses": 1 }
  // STORE_CREDIT: { "amount": 5000 } (in cents)
  // PRODUCT: { "productId": "gid://shopify/Product/123", "variantId": "...", "quantity": 1 }
  // POINTS: { "amount": 1000 }
  // CUSTOM: { "fulfillmentInstructions": "Contact customer to arrange..." }

  // Distribution
  quantity     Int @default(1) // How many of this prize available
  quantityWon  Int @default(0) // How many have been won
  displayOrder Int @default(0) // Order in prize list (lower = higher priority)

  // Odds Configuration (for WEIGHTED draw type)
  weight Int @default(100) // Relative weight for weighted draws

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  raffle  Raffle         @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  winners RaffleWinner[]

  @@index([raffleId])
  @@index([raffleId, displayOrder])
}

model RaffleEntry {
  id         String @id @default(uuid())
  raffleId   String
  customerId String
  shop       String

  // Entry Details
  entriesCount    Int     @default(1) // Number of entries in this batch
  pointsSpent     Int // Total points spent for these entries
  entryMultiplier Decimal @default(1.0) @db.Decimal(3, 2) // Tier bonus multiplier applied

  // Psychology Bonuses Applied
  streakBonusApplied    Decimal? @db.Decimal(3, 2) // Streak multiplier (e.g., 1.25)
  earlyBirdBonusApplied Boolean  @default(false) // Was early bird bonus applied?
  luckyNumberBonus      Int      @default(0) // Bonus entries from lucky numbers
  bonusEventId          String? // ID of bonus event that was active
  instantWinsTriggered  Int      @default(0) // Count of instant wins from this entry
  isFreeEntry           Boolean  @default(false) // Was this a daily free entry?

  // Tracking
  isWinner Boolean @default(false) // Quick lookup for win status

  // Metadata
  createdAt DateTime @default(now())

  // Relations
  raffle        Raffle         @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  customer      Customer       @relation("RaffleEntries", fields: [customerId], references: [id], onDelete: Cascade)
  winners       RaffleWinner[]
  ledgerEntries PointsLedger[] @relation("RaffleEntryLedger")

  // Psychology relations
  instantWinLogs RaffleInstantWinLog[] @relation("RaffleEntryInstantWins")

  @@unique([raffleId, customerId]) // One entry record per customer per raffle
  @@index([raffleId])
  @@index([customerId])
  @@index([shop, customerId])
  @@index([raffleId, isWinner])
}

model RaffleWinner {
  id            String @id @default(uuid())
  raffleId      String
  raffleEntryId String
  rafflePrizeId String
  customerId    String
  shop          String

  // Win Details
  winPosition Int // 1st, 2nd, 3rd, etc.
  selectedAt  DateTime @default(now()) // When this winner was drawn

  // Prize Delivery
  deliveryStatus RafflePrizeDeliveryStatus @default(PENDING)
  deliveredAt    DateTime?
  deliveryNotes  String?                   @db.Text // Admin notes about delivery

  // Prize-specific delivery details
  discountCode   String? // For DISCOUNT prizes
  storeCreditId  String? // For STORE_CREDIT prizes (links to StoreCreditLedger)
  pointsLedgerId String? // For POINTS prizes (links to PointsLedger)

  // Notification Tracking
  notifiedAt     DateTime? // When winner was notified
  notifyAttempts Int       @default(0)
  claimedAt      DateTime? // When winner acknowledged/claimed

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  raffle   Raffle      @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  entry    RaffleEntry @relation(fields: [raffleEntryId], references: [id], onDelete: Cascade)
  prize    RafflePrize @relation(fields: [rafflePrizeId], references: [id], onDelete: Cascade)
  customer Customer    @relation("RaffleWins", fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([raffleId, winPosition]) // Only one winner per position
  @@index([raffleId])
  @@index([customerId])
  @@index([shop, customerId])
  @@index([deliveryStatus])
}

// Raffle Status Lifecycle
enum RaffleStatus {
  DRAFT // Being configured, not visible
  SCHEDULED // Visible, entries not yet open
  ACTIVE // Entries are open
  CLOSED // Entries closed, awaiting draw
  DRAWING // Draw in progress
  COMPLETED // Winners selected, prizes being delivered
  CANCELLED // Raffle cancelled, entries refunded
}

// How winners are selected
enum RaffleDrawType {
  RANDOM // Pure random selection
  WEIGHTED // Weighted by entry count (more entries = higher chance)
  FIFO // First entries win (early bird advantage)
}

// Types of prizes that can be won
enum RafflePrizeType {
  DISCOUNT // Discount code (percentage or fixed)
  STORE_CREDIT // Store credit added to account
  PRODUCT // Free product
  POINTS // Points added back to balance
  CUSTOM // Custom prize requiring manual fulfillment
}

// Prize delivery status
enum RafflePrizeDeliveryStatus {
  PENDING // Not yet delivered
  PROCESSING // Being processed (e.g., discount code being generated)
  DELIVERED // Successfully delivered
  FAILED // Delivery failed (needs retry)
  CLAIMED // Winner acknowledged receipt
}

// Activity types for social proof feed
enum RaffleActivityType {
  ENTRY_PURCHASED // Customer bought entries
  INSTANT_WIN // Customer won instant prize
  GRAND_WINNER // Customer won grand prize in draw
  STREAK_MILESTONE // Customer hit streak milestone (7, 14, 30 days)
  EARLY_BIRD // Customer got early bird bonus
  LUCKY_NUMBER // Customer hit a lucky number
}

// Bonus event types for urgency mechanics
enum RaffleBonusEventType {
  HAPPY_HOUR // Time-limited bonus (e.g., 2x entries 6-8pm)
  FLASH_BONUS // Short flash sale bonus
  EARLY_BIRD // First N entries get bonus
  LAST_CHANCE // Final hours bonus
  MILESTONE // Entry milestone bonus (100th entry, etc.)
}

// ============================================
// RAFFLE PSYCHOLOGY SYSTEM MODELS
// ============================================
// Habit formation, variable rewards, social proof, urgency mechanics

// Tracks customer raffle engagement streaks
model RaffleStreak {
  id         String @id @default(uuid())
  shop       String
  customerId String @unique // One streak record per customer

  // Streak tracking
  currentStreak   Int       @default(0) // Current consecutive days
  longestStreak   Int       @default(0) // All-time longest streak
  lastEntryDate   DateTime? // Last date an entry was made
  streakStartDate DateTime? // When current streak began

  // Daily free entry tracking
  freeEntriesUsedToday Int       @default(0) // How many free entries used today
  freeEntryLastUsedAt  DateTime? // When last free entry was claimed

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  customer Customer @relation("RaffleStreaks", fields: [customerId], references: [id], onDelete: Cascade)

  @@index([shop, customerId])
  @@index([shop, currentStreak])
  @@index([lastEntryDate])
}

// Instant-win micro-prizes during entry purchase
model RaffleInstantWin {
  id       String @id @default(uuid())
  raffleId String
  shop     String

  // Prize details
  name        String // "Lucky 25 Points", "Bonus Entry"
  description String? // Optional description
  imageUrl    String? // Prize image

  // Prize type and value (same as RafflePrize)
  prizeType  RafflePrizeType
  prizeValue Json // Type-specific value configuration

  // Probability configuration
  winChancePercent Decimal @db.Decimal(7, 6) // 0.000001 to 1.000000 (e.g., 0.15 = 15%)
  rarity           String  @default("COMMON") // COMMON, UNCOMMON, RARE, EPIC, LEGENDARY

  // Win limits
  maxWinsTotal       Int? // Total wins allowed (null = unlimited)
  maxWinsPerCustomer Int  @default(1) // Per-customer win limit
  currentWinsTotal   Int  @default(0) // Current total wins

  // Time window (optional)
  startsAt DateTime?
  endsAt   DateTime?

  // Status
  isActive Boolean @default(true)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  raffle Raffle                @relation("RaffleInstantWins", fields: [raffleId], references: [id], onDelete: Cascade)
  wins   RaffleInstantWinLog[]

  @@index([raffleId, isActive])
  @@index([shop])
}

// Log of instant-win occurrences
model RaffleInstantWinLog {
  id            String @id @default(uuid())
  instantWinId  String
  customerId    String
  raffleEntryId String
  shop          String

  // Delivery tracking
  delivered    Boolean   @default(false)
  deliveredAt  DateTime?
  deliveryData Json? // Prize-specific delivery details

  // Metadata
  createdAt DateTime @default(now())

  // Relations
  instantWin RaffleInstantWin @relation(fields: [instantWinId], references: [id], onDelete: Cascade)
  customer   Customer         @relation("RaffleInstantWins", fields: [customerId], references: [id], onDelete: Cascade)
  entry      RaffleEntry      @relation("RaffleEntryInstantWins", fields: [raffleEntryId], references: [id], onDelete: Cascade)

  @@index([instantWinId])
  @@index([customerId])
  @@index([raffleEntryId])
  @@index([shop, createdAt])
}

// Activity feed for social proof
model RaffleActivity {
  id       String @id @default(uuid())
  raffleId String
  shop     String

  // Activity details
  activityType RaffleActivityType
  customerId   String? // Optional, null for anonymous activities
  displayName  String // Anonymized name: "J***n S."
  data         Json // Activity-specific data

  // Visibility
  isPublic  Boolean   @default(true)
  expiresAt DateTime? // Auto-expire old activities

  // Metadata
  createdAt DateTime @default(now())

  // Relations
  raffle   Raffle    @relation("RaffleActivities", fields: [raffleId], references: [id], onDelete: Cascade)
  customer Customer? @relation("RaffleActivities", fields: [customerId], references: [id], onDelete: SetNull)

  @@index([raffleId, createdAt])
  @@index([shop, createdAt])
  @@index([activityType])
}

// Bonus entry events (happy hours, flash sales)
model RaffleBonusEvent {
  id       String  @id @default(uuid())
  shop     String
  raffleId String? // null = applies to all raffles

  // Event details
  name        String // "Happy Hour", "Flash Bonus"
  description String?

  // Event type
  eventType RaffleBonusEventType

  // Bonus configuration
  bonusMultiplier  Decimal @default(1.5) @db.Decimal(3, 2) // 1.5x entries
  bonusEntriesFlat Int     @default(0) // +N flat bonus entries
  discountPercent  Int     @default(0) // % discount on entry cost

  // Timing
  startsAt DateTime
  endsAt   DateTime

  // Recurring configuration (optional)
  isRecurring    Boolean @default(false)
  recurringDays  Json? // [1, 3, 5] = Mon, Wed, Fri (0-6 = Sun-Sat)
  recurringHours Json? // { "start": 18, "end": 20 } = 6pm-8pm

  // Usage limits
  maxUses            Int? // Total uses allowed
  currentUses        Int  @default(0)
  maxUsesPerCustomer Int? // Per-customer limit

  // Status
  isActive Boolean @default(true)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  raffle Raffle?                 @relation("RaffleBonusEvents", fields: [raffleId], references: [id], onDelete: Cascade)
  usages RaffleBonusEventUsage[]

  @@index([shop, isActive])
  @@index([startsAt, endsAt])
  @@index([raffleId])
}

// Tracks usage of bonus events per customer
model RaffleBonusEventUsage {
  id           String @id @default(uuid())
  bonusEventId String
  customerId   String
  shop         String

  // Usage tracking
  usageCount Int @default(1)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bonusEvent RaffleBonusEvent @relation(fields: [bonusEventId], references: [id], onDelete: Cascade)
  customer   Customer         @relation("RaffleBonusEventUsages", fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([bonusEventId, customerId])
  @@index([customerId])
}

// Lucky number tracking and rewards
model RaffleLuckyNumber {
  id         String @id @default(uuid())
  raffleId   String
  shop       String
  customerId String

  // Lucky number details
  luckyNumber  Int // The entry number that was lucky (e.g., 100th entry)
  bonusType    String // "MILESTONE", "SEQUENCE", "RANDOM"
  bonusEntries Int // Bonus entries awarded

  // Metadata
  createdAt DateTime @default(now())

  // Relations
  raffle   Raffle   @relation("RaffleLuckyNumbers", fields: [raffleId], references: [id], onDelete: Cascade)
  customer Customer @relation("RaffleLuckyNumbers", fields: [customerId], references: [id], onDelete: Cascade)

  @@index([raffleId])
  @@index([customerId])
  @@index([shop, createdAt])
}

// ============================================
// MYSTERY BOXES SYSTEM MODELS
// ============================================

model MysteryBox {
  id   String @id @default(uuid())
  shop String

  // Basic Info
  name        String // "Golden Mystery Box", "Lucky Grab"
  description String? @db.Text
  imageUrl    String?

  // Status & Timing
  status   MysteryBoxStatus @default(DRAFT)
  startsAt DateTime
  endsAt   DateTime

  // Cost & Limits
  openCost            Int  @default(100) // Points per open
  maxOpensTotal       Int? // null = unlimited
  maxOpensPerCustomer Int  @default(5)

  // Access Control
  tierRestrictions Json? // { "allowedTierIds": ["tier1", "tier2"] }
  minimumTier      String?
  isPublic         Boolean @default(true)

  // Denormalized Statistics
  totalOpens    Int @default(0)
  uniqueOpeners Int @default(0)
  totalSpent    Int @default(0)

  // Psychology Features
  enableActivityFeed    Boolean @default(true)
  enableStreakBonuses   Boolean @default(true)
  enablePitySystem      Boolean @default(true)
  enableLuckyStreak     Boolean @default(true)
  dailyFreeOpens        Int     @default(0) // 0 = disabled
  pityThreshold         Int     @default(10) // Guaranteed non-common after N commons
  luckyStreakMultiplier Decimal @default(1.1) @db.Decimal(3, 2) // 10% bonus per streak

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  rewards     MysteryBoxReward[]
  opens       MysteryBoxOpen[]
  winners     MysteryBoxWinner[]
  activities  MysteryBoxActivity[]
  bonusEvents MysteryBoxBonusEvent[]

  @@index([shop])
  @@index([shop, status])
  @@index([status, startsAt])
  @@index([status, endsAt])
}

model MysteryBoxReward {
  id    String @id @default(uuid())
  boxId String

  // Reward Details
  name        String
  description String?
  imageUrl    String?

  // Type & Configuration
  rewardType  MysteryBoxRewardType
  rewardValue Json // Type-specific config

  // Probability & Rarity
  probability Decimal          @db.Decimal(5, 2) // 0.01 - 100.00
  rarity      MysteryBoxRarity @default(COMMON)

  // Inventory (optional finite supply)
  quantity    Int? // null = unlimited
  quantityWon Int  @default(0)

  // Display Order
  position Int @default(0)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  box     MysteryBox         @relation(fields: [boxId], references: [id], onDelete: Cascade)
  winners MysteryBoxWinner[]

  @@index([boxId])
  @@index([boxId, rarity])
}

model MysteryBoxOpen {
  id         String @id @default(uuid())
  boxId      String
  customerId String
  shop       String

  // Transaction Details
  pointsSpent Int
  openedAt    DateTime @default(now())

  // Psychology Tracking
  streakDay          Int? // Which day of streak this was
  streakBonusApplied Decimal? @db.Decimal(3, 2) // Multiplier applied
  luckyStreakCount   Int      @default(0) // Lucky streak at time of open
  luckyStreakBonus   Decimal? @db.Decimal(3, 2) // Multiplier applied
  bonusEventId       String? // ID of bonus event if applicable
  discountApplied    Int      @default(0) // Points saved from discount
  isFreeOpen         Boolean  @default(false)
  pityTriggered      Boolean  @default(false)
  nearMissRewardId   String? // ID of reward that "almost" won

  // Relations
  box      MysteryBox        @relation(fields: [boxId], references: [id], onDelete: Cascade)
  customer Customer          @relation("MysteryBoxOpens", fields: [customerId], references: [id], onDelete: Cascade)
  winner   MysteryBoxWinner? @relation("MysteryBoxOpenWinner")

  @@index([boxId])
  @@index([customerId])
  @@index([shop, customerId])
  @@index([boxId, customerId])
}

model MysteryBoxWinner {
  id         String @id @default(uuid())
  boxId      String
  openId     String @unique // 1:1 with MysteryBoxOpen
  rewardId   String
  customerId String
  shop       String

  // Delivery Tracking
  deliveryStatus MysteryBoxDeliveryStatus @default(PENDING)
  deliveredAt    DateTime?
  deliveryNotes  String?                  @db.Text

  // Reward-specific delivery details
  discountCode   String?
  storeCreditId  String?
  pointsLedgerId String?

  // Notification
  notifiedAt     DateTime?
  notifyAttempts Int       @default(0)
  claimedAt      DateTime?

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  box      MysteryBox       @relation(fields: [boxId], references: [id], onDelete: Cascade)
  open     MysteryBoxOpen   @relation("MysteryBoxOpenWinner", fields: [openId], references: [id], onDelete: Cascade)
  reward   MysteryBoxReward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  customer Customer         @relation("MysteryBoxWins", fields: [customerId], references: [id], onDelete: Cascade)

  @@index([boxId])
  @@index([customerId])
  @@index([deliveryStatus])
  @@index([shop, deliveryStatus])
}

// Mystery Box Status Lifecycle
enum MysteryBoxStatus {
  DRAFT // Being configured
  SCHEDULED // Ready, waiting for start time
  ACTIVE // Accepting opens
  CLOSED // No new opens
  COMPLETED // All processing done
  CANCELLED // Cancelled
}

// Reward rarity tiers
enum MysteryBoxRarity {
  COMMON // ~60-70%
  UNCOMMON // ~20-25%
  RARE // ~8-12%
  EPIC // ~2-5%
  LEGENDARY // ~0.5-2%
}

// Types of rewards
enum MysteryBoxRewardType {
  POINTS // Bonus points
  DISCOUNT // Discount code
  STORE_CREDIT // Store credit
  PRODUCT // Free product
  CUSTOM // Manual fulfillment
  NOTHING // "Better luck next time"
}

// Delivery status
enum MysteryBoxDeliveryStatus {
  PENDING
  PROCESSING
  DELIVERED
  FAILED
  CLAIMED
}

// Activity types for mystery box social proof feed
enum MysteryBoxActivityType {
  BOX_OPENED
  RARE_WIN
  EPIC_WIN
  LEGENDARY_WIN
  STREAK_MILESTONE
  PITY_TRIGGERED
  LUCKY_STREAK
  FREE_OPEN_CLAIMED
}

// Bonus event types for mystery boxes
enum MysteryBoxBonusEventType {
  HAPPY_HOUR
  FLASH_DISCOUNT
  DOUBLE_REWARDS
  LUCKY_HOUR
  LAST_CHANCE
}

// ============================================
// MYSTERY BOX PSYCHOLOGY SYSTEM
// ============================================
// Psychological engagement features to maximize customer participation
// Includes: streaks, pity system, lucky streaks, activity feed, bonus events

// Tracks customer mystery box engagement streaks and pity system
model MysteryBoxStreak {
  id         String @id @default(uuid())
  shop       String
  customerId String @unique

  // Daily streak tracking
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastOpenDate    DateTime?
  streakStartDate DateTime?

  // Free opens tracking
  freeOpensUsedToday Int       @default(0)
  freeOpenLastUsedAt DateTime?

  // Session lucky streak (resets on inactivity)
  luckyStreakCount     Int       @default(0)
  luckyStreakUpdatedAt DateTime?

  // Pity system - guaranteed rare after N commons
  commonsSinceRare Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer @relation("MysteryBoxStreaks", fields: [customerId], references: [id], onDelete: Cascade)

  @@index([shop, customerId])
}

// Activity feed for social proof
model MysteryBoxActivity {
  id           String                 @id @default(uuid())
  boxId        String
  shop         String
  activityType MysteryBoxActivityType
  customerId   String?
  displayName  String // Anonymized: "J***n S."
  data         Json // { rewardName, rarity, pointsWon, etc. }
  isPublic     Boolean                @default(true)
  expiresAt    DateTime?
  createdAt    DateTime               @default(now())

  box      MysteryBox @relation(fields: [boxId], references: [id], onDelete: Cascade)
  customer Customer?  @relation("MysteryBoxActivities", fields: [customerId], references: [id], onDelete: SetNull)

  @@index([boxId, createdAt])
  @@index([shop, createdAt])
}

// Bonus events (happy hours, flash discounts)
model MysteryBoxBonusEvent {
  id          String                   @id @default(uuid())
  shop        String
  boxId       String? // null = applies to all boxes
  name        String
  description String?
  eventType   MysteryBoxBonusEventType

  // Bonus configuration
  discountPercent   Int     @default(0) @db.SmallInt // % off point cost
  bonusMultiplier   Decimal @default(1.0) @db.Decimal(3, 2) // Multiplier on reward values
  extraRewardChance Int     @default(0) @db.SmallInt // % chance of bonus reward

  // Timing
  startsAt DateTime
  endsAt   DateTime

  // Recurring configuration
  isRecurring    Boolean @default(false)
  recurringDays  Json? // [0,1,2,3,4,5,6] for days of week
  recurringHours Json? // { start: 14, end: 16 }

  // Usage limits
  maxUses            Int? // null = unlimited
  currentUses        Int  @default(0)
  maxUsesPerCustomer Int?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  box    MysteryBox?                  @relation(fields: [boxId], references: [id], onDelete: Cascade)
  usages MysteryBoxBonusEventUsage[]

  @@index([shop, isActive])
  @@index([shop, startsAt, endsAt])
}

// Track bonus event usage per customer
model MysteryBoxBonusEventUsage {
  id         String   @id @default(uuid())
  eventId    String
  customerId String
  shop       String
  usedAt     DateTime @default(now())

  event    MysteryBoxBonusEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  customer Customer             @relation("MysteryBoxBonusUsages", fields: [customerId], references: [id], onDelete: Cascade)

  @@index([eventId, customerId])
  @@index([shop, customerId])
}

// ============================================
// CHALLENGES SYSTEM
// ============================================
// Goal-based engagement activities for customers
// Customers complete objectives (spending, orders, referrals) to earn rewards

model Challenge {
  id   String @id @default(uuid())
  shop String

  // Basic Info
  name        String
  description String? @db.Text
  imageUrl    String?

  // Status & Timing
  status   ChallengeStatus @default(DRAFT)
  startsAt DateTime
  endsAt   DateTime

  // Objective Configuration
  objectiveType   ChallengeObjectiveType
  targetValue     Int // e.g., 500 (dollars), 5 (orders), 3 (referrals)
  objectiveConfig Json? // Additional config per type
  // SPENDING: { "minOrderValue": 50, "excludeDiscounted": true }
  // ORDER_COUNT: { "minOrderValue": 10 }
  // REFERRAL: { "requirePurchase": true, "minPurchaseValue": 25 }
  // PRODUCT_PURCHASE: { "productIds": ["gid://..."], "collectionIds": ["gid://..."], "quantity": 1 }
  // REVIEW: { "productIds": ["gid://..."], "minRating": 4 }
  // STREAK: { "streakType": "ORDER", "periodDays": 7 }

  // Access Control
  tierRestrictions Json? // { "allowedTierIds": ["tier1", "tier2"] }
  minimumTierId    String? // Minimum tier required
  isPublic         Boolean @default(true)

  // ============================================
  // MISSION SYSTEM FIELDS (Gamification)
  // ============================================

  // Mission Cadence - determines reset behavior
  cadence MissionCadence @default(SPECIAL)

  // Gamification Attributes
  rarity   MissionRarity   @default(COMMON)
  category MissionCategory @default(CHALLENGE)
  xpReward Int             @default(10) // Experience points awarded

  // Template Reference (for recurring missions)
  templateId String?
  template   MissionTemplate? @relation(fields: [templateId], references: [id])

  // Streak/Combo Eligibility
  comboEligible  Boolean @default(true) // Can contribute to daily combo
  streakEligible Boolean @default(true) // Can contribute to streak

  // Display Customization
  iconEmoji String? @default("🎯") // Mission icon
  sortOrder Int     @default(0) // Display order within cadence

  // Scheduling (for recurring)
  nextResetAt DateTime? // When this mission instance expires/resets

  // Denormalized Statistics
  totalParticipants   Int @default(0)
  completedCount      Int @default(0)
  claimedCount        Int @default(0)
  totalRewardsAwarded Int @default(0) // Total value of rewards given

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  reward       ChallengeReward?
  participants ChallengeParticipant[]
  progressLogs ChallengeProgressLog[]

  @@index([shop])
  @@index([shop, status])
  @@index([status, startsAt])
  @@index([status, endsAt])
  @@index([shop, objectiveType])
  @@index([shop, cadence, status])
  @@index([shop, category])
  @@index([templateId])
}

model ChallengeReward {
  id          String @id @default(uuid())
  challengeId String @unique

  // Reward Configuration
  rewardType  ChallengeRewardType
  rewardValue Json
  // POINTS: { "amount": 500 }
  // STORE_CREDIT: { "amount": 2500 } // in cents
  // DISCOUNT: { "type": "percentage" | "fixed", "value": 10, "maxUses": 1, "minOrderValue": 50 }
  // TIER_UPGRADE: { "tierId": "...", "durationDays": 30 } // null = permanent
  // CUSTOM: { "description": "...", "fulfillmentInstructions": "..." }

  // Display
  description String // Human-readable reward description

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@index([challengeId])
}

model ChallengeParticipant {
  id          String @id @default(uuid())
  challengeId String
  customerId  String
  shop        String

  // Progress Tracking
  currentProgress Int @default(0) // Current value towards target
  progressPercent Int @default(0) // Pre-calculated percentage (0-100)

  // Status
  status      ChallengeParticipantStatus @default(IN_PROGRESS)
  completedAt DateTime?
  claimedAt   DateTime?

  // Reward Delivery (when claimed)
  rewardDelivered     Boolean @default(false)
  rewardDeliveryId    String? // Points ledger ID, discount code, etc.
  rewardDeliveryNotes String? @db.Text

  // Metadata
  joinedAt  DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  challenge    Challenge              @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  customer     Customer               @relation("ChallengeParticipants", fields: [customerId], references: [id], onDelete: Cascade)
  progressLogs ChallengeProgressLog[]

  @@unique([challengeId, customerId])
  @@index([challengeId])
  @@index([customerId])
  @@index([shop, customerId])
  @@index([challengeId, status])
  @@index([status, completedAt])
}

model ChallengeProgressLog {
  id            String @id @default(uuid())
  challengeId   String
  participantId String
  shop          String

  // Progress Details
  progressDelta      Int // Amount added (can be negative for corrections)
  newProgress        Int // Progress value after this update
  newProgressPercent Int // Percentage after this update

  // Source Reference
  sourceType String // "ORDER", "REFERRAL", "REVIEW", "STREAK", "MANUAL"
  sourceId   String? // Order ID, referral ID, etc.

  // Metadata
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())

  // Relations
  challenge   Challenge            @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  participant ChallengeParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([challengeId])
  @@index([participantId])
  @@index([sourceType, sourceId])
  @@index([createdAt])
}

// ============================================
// MISSION SYSTEM MODELS (Gamification)
// ============================================

// Template for recurring missions (Daily/Weekly/Monthly)
// Instances are generated from templates by the scheduler
model MissionTemplate {
  id   String @id @default(uuid())
  shop String

  // Basic Info
  name        String
  description String? @db.Text
  imageUrl    String?

  // Objective Configuration (same as Challenge)
  objectiveType   ChallengeObjectiveType
  targetValue     Int
  objectiveConfig Json?

  // Cadence & Gamification
  cadence  MissionCadence
  rarity   MissionRarity   @default(COMMON)
  category MissionCategory @default(CHALLENGE)
  xpReward Int             @default(10)

  // Reward Configuration
  rewardType        ChallengeRewardType
  rewardValue       Json
  rewardDescription String

  // Display
  iconEmoji String @default("🎯")
  sortOrder Int    @default(0)

  // Access Control
  tierRestrictions Json? // { "allowedTierIds": ["tier1", "tier2"] }

  // Active State
  isActive Boolean @default(true)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations - challenges generated from this template
  instances Challenge[]

  @@unique([shop, name])
  @@index([shop, isActive, cadence])
  @@index([shop, category])
}

// Customer mission statistics (denormalized for performance)
// Tracks XP, levels, streaks, combos per customer
model CustomerMissionStats {
  id         String @id @default(uuid())
  shop       String
  customerId String @unique

  // XP & Levels
  totalXp       Int @default(0)
  currentLevel  Int @default(1)
  xpToNextLevel Int @default(100) // Calculated based on level scaling

  // Mission Completion Counts
  totalCompleted   Int @default(0)
  dailyCompleted   Int @default(0)
  weeklyCompleted  Int @default(0)
  monthlyCompleted Int @default(0)

  // Streak Tracking (consecutive days with mission completion)
  currentStreak   Int       @default(0)
  longestStreak   Int       @default(0)
  lastMissionDate DateTime? // Last date a mission was completed

  // Daily Combo (multiple missions same day = bonus XP)
  todayComboCount  Int       @default(0)
  lastComboResetAt DateTime? // When combo was last reset

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  customer         Customer                 @relation("MissionStats", fields: [customerId], references: [id], onDelete: Cascade)
  completionEvents MissionCompletionEvent[]

  @@index([shop, customerId])
  @@index([shop, currentStreak])
  @@index([shop, totalXp])
  @@index([shop, currentLevel])
}

// Mission completion events for triggering animations
// Consumed by storefront to show celebrations
model MissionCompletionEvent {
  id          String @id @default(uuid())
  shop        String
  customerId  String
  challengeId String

  // Event Type
  eventType MissionEventType

  // XP Earned
  xpEarned Int @default(0)
  bonusXp  Int @default(0) // From streak + combo bonuses

  // Animation Triggers
  triggersConfetti   Boolean @default(false) // Confetti particle burst
  triggersLevelUp    Boolean @default(false) // Full level-up celebration
  triggersStreakFire Boolean @default(false) // Streak fire animation

  // Event Payload (extra data for rendering)
  payload Json? // { streakCount, comboCount, newLevel, etc. }

  // Acknowledgment State (consumed by storefront)
  acknowledged Boolean @default(false)

  // Metadata
  createdAt DateTime @default(now())

  // Relations
  stats CustomerMissionStats? @relation(fields: [customerId], references: [customerId], onDelete: Cascade)

  @@index([shop, customerId, acknowledged])
  @@index([createdAt])
}

// Challenge Status Lifecycle
enum ChallengeStatus {
  DRAFT // Being configured
  SCHEDULED // Ready, waiting for start time
  ACTIVE // Accepting participants and progress
  CLOSED // No new participants, existing can complete
  COMPLETED // All processing done
  CANCELLED // Cancelled
}

// Challenge Objective Types
enum ChallengeObjectiveType {
  SPENDING // Spend X amount
  ORDER_COUNT // Place X orders
  REFERRAL // Refer X friends (who purchase)
  PRODUCT_PURCHASE // Buy specific products/collections
  REVIEW // Submit X product reviews
  STREAK // Maintain X-day purchase streak
}

// Challenge Reward Types
enum ChallengeRewardType {
  POINTS // Points credited to balance
  STORE_CREDIT // Store credit issued
  DISCOUNT // Discount code generated
  TIER_UPGRADE // Temporary or permanent tier upgrade
  CUSTOM // Manual fulfillment required
}

// Challenge Participant Status
enum ChallengeParticipantStatus {
  IN_PROGRESS // Working on challenge
  COMPLETED // Met target, awaiting claim
  CLAIMED // Reward has been claimed
  EXPIRED // Challenge ended before completion
}

// ============================================
// MISSION SYSTEM ENUMS (Gamification)
// ============================================

// Mission Cadence - when missions reset/recur
enum MissionCadence {
  DAILY // Reset every 24 hours at configured time
  WEEKLY // Reset every 7 days
  MONTHLY // Reset at month start
  SPECIAL // One-time promotional, no reset
}

// Mission Rarity - visual distinction and difficulty
enum MissionRarity {
  COMMON // Gray border, easy missions
  UNCOMMON // Green border, medium difficulty
  RARE // Blue border, harder missions
  EPIC // Purple border, challenging
  LEGENDARY // Gold gradient border, very hard
}

// Mission Category - groups missions by merchant value
enum MissionCategory {
  SHOPPING // Purchase missions (direct revenue)
  DISCOVERY // Try new products (basket expansion)
  SOCIAL // Referrals, reviews (acquisition/UGC)
  STREAK // Consecutive activity (retention)
  CHALLENGE // One-time achievements
}

// Mission Completion Event Type - for animation triggers
enum MissionEventType {
  COMPLETE // Mission objective met
  CLAIM // Reward claimed
  MILESTONE // Progress milestone hit
  STREAK // Streak milestone reached
  COMBO // Combo bonus triggered
  LEVEL_UP // Customer leveled up
}

// ============================================
// WEBHOOK IDEMPOTENCY & AUDIT MODELS
// ============================================

// Track processed webhooks to prevent duplicate processing
model ProcessedWebhook {
  id    String @id // X-Shopify-Webhook-Id header value
  topic String // APP_SUBSCRIPTIONS_UPDATE, ORDERS_CREATE, etc.
  shop  String

  // Processing status
  status String @default("PROCESSING") // PROCESSING, COMPLETED, FAILED

  // Timestamps
  receivedAt  DateTime  @default(now())
  completedAt DateTime?

  // Error tracking (if processing failed)
  errorMessage String? @db.Text
  retryCount   Int     @default(0)

  // Payload hash for debugging (not storing full payload to save space)
  payloadHash String? // SHA256 of payload for verification

  @@index([shop])
  @@index([topic])
  @@index([receivedAt])
  @@index([status])
}

// Audit log for webhook processing events
model WebhookAuditLog {
  id        String @id @default(uuid())
  shop      String
  webhookId String // Reference to ProcessedWebhook.id
  topic     String

  // Event details
  action String // RECEIVED, PROCESSING, COMPLETED, FAILED, REJECTED_DUPLICATE, REJECTED_STALE

  // For ordering checks
  incomingTimestamp DateTime? // Timestamp from webhook payload (updated_at or triggered_at)
  existingTimestamp DateTime? // Existing record's timestamp (for stale rejection)

  // Rejection details
  rejectionReason String? // DUPLICATE, STALE, INVALID_SIGNATURE, etc.

  // Metadata
  metadata  Json? // Additional context
  createdAt DateTime @default(now())

  @@index([shop, createdAt(sort: Desc)])
  @@index([webhookId])
  @@index([action])
}

// ============================================
// SUBSCRIPTION RECONCILIATION
// ============================================

// Track subscription state reconciliation between local DB and Shopify
model ReconciliationLog {
  id   String @id @default(uuid())
  shop String

  // State comparison
  localState   Json? // Snapshot of local subscription state
  shopifyState Json? // Snapshot of Shopify subscription state

  // Detected issues
  mismatches    Json? // Array of mismatch descriptions
  mismatchCount Int   @default(0)

  // Resolution
  action     String // DETECTED, AUTO_FIXED, MANUAL_REVIEW, IGNORED
  resolution String? // Description of fix applied
  resolvedAt DateTime?
  resolvedBy String? // System or admin who resolved

  createdAt DateTime @default(now())

  @@index([shop, createdAt(sort: Desc)])
  @@index([action])
  @@index([mismatchCount])
}

// ============================================
// THIRD-PARTY APP INTEGRATIONS
// ============================================

// Integration configuration and credentials
model Integration {
  id   String @id @default(cuid())
  shop String // Foreign key to shop domain

  // Integration identity
  provider IntegrationProvider
  name     String // Display name
  status   IntegrationStatus   @default(DISCONNECTED)

  // Configuration (JSON)
  config Json @default("{}")

  // OAuth tokens (encrypted at rest)
  accessToken    String?   @db.Text // Encrypted
  refreshToken   String?   @db.Text // Encrypted
  tokenExpiresAt DateTime?
  scopes         String[]  @default([])

  // API credentials (encrypted at rest)
  apiKey        String? @db.Text // Encrypted
  apiSecret     String? @db.Text // Encrypted
  webhookSecret String? // For verifying inbound webhooks

  // Webhook configuration
  webhookUrl           String? // Our endpoint for this integration
  webhookSubscriptions Json    @default("[]")

  // Feature flags
  enabledFeatures String[] @default([])
  pointsConfig    Json? // Integration-specific points rules

  // Sync & error tracking
  lastSyncAt  DateTime?
  lastErrorAt DateTime?
  lastError   String?   @db.Text
  metadata    Json      @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  events   IntegrationEvent[]
  webhooks IntegrationWebhook[]

  @@unique([shop, provider])
  @@index([shop])
  @@index([provider, status])
}

// Outbound loyalty events to integrations
model IntegrationEvent {
  id            String      @id @default(cuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  shop          String

  // Event details
  eventType LoyaltyEventType
  payload   Json

  // Delivery status
  status        IntegrationEventStatus @default(PENDING)
  attempts      Int                    @default(0)
  lastAttemptAt DateTime?
  deliveredAt   DateTime?
  error         String?                @db.Text

  // Reference data
  customerId        String?
  shopifyCustomerId String?
  orderId           String?

  createdAt DateTime @default(now())

  @@index([integrationId, status])
  @@index([shop, eventType])
  @@index([status, createdAt])
}

// Inbound webhooks from integrations
model IntegrationWebhook {
  id            String      @id @default(cuid())
  integrationId String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  shop          String

  // Webhook identity
  webhookId String @unique // External webhook ID for idempotency
  topic     String // e.g., "review.created", "subscription.renewed"

  // Payload
  payload Json
  headers Json @default("{}")

  // Processing status
  status      IntegrationWebhookStatus @default(RECEIVED)
  processedAt DateTime?
  error       String?                  @db.Text

  // Actions taken
  pointsAwarded Int?
  actionsTaken  Json @default("[]")

  createdAt DateTime @default(now())

  @@index([integrationId, topic])
  @@index([shop, status])
  @@index([webhookId])
}

// OAuth state storage for PKCE flow
model OAuthState {
  id       String              @id @default(cuid())
  shop     String
  provider IntegrationProvider

  // PKCE
  state        String  @unique
  codeVerifier String? @db.Text // Encrypted, optional for non-PKCE flows

  // OAuth context
  redirectUri String // Callback URL for token exchange
  metadata    Json   @default("{}") // Additional data (returnUrl, etc.)

  // Security
  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([state])
  @@index([expiresAt])
}

// Points rules for integration triggers
model IntegrationPointsRule {
  id       String              @id @default(cuid())
  shop     String
  provider IntegrationProvider

  // Rule definition
  triggerEvent String // e.g., "review.created", "subscription.renewed"
  name         String // Display name
  description  String?

  // Points configuration
  pointsType    IntegrationPointsType @default(FIXED)
  pointsAmount  Int                   @default(0) // Fixed amount
  pointsPercent Float? // Percentage of order value
  maxPoints     Int? // Cap for percentage-based

  // Conditions (JSON)
  conditions Json @default("{}")

  // Status
  enabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, provider, triggerEvent])
  @@index([shop, provider])
}

// ============================================
// AI FEEDBACK SYSTEM
// ============================================
// Models for tracking AI session context, learning patterns,
// and self-improvement feedback loop

model AISession {
  id        String @id @default(cuid())
  sessionId String @unique // Claude session identifier

  startedAt DateTime  @default(now())
  endedAt   DateTime?

  // Context
  primaryIntent String? // What the user asked for
  territory     String? // "charted" | "uncharted"

  // Outcomes
  tasksCompleted Int @default(0)
  tasksAttempted Int @default(0)
  filesModified  Int @default(0)
  filesCreated   Int @default(0)

  // Self-assessment
  satisfactionScore Int? // 1-10 AI self-rating
  learnings         String? @db.Text // Key insights from session

  // Relations
  actions     AISessionAction[]
  feedback    AISessionFeedback[]
  codeMetrics AICodeMetric[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startedAt])
}

model AISessionAction {
  id        String    @id @default(cuid())
  sessionId String
  session   AISession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  actionType  String // "file_edit" | "file_create" | "refactor" | "fix" | "feature"
  filePath    String?
  description String  @db.Text

  // Pattern tracking
  patternUsed   String? // Which pattern was applied
  wasSuccessful Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([actionType])
}

model AISessionFeedback {
  id        String    @id @default(cuid())
  sessionId String
  session   AISession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  dimension String // "truth" | "understanding" | "beauty" | "justice" | "creativity"
  rating    String // "complete" | "partial" | "failed"
  reason    String? @db.Text

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([dimension])
}

model AICodeMetric {
  id        String     @id @default(cuid())
  sessionId String?
  session   AISession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  filePath    String
  metricType  String // "complexity" | "duplication" | "coverage" | "debt"
  valueBefore Float?
  valueAfter  Float

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([filePath])
  @@index([metricType])
}

model AILearningPattern {
  id          String @id @default(cuid())
  patternName String @unique
  description String @db.Text

  // Confidence evolution
  timesUsed       Int   @default(0)
  timesSuccessful Int   @default(0)
  confidence      Float @default(0.5) // 0-1 scale

  // Context
  applicableTo String[] // ["data-api", "tier-system", "webhooks"]
  antiPatterns String[] // What NOT to do

  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([patternName])
  @@index([confidence])
}

model AICodeQualitySignal {
  id String @id @default(cuid())

  area        String // "services" | "routes" | "components"
  signalType  String // "ugliness" | "debt" | "complexity"
  severity    String // "low" | "medium" | "high"
  description String  @db.Text
  filePath    String?
  lineNumber  Int?

  resolved   Boolean   @default(false)
  resolvedAt DateTime?
  resolvedBy String? // session ID that fixed it

  createdAt DateTime @default(now())

  @@index([area])
  @@index([signalType])
  @@index([resolved])
}

model AIArchitectureHealth {
  id String @id @default(cuid())

  snapshotDate DateTime @default(now())

  // Metrics
  totalFiles      Int
  totalLines      Int
  avgComplexity   Float
  duplicateBlocks Int

  // Pattern adherence
  dataApiCompliant     Float // 0-100%
  shopScopingCompliant Float // 0-100%
  errorHandlingScore   Float // 0-100%

  // Trends
  trendDirection String // "improving" | "stable" | "declining"

  createdAt DateTime @default(now())

  @@index([snapshotDate])
}

model AIInnovationTracker {
  id String @id @default(cuid())

  feature   String // What was built
  territory String // "charted" | "uncharted"

  // If uncharted
  pioneering  Boolean @default(false)
  pathQuality String? // "well-built" | "fragile" | "incomplete"

  // Impact
  enablesFuture Boolean  @default(false)
  connectedTo   String[] // Related features/systems

  createdAt DateTime @default(now())

  @@index([territory])
  @@index([feature])
}

// ============================================
// AI EMAIL ASSISTANT USAGE TRACKING
// ============================================

model AIUsage {
  id String @id @default(uuid())

  shop String // Shop domain
  date DateTime @default(now()) @db.Date // Usage date

  // Request counts by action type
  generateRequests   Int @default(0) // Content generation requests
  enhanceRequests    Int @default(0) // Content enhancement requests
  subjectRequests    Int @default(0) // Subject line generation requests

  // Token usage for cost tracking
  totalTokensInput  Int @default(0) // Input tokens consumed
  totalTokensOutput Int @default(0) // Output tokens generated

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, date]) // One record per shop per day
  @@index([shop])
  @@index([date])
}

