  CNY  // Chinese Yuan
  SEK  // Swedish Krona
  NZD  // New Zealand Dollar
  NOK  // Norwegian Krone
  MXN  // Mexican Peso
  SGD  // Singapore Dollar
  HKD  // Hong Kong Dollar
  KRW  // South Korean Won
  TRY  // Turkish Lira
  INR  // Indian Rupee
  RUB  // Russian Ruble
  BRL  // Brazilian Real
  ZAR  // South African Rand
  AED  // UAE Dirham
