  CANCELLED
  REQUIRES_ACTION // e.g., 3D Secure
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum PurchaseType {
  ONE_TIME // One-time purchase only
  SUBSCRIPTION // Subscription only
  BOTH // Supports both purchase types
}

enum ProductDuration {
