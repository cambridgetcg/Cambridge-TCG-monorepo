// ============================================
// WEBHOOK PROCESSING MODELS
// ============================================

model WebhookProcessed {
  id          String   @id @default(uuid())
  webhookId   String   @unique
  topic       String
  shop        String
  processedAt DateTime @default(now())

  @@index([shop, topic])
}

// Distributed lock for cron jobs to prevent concurrent execution
// When a cron job starts, it tries to create a lock with unique jobName
// If creation fails (unique constraint), another instance is running
model CronLock {
  id         String   @id @default(uuid())
  jobName    String   @unique // Only one lock per job type
  lockedAt   DateTime @default(now())
  expiresAt  DateTime // Auto-release if instance crashes
  instanceId String? // Vercel deployment ID or similar

  @@index([expiresAt]) // For cleanup queries
}

model DeadLetterQueue {
  id        String   @id @default(uuid())
  webhookId String?
  shop      String
  topic     String
  payload   Json
  attempts  Int
  error     String?
  createdAt DateTime @default(now())
  failedAt  DateTime

  @@index([shop, failedAt])
}

// ============================================
// SYNC MANAGEMENT MODELS
// ============================================

model SyncStatus {
  id               String         @id @default(uuid())
  shop             String
  syncType         String // "orders", "customers", "products"
  lastSyncAt       DateTime // Last time sync ran
  lastSuccessfulId String? // Last successfully synced record ID
  syncCursor       String? // GraphQL cursor for pagination
  status           SyncStatusEnum // Current sync status
  errorMessage     String? // Error details if failed
  recordsProcessed Int            @default(0) // Number of records processed
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([shop, syncType])
  @@index([shop, lastSyncAt])
}

enum SyncStatusEnum {
  IDLE
  RUNNING
  FAILED
  COMPLETED
}

// ============================================
// EXCHANGE RATE MODELS
// ============================================

model ExchangeRate {
  id String @id @default(uuid())

  // Rate configuration
  baseCurrency Currency @default(USD) // Base currency for rates
  rates        Json // { EUR: 1.09, GBP: 1.27, ... }
  provider     String // "ExchangeRate-API", "Shopify", etc.

  // Timestamps
  fetchedAt DateTime // When rates were fetched from provider
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Metadata
  metadata Json? // Provider response metadata

  @@index([baseCurrency, fetchedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

model SystemAlert {
  id String @id @default(uuid())

  // Alert details
  type     String // EXCHANGE_RATE_STALENESS, etc.
  severity String // INFO, WARNING, CRITICAL
  message  String // Alert message
  details  Json // Additional context

  // Status
  resolved   Boolean   @default(false)
  resolvedAt DateTime?

  // Timestamps
  createdAt DateTime @default(now())

  @@index([type, resolved])
  @@index([severity, createdAt(sort: Desc)])
}

// ============================================
// EMAIL MARKETING MODELS
// ============================================

model EmailTemplate {
  id   String @id @default(uuid())
  shop String

  // Template details
  name        String // Template name (e.g., "Welcome Email", "Tier Upgrade")
  type        String // welcome, tier_change, points_reminder, etc.
  subject     String // Email subject line
  content     Json // Block-based content structure
  previewText String? // Preview text for email clients
  bodyHtml    String? // HTML content of email
  bodyText    String? // Plain text content of email
  htmlContent String? // Full HTML content (compiled)

  // Status
  isActive Boolean @default(true)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  campaigns   EmailCampaign[]
  automations EmailAutomation[]

  @@index([shop, type])
  @@index([shop, isActive])
}

model EmailCampaign {
  id   String @id @default(uuid())
  shop String

  // Campaign details
  name        String // Campaign name
  subject     String? // Email subject line
  previewText String? // Email preview text
  templateId  String // Reference to EmailTemplate
  template    EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  // Status
  status String // draft, scheduled, sending, sent, failed

  // Segmentation
  segmentRules Json // Segment criteria

  // Scheduling
  scheduledFor DateTime? // When to send
  sentAt       DateTime? // When actually sent

  // Metrics
  metrics Json? // { sent, delivered, opened, clicked, revenue, orders }

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop, status])
  @@index([shop, scheduledFor])
  @@index([sentAt(sort: Desc)])
}

model EmailAutomation {
  id   String @id @default(uuid())
  shop String

  // Automation details
  name       String // Automation name
  trigger    String // welcome, tier_upgrade, points_expiry, etc.
  templateId String // Reference to EmailTemplate
  template   EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  // Status
  isEnabled Boolean @default(true)

  // Conditions & Timing
  conditions   Json // Conditional logic
  delayMinutes Int  @default(0) // Delay before sending

  // Metrics
  totalSent    Int @default(0)
  totalOpened  Int @default(0)
  totalClicked Int @default(0)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop, trigger])
  @@index([shop, isEnabled])
}

/// Stores delayed automation executions for processing by a cron job.
model PendingAutomation {
  id             String   @id @default(uuid())
  shop           String
  automationId   String
  automationName String
  templateId     String

  // Recipient
  recipientEmail     String @db.VarChar(255)
  recipientFirstName String? @db.VarChar(255)
  recipientLastName  String? @db.VarChar(255)

  // Trigger context
  triggerType String
  triggerData Json? // Original event data for template personalization

