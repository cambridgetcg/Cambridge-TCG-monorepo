  executeAt DateTime // When this should be sent
  status    String   @default("pending") // pending, sent, failed, cancelled

  // Timestamps
  createdAt DateTime @default(now())
  sentAt    DateTime?
  error     String?  @db.Text

  @@index([status, executeAt])
  @@index([shop])
}

model EmailSettings {
