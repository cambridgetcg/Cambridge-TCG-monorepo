model WebhookProcessed {
  id          String   @id @default(uuid())
  webhookId   String   @unique
  topic       String
  shop        String
  processedAt DateTime @default(now())

  @@index([shop, topic])
}

// Distributed lock for cron jobs to prevent concurrent execution
// When a cron job starts, it tries to create a lock with unique jobName
// If creation fails (unique constraint), another instance is running
model CronLock {
  id          String   @id @default(uuid())
  jobName     String   @unique  // Only one lock per job type
  lockedAt    DateTime @default(now())
  expiresAt   DateTime          // Auto-release if instance crashes
  instanceId  String?           // Vercel deployment ID or similar

  @@index([expiresAt])          // For cleanup queries
}

model DeadLetterQueue {
  id        String   @id @default(uuid())
  webhookId String?
  shop      String
  topic     String
  payload   Json
  attempts  Int
  error     String?
  createdAt DateTime @default(now())
  failedAt  DateTime

  @@index([shop, failedAt])
}

// ============================================
// SYNC MANAGEMENT MODELS
// ============================================

model SyncStatus {
  id                String          @id @default(uuid())
  shop              String
  syncType          String          // "orders", "customers", "products"
  lastSyncAt        DateTime        // Last time sync ran
  lastSuccessfulId  String?         // Last successfully synced record ID
  syncCursor        String?         // GraphQL cursor for pagination
  status            SyncStatusEnum  // Current sync status
  errorMessage      String?         // Error details if failed
  recordsProcessed  Int             @default(0) // Number of records processed
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([shop, syncType])
  @@index([shop, lastSyncAt])
}

enum SyncStatusEnum {
  IDLE
  RUNNING
