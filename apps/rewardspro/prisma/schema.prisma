  shop             String
  slug             String    // Unique identifier for the recommendation type
  type             String    // e.g., 'inactive_customers', 'tier_upgrade_opportunity'
  title            String
  description      String    @db.Text
  segmentPayload   Json      // Customer segment criteria and rules
