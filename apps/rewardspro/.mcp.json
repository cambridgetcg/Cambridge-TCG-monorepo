{
  "mcpServers": {
    "framer": {
      "type": "sse",
      "url": "https://mcp.unframer.co/sse?id=d991e528476689c08477f37392cf198b984bea08579bdfa73fb041df2ec80e78&secret=3NFxkbndEnjT0nKdibHyUMjFDYdwdSLx"
    },
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com"
    },
    "prisma": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "prisma", "mcp"]
    },
    "shopify-dev": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@shopify/dev-mcp@latest"]
    },
    "shopify-test": {
      "type": "stdio",
      "command": "node",
      "args": ["./mcp-shopify-server.js"],
      "env": {
        "SHOPIFY_APP_URL": "http://localhost:3000",
        "NODE_ENV": "development"
      }
    },
    "filesystem": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "."]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "postgres": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres"],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}"
      }
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    }
  }
}
