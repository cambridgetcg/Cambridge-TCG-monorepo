# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform provider lock files are intentionally committed. They pin reviewed
# provider checksums and are not state.

# Terraform directory
.terraform/

# Variable files with secrets
terraform.tfvars
*.auto.tfvars

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Sensitive outputs
lambda_placeholder.zip
tfplan
tfplan.*
*.tfplan
*.tfplan.*

# CLI configuration files
.terraformrc
terraform.rc
