{
  "include": ["env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": [
    "node_modules",
    "app/components/BalancedReactComponents.tsx",
    "app/components/PolarisSemanticExamples.tsx",
    "app/components/SemanticReactComponents.tsx",
    "app/components/renaissance/**",
    "test/**"
  ],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "removeComments": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "baseUrl": ".",
    "paths": {
      "~/*": ["./app/*"]
    },
    "types": ["node"]
  }
}
