{% comment %}
  RewardsPro Rewards Widget
  This app embed block adds a floating rewards widget to the storefront
{% endcomment %}

{% schema %}
{
  "name": "RewardsPro Widget",
  "target": "body",
  "enabled_on": {
    "templates": ["*"]
  },
  "stylesheet": "widget.css",
  "javascript": "widget-simple.js",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable",
      "label": "Enable RewardsPro Widget",
      "default": true,
      "info": "Show the rewards widget on your storefront"
    },
    {
      "type": "header",
      "content": "Widget Configuration"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Widget Position",
      "options": [
        { "value": "bottom-right", "label": "Bottom Right" },
        { "value": "bottom-left", "label": "Bottom Left" },
        { "value": "top-right", "label": "Top Right" },
        { "value": "top-left", "label": "Top Left" }
      ],
      "default": "bottom-right"
    },
    {
      "type": "checkbox",
      "id": "start_minimized",
      "label": "Start Minimized",
      "default": false,
      "info": "Widget starts as a small button"
    },
    {
      "type": "checkbox",
      "id": "inline_critical_css",
      "label": "Inline Critical CSS",
      "default": true,
      "info": "Prevents layout shift on page load"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "theme_color",
      "label": "Primary Color",
      "default": "#5C6AC4"
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Icon Style",
      "options": [
        { "value": "emoji", "label": "Emoji (🎁)" },
        { "value": "svg", "label": "SVG Icon" },
        { "value": "text", "label": "Text Only" }
      ],
      "default": "emoji"
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "range",
      "id": "animation_speed",
      "label": "Animation Speed",
      "min": 0,
      "max": 1000,
      "step": 100,
      "default": 300,
      "unit": "ms"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "widget_title",
      "label": "Widget Title",
      "default": "Rewards Center"
    },
    {
      "type": "textarea",
      "id": "guest_message",
      "label": "Guest Message",
      "default": "Join our rewards program and earn cashback on every purchase!"
    },
    {
      "type": "text",
      "id": "sign_in_text",
      "label": "Sign In Button Text",
      "default": "Sign In"
    },
    {
      "type": "text",
      "id": "register_text",
      "label": "Register Button Text",
      "default": "Join Now"
    },
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "checkbox",
      "id": "remember_state",
      "label": "Remember Minimize State",
      "default": true,
      "info": "Remember if user minimized the widget"
    },
    {
      "type": "range",
      "id": "auto_hide_delay",
      "label": "Auto-hide After (seconds)",
      "min": 0,
      "max": 30,
      "step": 5,
      "default": 0,
      "unit": "sec",
      "info": "0 = never auto-hide"
    },
    {
      "type": "header",
      "content": "Page Spacing"
    },
    {
      "type": "range",
      "id": "bottom_margin",
      "label": "Bottom Page Margin",
      "min": 0,
      "max": 200,
      "step": 10,
      "default": 80,
      "unit": "px",
      "info": "Adds space at the bottom of the page to prevent overlap"
    },
    {
      "type": "checkbox",
      "id": "enable_bottom_margin",
      "label": "Enable Bottom Margin",
      "default": true,
      "info": "Add spacing below the widget area"
    }
  ]
}
{% endschema %}

{% comment %} Only render if enabled {% endcomment %}
{% if block.settings.enable %}

  {% comment %} Inline critical CSS for immediate positioning {% endcomment %}
  {% if block.settings.inline_critical_css %}
    <style>
      .rp-widget-container {
        position: fixed;
        z-index: 999999;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        --rp-theme-color: {{ block.settings.theme_color }};
        --rp-animation-speed: {{ block.settings.animation_speed }}ms;
      }
      
      {% case block.settings.position %}
        {% when 'bottom-right' %}
          .rp-widget-container { bottom: 20px; right: 20px; }
        {% when 'bottom-left' %}
          .rp-widget-container { bottom: 20px; left: 20px; }
        {% when 'top-right' %}
          .rp-widget-container { top: 20px; right: 20px; }
        {% when 'top-left' %}
          .rp-widget-container { top: 20px; left: 20px; }
      {% endcase %}
      
      .rp-widget-minimized {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: var(--rp-theme-color);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform var(--rp-animation-speed) ease;
      }
      
      .rp-widget-minimized:hover {
        transform: scale(1.05);
      }
      
      {% unless block.settings.show_on_mobile %}
        @media (max-width: 768px) {
          .rp-widget-container { display: none !important; }
        }
      {% endunless %}
      
      /* Bottom spacer responsive styles */
      .rp-widget-bottom-spacer {
        background: transparent;
        pointer-events: none;
        user-select: none;
      }
      
      /* Reduce spacing on mobile */
      @media (max-width: 768px) {
        .rp-widget-bottom-spacer {
          height: {{ block.settings.bottom_margin | divided_by: 2 | default: 40 }}px !important;
        }
      }
      
      /* Ensure spacer works with different page layouts */
      body:has(.sticky-footer) .rp-widget-bottom-spacer {
        height: calc({{ block.settings.bottom_margin | default: 80 }}px + 20px) !important;
      }
    </style>
  {% endif %}

  {% comment %} 
    Security-hardened widget configuration
    NO customer IDs, emails, or sensitive data exposed
  {% endcomment %}
  
  {% comment %} Meta tags for session detection (server-side verified) {% endcomment %}
  {% if customer %}
    <meta name="rewardspro-session" content="authenticated">
    <meta name="rewardspro-session-check" content="{{ 'now' | date: '%s' | hmac: shop.domain }}">
  {% else %}
    <meta name="rewardspro-session" content="guest">
  {% endif %}
  
  <script>
    // SECURE: Only public, non-sensitive configuration
    window.RewardsProConfig = {
      // Session state (boolean only, no IDs or personal data)
      isAuthenticated: {% if customer %}true{% else %}false{% endif %},
      
      // Widget settings from theme customizer
      settings: {
        position: {{ block.settings.position | json }},
        startMinimized: {{ block.settings.start_minimized | json }},
        themeColor: {{ block.settings.theme_color | json }},
        iconStyle: {{ block.settings.icon_style | json }},
        animationSpeed: {{ block.settings.animation_speed }},
        rememberState: {{ block.settings.remember_state | json }},
        autoHideDelay: {{ block.settings.auto_hide_delay }},
        showOnMobile: {{ block.settings.show_on_mobile | json }}
      },
      
      // Content strings
      content: {
        title: {{ block.settings.widget_title | json }},
        guestMessage: {{ block.settings.guest_message | json }},
        signInText: {{ block.settings.sign_in_text | json }},
        registerText: {{ block.settings.register_text | json }}
      },
      
      // Shop information (public data only)
      shop: {
        domain: {{ shop.domain | json }},
        name: {{ shop.name | json }},
        currency: {{ shop.currency | json }},
        moneyFormat: {{ shop.money_format | json }},
        locale: {{ request.locale.iso_code | json }}
      },
      
      // Public URLs
      urls: {
        login: {{ routes.account_login_url | json }},
        register: {{ routes.account_register_url | json }},
        account: {{ routes.account_url | json }},
        // Protected app proxy endpoint (HMAC verified)
        membershipApi: {{ '/apps/rewardspro/membership' | json }}
      },
      
      // Environment flags
      environment: {
        debug: {% if request.host contains '.myshopify.io' %}true{% else %}false{% endif %},
        timestamp: {{ 'now' | date: '%s' }}
      }
    };
  </script>

  {% comment %} Widget container will be created by JavaScript {% endcomment %}
  <div id="rewardspro-widget-root" data-widget-version="1.0.0"></div>
  
  {% comment %} Bottom spacing to prevent widget touching page bottom {% endcomment %}
  {% if block.settings.enable_bottom_margin %}
    <div class="rp-widget-bottom-spacer" 
         aria-hidden="true" 
         style="height: {{ block.settings.bottom_margin | default: 80 }}px; width: 100%; display: block; clear: both;"></div>
  {% endif %}

{% endif %}