{% comment %}
  RewardsPro Rewards Widget
  This app embed block adds a floating rewards widget to the storefront
{% endcomment %}

{% schema %}
{
  "name": "RewardsPro Widget",
  "target": "body",
  "enabled_on": {
    "templates": ["*"]
  },
  "stylesheet": "widget.css",
  "javascript": "widget.js",
  "settings": [
    {
      "type": "header",
      "content": "Widget Configuration"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Widget Position",
      "options": [
        { "value": "bottom-right", "label": "Bottom Right" },
        { "value": "bottom-left", "label": "Bottom Left" },
        { "value": "top-right", "label": "Top Right" },
        { "value": "top-left", "label": "Top Left" }
      ],
      "default": "bottom-right"
    },
    {
      "type": "checkbox",
      "id": "start_minimized",
      "label": "Start Minimized",
      "default": false,
      "info": "Widget starts as a small button"
    },
    {
      "type": "checkbox",
      "id": "inline_critical_css",
      "label": "Inline Critical CSS",
      "default": true,
      "info": "Prevents layout shift on page load"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "theme_color",
      "label": "Primary Color",
      "default": "#5C6AC4"
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Icon Style",
      "options": [
        { "value": "emoji", "label": "Emoji (🎁)" },
        { "value": "svg", "label": "SVG Icon" },
        { "value": "text", "label": "Text Only" }
      ],
      "default": "emoji"
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on Mobile",
      "default": true
    },
    {
      "type": "range",
      "id": "animation_speed",
      "label": "Animation Speed",
      "min": 0,
      "max": 1000,
      "step": 100,
      "default": 300,
      "unit": "ms"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "widget_title",
      "label": "Widget Title",
      "default": "Rewards Center"
    },
    {
      "type": "textarea",
      "id": "guest_message",
      "label": "Guest Message",
      "default": "Join our rewards program and earn cashback on every purchase!"
    },
    {
      "type": "text",
      "id": "sign_in_text",
      "label": "Sign In Button Text",
      "default": "Sign In"
    },
    {
      "type": "text",
      "id": "register_text",
      "label": "Register Button Text",
      "default": "Join Now"
    },
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "checkbox",
      "id": "remember_state",
      "label": "Remember Minimize State",
      "default": true,
      "info": "Remember if user minimized the widget"
    },
    {
      "type": "range",
      "id": "auto_hide_delay",
      "label": "Auto-hide After (seconds)",
      "min": 0,
      "max": 30,
      "step": 5,
      "default": 0,
      "unit": "sec",
      "info": "0 = never auto-hide"
    }
  ]
}
{% endschema %}

{% comment %} Only render if enabled {% endcomment %}
{% if block.settings.enable %}

  {% comment %} Inline critical CSS for immediate positioning {% endcomment %}
  {% if block.settings.inline_critical_css %}
    <style>
      .rp-widget-container {
        position: fixed;
        z-index: 999999;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        --rp-theme-color: {{ block.settings.theme_color }};
        --rp-animation-speed: {{ block.settings.animation_speed }}ms;
      }
      
      {% case block.settings.position %}
        {% when 'bottom-right' %}
          .rp-widget-container { bottom: 20px; right: 20px; }
        {% when 'bottom-left' %}
          .rp-widget-container { bottom: 20px; left: 20px; }
        {% when 'top-right' %}
          .rp-widget-container { top: 20px; right: 20px; }
        {% when 'top-left' %}
          .rp-widget-container { top: 20px; left: 20px; }
      {% endcase %}
      
      .rp-widget-minimized {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background: var(--rp-theme-color);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform var(--rp-animation-speed) ease;
      }
      
      .rp-widget-minimized:hover {
        transform: scale(1.05);
      }
      
      {% unless block.settings.show_on_mobile %}
        @media (max-width: 768px) {
          .rp-widget-container { display: none !important; }
        }
      {% endunless %}
    </style>
  {% endif %}

  {% comment %} Widget configuration data {% endcomment %}
  <script>
    window.RewardsProConfig = {
      // Widget settings
      position: '{{ block.settings.position }}',
      startMinimized: {{ block.settings.start_minimized | json }},
      themeColor: '{{ block.settings.theme_color }}',
      iconStyle: '{{ block.settings.icon_style }}',
      animationSpeed: {{ block.settings.animation_speed }},
      rememberState: {{ block.settings.remember_state | json }},
      autoHideDelay: {{ block.settings.auto_hide_delay }},
      showOnMobile: {{ block.settings.show_on_mobile | json }},
      
      // Content
      title: {{ block.settings.widget_title | json }},
      guestMessage: {{ block.settings.guest_message | json }},
      signInText: {{ block.settings.sign_in_text | json }},
      registerText: {{ block.settings.register_text | json }},
      
      // Customer data
      customerId: {% if customer %}{{ customer.id | json }}{% else %}null{% endif %},
      customerEmail: {% if customer %}{{ customer.email | json }}{% else %}null{% endif %},
      customerName: {% if customer %}{{ customer.name | json }}{% else %}null{% endif %},
      customerTags: {% if customer %}{{ customer.tags | json }}{% else %}[]{% endif %},
      
      // Shop data
      shop: {{ shop.domain | json }},
      shopName: {{ shop.name | json }},
      shopCurrency: {{ shop.currency | json }},
      shopLocale: {{ request.locale.iso_code | json }},
      
      // URLs
      loginUrl: {{ routes.account_login_url | json }},
      registerUrl: {{ routes.account_register_url | json }},
      accountUrl: {{ routes.account_url | json }},
      
      // API endpoints
      membershipApiUrl: '/apps/rewardspro/membership',
      
      // Security
      sessionToken: '{{ content_for_header | escape }}',
      
      // Debug mode
      debug: {% if request.host contains '.myshopify.io' %}true{% else %}false{% endif %}
    };
  </script>

  {% comment %} Widget container will be created by JavaScript {% endcomment %}
  <div id="rewardspro-widget-root" data-widget-version="1.0.0"></div>

{% endif %}