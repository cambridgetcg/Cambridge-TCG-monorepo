<!-- Rewards Hub CTA Block -->
{% comment %}
  General call-to-action block for the rewards program:
  - Shows points balance teaser for logged-in customers
  - Encourages sign-up/login for guests
  - Links to customer account or rewards hub
{% endcomment %}

<div id="rp-rewards-hub-cta-{{ block.id }}"
     class="rp-rewards-hub-cta"
     data-block-id="{{ block.id }}"
     data-shop-domain="{{ shop.permanent_domain }}"
     data-api-endpoint="/apps/rewardspro/customer-summary"
     data-layout="{{ block.settings.layout | default: 'horizontal' }}"
     data-show-points="{{ block.settings.show_points | default: true }}"
     data-show-tier="{{ block.settings.show_tier | default: true }}"
     data-show-activities="{{ block.settings.show_activities | default: true }}"
     {% if customer %}
       data-customer-id="{{ customer.id }}"
       data-authenticated="true"
     {% else %}
       data-authenticated="false"
     {% endif %}
     style="
       {% if block.settings.background_color %}--rp-cta-bg: {{ block.settings.background_color }};{% endif %}
       {% if block.settings.text_color %}--rp-cta-text: {{ block.settings.text_color }};{% endif %}
       {% if block.settings.accent_color %}--rp-cta-accent: {{ block.settings.accent_color }};{% endif %}
       {% if block.settings.button_color %}--rp-cta-button: {{ block.settings.button_color }};{% endif %}
       {% if block.settings.button_text_color %}--rp-cta-button-text: {{ block.settings.button_text_color }};{% endif %}
     ">

  {% comment %} Loading state {% endcomment %}
  <div class="rp-rewards-hub-cta__loading">
    <div class="rp-rewards-hub-cta__loading-spinner"></div>
  </div>

  {% comment %} Authenticated customer content {% endcomment %}
  {% if customer %}
    <div class="rp-rewards-hub-cta__content rp-rewards-hub-cta__content--authenticated" style="display: none;">
      <div class="rp-rewards-hub-cta__header">
        <span class="rp-rewards-hub-cta__icon">{{ block.settings.member_icon | default: '⭐' }}</span>
        <span class="rp-rewards-hub-cta__greeting">{{ block.settings.greeting_text | default: 'Welcome back!' }}</span>
      </div>

      {% comment %} Dynamic content populated by JavaScript {% endcomment %}
      <div class="rp-rewards-hub-cta__summary">
        {% comment %} Points balance, tier, and activity counts will be rendered here {% endcomment %}
      </div>

      <a href="{{ block.settings.cta_url | default: '/account' }}" class="rp-rewards-hub-cta__button">
        {{ block.settings.cta_text | default: 'View My Rewards' }}
      </a>
    </div>
  {% else %}
    {% comment %} Guest content {% endcomment %}
    <div class="rp-rewards-hub-cta__content rp-rewards-hub-cta__content--guest" style="display: none;">
      <div class="rp-rewards-hub-cta__header">
        <span class="rp-rewards-hub-cta__icon">{{ block.settings.guest_icon | default: '🎁' }}</span>
        <span class="rp-rewards-hub-cta__title">{{ block.settings.guest_title | default: 'Join Our Rewards Program' }}</span>
      </div>

      <p class="rp-rewards-hub-cta__description">
        {{ block.settings.guest_description | default: 'Earn points, unlock exclusive perks, and get rewarded for every purchase.' }}
      </p>

      {% comment %} Activity highlights {% endcomment %}
      <div class="rp-rewards-hub-cta__highlights">
        {% comment %} JavaScript will render active raffles, challenges, etc. {% endcomment %}
      </div>

      <div class="rp-rewards-hub-cta__actions">
        <a href="{{ block.settings.signup_url | default: '/account/register' }}" class="rp-rewards-hub-cta__button rp-rewards-hub-cta__button--primary">
          {{ block.settings.signup_text | default: 'Sign Up' }}
        </a>
        <a href="{{ block.settings.login_url | default: '/account/login' }}" class="rp-rewards-hub-cta__button rp-rewards-hub-cta__button--secondary">
          {{ block.settings.login_text | default: 'Log In' }}
        </a>
      </div>
    </div>
  {% endif %}

  {% comment %} Error state {% endcomment %}
  <div class="rp-rewards-hub-cta__error" style="display: none;">
    <span>Unable to load rewards info</span>
  </div>
</div>

{% comment %} Fallback for browsers without JavaScript {% endcomment %}
<noscript>
  <div class="rp-rewards-hub-cta__noscript">
    {% if customer %}
      <a href="{{ block.settings.cta_url | default: '/account' }}">{{ block.settings.cta_text | default: 'View My Rewards' }}</a>
    {% else %}
      <a href="{{ block.settings.signup_url | default: '/account/register' }}">{{ block.settings.signup_text | default: 'Join Rewards' }}</a>
    {% endif %}
  </div>
</noscript>

{% schema %}
{
  "name": "Rewards Hub CTA",
  "target": "section",
  "stylesheet": "activity-teasers.css",
  "javascript": "activity-teasers.js",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout Style",
      "options": [
        { "value": "horizontal", "label": "Horizontal Banner" },
        { "value": "vertical", "label": "Vertical Card" },
        { "value": "compact", "label": "Compact" }
      ],
      "default": "horizontal",
      "info": "Choose how the CTA is displayed"
    },
    {
      "type": "header",
      "content": "Member Settings"
    },
    {
      "type": "text",
      "id": "member_icon",
      "label": "Member Icon",
      "default": "⭐"
    },
    {
      "type": "text",
      "id": "greeting_text",
      "label": "Greeting Text",
      "default": "Welcome back!"
    },
    {
      "type": "checkbox",
      "id": "show_points",
      "label": "Show Points Balance",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tier",
      "label": "Show Current Tier",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_activities",
      "label": "Show Activity Counts",
      "default": true,
      "info": "Show counts of active raffles, challenges, etc."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "View My Rewards"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Guest Settings"
    },
    {
      "type": "text",
      "id": "guest_icon",
      "label": "Guest Icon",
      "default": "🎁"
    },
    {
      "type": "text",
      "id": "guest_title",
      "label": "Guest Title",
      "default": "Join Our Rewards Program"
    },
    {
      "type": "textarea",
      "id": "guest_description",
      "label": "Guest Description",
      "default": "Earn points, unlock exclusive perks, and get rewarded for every purchase."
    },
    {
      "type": "text",
      "id": "signup_text",
      "label": "Sign Up Button Text",
      "default": "Sign Up"
    },
    {
      "type": "url",
      "id": "signup_url",
      "label": "Sign Up Link"
    },
    {
      "type": "text",
      "id": "login_text",
      "label": "Log In Button Text",
      "default": "Log In"
    },
    {
      "type": "url",
      "id": "login_url",
      "label": "Log In Link"
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Background Color"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color"
    }
  ]
}
{% endschema %}
