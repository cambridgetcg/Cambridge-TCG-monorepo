<!-- Mystery Box Teaser Block -->
{% comment %}
  Displays mystery boxes as discovery teasers throughout the store:
  - Shows available mystery boxes with rarity preview
  - Fetches real-time data from API
  - Links to customer account or rewards hub
{% endcomment %}

<div id="rp-mystery-box-teaser-{{ block.id }}"
     class="rp-mystery-box-teaser"
     data-block-id="{{ block.id }}"
     data-shop-domain="{{ shop.permanent_domain }}"
     data-api-endpoint="/apps/rewardspro/mystery-boxes"
     data-display-mode="{{ block.settings.display_mode | default: 'featured' }}"
     data-show-rarity="{{ block.settings.show_rarity | default: true }}"
     data-show-cost="{{ block.settings.show_cost | default: true }}"
     data-cta-text="{{ block.settings.cta_text | default: 'Open Now' }}"
     data-cta-url="{{ block.settings.cta_url | default: '/account' }}"
     data-max-display="{{ block.settings.max_display | default: 1 }}"
     {% if customer %}
       data-customer-id="{{ customer.id }}"
       data-authenticated="true"
     {% else %}
       data-authenticated="false"
       data-guest-cta-text="{{ block.settings.guest_cta_text | default: 'Sign In to Open' }}"
       data-guest-cta-url="{{ block.settings.guest_cta_url | default: '/account/login' }}"
     {% endif %}
     style="
       {% if block.settings.background_color %}--rp-teaser-bg: {{ block.settings.background_color }};{% endif %}
       {% if block.settings.text_color %}--rp-teaser-text: {{ block.settings.text_color }};{% endif %}
       {% if block.settings.accent_color %}--rp-teaser-accent: {{ block.settings.accent_color }};{% endif %}
     ">

  {% comment %} Loading state {% endcomment %}
  <div class="rp-mystery-box-teaser__loading">
    <div class="rp-mystery-box-teaser__loading-spinner"></div>
    <span>Loading mystery boxes...</span>
  </div>

  {% comment %} Content placeholder - populated by JavaScript {% endcomment %}
  <div class="rp-mystery-box-teaser__content" style="display: none;">
    {% comment %} JavaScript will render mystery box cards here {% endcomment %}
  </div>

  {% comment %} Empty state {% endcomment %}
  <div class="rp-mystery-box-teaser__empty" style="display: none;">
    <span class="rp-mystery-box-teaser__empty-icon">{{ block.settings.empty_icon | default: '🎁' }}</span>
    <span class="rp-mystery-box-teaser__empty-text">{{ block.settings.empty_message | default: 'No mystery boxes available' }}</span>
  </div>

  {% comment %} Error state {% endcomment %}
  <div class="rp-mystery-box-teaser__error" style="display: none;">
    <span>Unable to load mystery boxes</span>
  </div>
</div>

{% comment %} Fallback for browsers without JavaScript {% endcomment %}
<noscript>
  <div class="rp-mystery-box-teaser__noscript">
    {% if customer %}
      <a href="{{ block.settings.cta_url | default: '/account' }}">View mystery boxes</a>
    {% else %}
      <a href="{{ block.settings.guest_cta_url | default: '/account/login' }}">Sign in to open mystery boxes</a>
    {% endif %}
  </div>
</noscript>

{% schema %}
{
  "name": "Mystery Box Teaser",
  "target": "section",
  "stylesheet": "activity-teasers.css",
  "javascript": "activity-teasers.js",
  "settings": [
    {
      "type": "header",
      "content": "Display Settings"
    },
    {
      "type": "select",
      "id": "display_mode",
      "label": "Display Mode",
      "options": [
        { "value": "featured", "label": "Featured Box Only" },
        { "value": "all", "label": "All Available Boxes" }
      ],
      "default": "featured",
      "info": "Show the most recent active box or all available boxes"
    },
    {
      "type": "range",
      "id": "max_display",
      "label": "Maximum Boxes to Show",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 1,
      "info": "Only applies when showing all boxes"
    },
    {
      "type": "checkbox",
      "id": "show_rarity",
      "label": "Show Rarity Preview",
      "default": true,
      "info": "Display reward rarity distribution (e.g., Legendary: 1%)"
    },
    {
      "type": "checkbox",
      "id": "show_cost",
      "label": "Show Open Cost",
      "default": true,
      "info": "Display points required to open"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Open Now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button Link",
      "info": "Where to send customers"
    },
    {
      "type": "text",
      "id": "guest_cta_text",
      "label": "Guest Button Text",
      "default": "Sign In to Open"
    },
    {
      "type": "url",
      "id": "guest_cta_url",
      "label": "Guest Button Link"
    },
    {
      "type": "header",
      "content": "Empty State"
    },
    {
      "type": "text",
      "id": "empty_icon",
      "label": "Empty State Icon",
      "default": "🎁"
    },
    {
      "type": "text",
      "id": "empty_message",
      "label": "Empty State Message",
      "default": "No mystery boxes available"
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "info": "Used for buttons and highlights"
    }
  ]
}
{% endschema %}
