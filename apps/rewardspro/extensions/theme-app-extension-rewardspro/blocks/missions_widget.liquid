<!-- MOBILE-REVIEWED: 2026-03-22 -->
<!-- Missions Widget Block -->
{%- render 'rp_utils_loader' -%}
{%- assign guest_cta_url = block.settings.guest_cta_url -%}
{%- if guest_cta_url == blank or guest_cta_url == '/account/login' -%}
  {%- assign guest_cta_url = routes.account_login_url -%}
{%- endif -%}
{% comment %}
  Gamified Missions Widget:
  - Detects customer login status automatically
  - Fetches real-time missions data from proxy API
  - Shows player stats, mission cards by cadence, claim flow
  - Renders celebration animations for completed missions
{% endcomment %}

{% comment %}
  API endpoint uses relative URL to avoid CORS issues with custom domains.
  The browser will resolve this to the current domain.
{% endcomment %}

{% if customer %}
  {% comment %} AUTHENTICATED STATE - Customer is logged in {% endcomment %}
  <div id="missions-widget-root"
       class="rp-missions-root"
       data-rp-utils-src="{{ 'rp-utils.js' | asset_url }}"
       data-rp-widget-src="{{ 'missions-widget.js' | asset_url }}"
       data-state="authenticated"
       data-customer-id="{{ customer.id }}"
       data-shop-domain="{{ shop.permanent_domain }}"
       data-api-endpoint="/apps/rewardspro/missions"
       data-claim-endpoint="/apps/rewardspro/challenges/claim"
       data-events-ack-endpoint="/apps/rewardspro/missions/events/ack"
       data-cache-duration="{{ block.settings.cache_duration | default: 30 }}"
       data-default-tab="{{ block.settings.default_tab | default: 'daily' }}">
    {% comment %} Loading placeholder - replaced by JavaScript {% endcomment %}
    <div class="rp-missions-loading">Loading missions...</div>
  </div>
{% else %}
  {% comment %} GUEST STATE - Customer is NOT logged in {% endcomment %}
  <div id="missions-widget-root"
       class="rp-missions-root"
       data-rp-utils-src="{{ 'rp-utils.js' | asset_url }}"
       data-rp-widget-src="{{ 'missions-widget.js' | asset_url }}"
       data-state="guest"
       data-shop-domain="{{ shop.permanent_domain }}"
       data-message="{{ block.settings.guest_message | default: 'Complete missions to earn XP and level up!' }}"
       data-cta-text="{{ block.settings.guest_cta_text | default: 'Sign In' }}"
       data-cta-url="{{ guest_cta_url }}">
    {% comment %} Guest placeholder - replaced by JavaScript {% endcomment %}
    <div class="rp-missions-guest">Sign in to view missions</div>
  </div>
{% endif %}

{% comment %} Fallback for browsers without JavaScript {% endcomment %}
<noscript>
  <div class="rp-missions-noscript">
    {% if customer %}
      Welcome back, {{ customer.first_name }}!
      <a href="{{ routes.account_url }}">Visit your account</a> to view missions.
    {% else %}
      <a href="{{ routes.account_login_url }}">Sign in</a> to view your missions.
    {% endif %}
  </div>
</noscript>

{% schema %}
{
  "name": "RewardsPro Missions",
  "target": "body",
  "stylesheet": "missions-widget.css",
  "javascript": "rp-widget-loader.js",
  "settings": [
    {
      "type": "header",
      "content": "Performance Settings"
    },
    {
      "type": "range",
      "id": "cache_duration",
      "label": "Cache duration (seconds)",
      "min": 15,
      "max": 120,
      "step": 15,
      "default": 30,
      "unit": "sec",
      "info": "How long to cache missions data. Lower = fresher progress, higher = better performance."
    },
    {
      "type": "select",
      "id": "default_tab",
      "label": "Default tab",
      "default": "daily",
      "options": [
        { "value": "daily", "label": "Daily" },
        { "value": "weekly", "label": "Weekly" },
        { "value": "monthly", "label": "Monthly" },
        { "value": "special", "label": "Special" }
      ],
      "info": "Which mission cadence tab to show by default."
    },
    {
      "type": "header",
      "content": "Guest User Settings"
    },
    {
      "type": "paragraph",
      "content": "These settings apply when a customer is NOT signed in"
    },
    {
      "type": "text",
      "id": "guest_message",
      "label": "Guest Message",
      "default": "Complete missions to earn XP and level up!",
      "info": "Message shown to non-logged-in visitors"
    },
    {
      "type": "text",
      "id": "guest_cta_text",
      "label": "Guest Button Text",
      "default": "Sign In",
      "info": "Text on the sign-in button for guests"
    },
    {
      "type": "text",
      "id": "guest_cta_url",
      "label": "Guest Button URL",
      "info": "Optional custom URL. Leave blank to use the store's customer-account sign-in route."
    }
  ]
}
{% endschema %}
