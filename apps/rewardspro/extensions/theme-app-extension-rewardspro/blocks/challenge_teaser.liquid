<!-- Challenge Teaser Block -->
{% comment %}
  Displays active challenges with progress as discovery teasers:
  - Shows customer's challenge progress
  - Fetches real-time progress data from API
  - Links to customer account or rewards hub
{% endcomment %}

<div id="rp-challenge-teaser-{{ block.id }}"
     class="rp-challenge-teaser"
     data-block-id="{{ block.id }}"
     data-shop-domain="{{ shop.permanent_domain }}"
     data-api-endpoint="/apps/rewardspro/challenges"
     data-display-mode="{{ block.settings.display_mode | default: 'featured' }}"
     data-show-progress="{{ block.settings.show_progress | default: true }}"
     data-show-reward="{{ block.settings.show_reward | default: true }}"
     data-show-countdown="{{ block.settings.show_countdown | default: true }}"
     data-cta-text="{{ block.settings.cta_text | default: 'View Challenge' }}"
     data-cta-url="{{ block.settings.cta_url | default: '/account' }}"
     data-max-display="{{ block.settings.max_display | default: 1 }}"
     {% if customer %}
       data-customer-id="{{ customer.id }}"
       data-authenticated="true"
     {% else %}
       data-authenticated="false"
       data-guest-cta-text="{{ block.settings.guest_cta_text | default: 'Sign In to Join' }}"
       data-guest-cta-url="{{ block.settings.guest_cta_url | default: '/account/login' }}"
     {% endif %}
     style="
       {% if block.settings.background_color %}--rp-teaser-bg: {{ block.settings.background_color }};{% endif %}
       {% if block.settings.text_color %}--rp-teaser-text: {{ block.settings.text_color }};{% endif %}
       {% if block.settings.accent_color %}--rp-teaser-accent: {{ block.settings.accent_color }};{% endif %}
       {% if block.settings.progress_color %}--rp-progress-color: {{ block.settings.progress_color }};{% endif %}
     ">

  {% comment %} Loading state {% endcomment %}
  <div class="rp-challenge-teaser__loading">
    <div class="rp-challenge-teaser__loading-spinner"></div>
    <span>Loading challenges...</span>
  </div>

  {% comment %} Content placeholder - populated by JavaScript {% endcomment %}
  <div class="rp-challenge-teaser__content" style="display: none;">
    {% comment %} JavaScript will render challenge cards here {% endcomment %}
  </div>

  {% comment %} Empty state {% endcomment %}
  <div class="rp-challenge-teaser__empty" style="display: none;">
    <span class="rp-challenge-teaser__empty-icon">{{ block.settings.empty_icon | default: '🏆' }}</span>
    <span class="rp-challenge-teaser__empty-text">{{ block.settings.empty_message | default: 'No active challenges right now' }}</span>
  </div>

  {% comment %} Error state {% endcomment %}
  <div class="rp-challenge-teaser__error" style="display: none;">
    <span>Unable to load challenges</span>
  </div>
</div>

{% comment %} Fallback for browsers without JavaScript {% endcomment %}
<noscript>
  <div class="rp-challenge-teaser__noscript">
    {% if customer %}
      <a href="{{ block.settings.cta_url | default: '/account' }}">View challenges</a>
    {% else %}
      <a href="{{ block.settings.guest_cta_url | default: '/account/login' }}">Sign in to join challenges</a>
    {% endif %}
  </div>
</noscript>

{% schema %}
{
  "name": "Challenge Teaser",
  "target": "section",
  "stylesheet": "activity-teasers.css",
  "javascript": "activity-teasers.js",
  "settings": [
    {
      "type": "header",
      "content": "Display Settings"
    },
    {
      "type": "select",
      "id": "display_mode",
      "label": "Display Mode",
      "options": [
        { "value": "featured", "label": "Featured Challenge Only" },
        { "value": "active", "label": "All Active Challenges" },
        { "value": "in_progress", "label": "Customer's In-Progress Only" }
      ],
      "default": "featured",
      "info": "Which challenges to display"
    },
    {
      "type": "range",
      "id": "max_display",
      "label": "Maximum Challenges to Show",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 1,
      "info": "Only applies when showing multiple challenges"
    },
    {
      "type": "checkbox",
      "id": "show_progress",
      "label": "Show Progress Bar",
      "default": true,
      "info": "Display customer's progress toward goal"
    },
    {
      "type": "checkbox",
      "id": "show_reward",
      "label": "Show Reward",
      "default": true,
      "info": "Display the reward for completing the challenge"
    },
    {
      "type": "checkbox",
      "id": "show_countdown",
      "label": "Show Countdown",
      "default": true,
      "info": "Display time remaining for the challenge"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "View Challenge"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button Link",
      "info": "Where to send customers"
    },
    {
      "type": "text",
      "id": "guest_cta_text",
      "label": "Guest Button Text",
      "default": "Sign In to Join"
    },
    {
      "type": "url",
      "id": "guest_cta_url",
      "label": "Guest Button Link"
    },
    {
      "type": "header",
      "content": "Empty State"
    },
    {
      "type": "text",
      "id": "empty_icon",
      "label": "Empty State Icon",
      "default": "🏆"
    },
    {
      "type": "text",
      "id": "empty_message",
      "label": "Empty State Message",
      "default": "No active challenges right now"
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "info": "Used for buttons and highlights"
    },
    {
      "type": "color",
      "id": "progress_color",
      "label": "Progress Bar Color",
      "default": "#4CAF50"
    }
  ]
}
{% endschema %}
