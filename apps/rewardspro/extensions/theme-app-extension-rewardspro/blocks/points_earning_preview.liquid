<!-- Points Earning Preview Block -->
{% comment %}
  Displays estimated points to be earned on product pages
  - Reads points config from shop metafields
  - Calculates points based on product price
  - Shows bonus indicator when promotional events are active
  - Updates dynamically on variant change
{% endcomment %}

{% comment %} Only render if we have a product and points are enabled {% endcomment %}
{% if product %}
  <div id="rp-points-preview-{{ product.id }}"
       class="rp-points-preview"
       data-product-id="{{ product.id }}"
       data-product-price="{{ product.selected_or_first_available_variant.price }}"
       data-shop-domain="{{ shop.permanent_domain }}"
       data-points-per-dollar="{{ shop.metafields.rewardspro.points_per_dollar | default: 10 }}"
       data-currency-icon="{{ shop.metafields.rewardspro.points_icon | default: '' }}"
       data-currency-name="{{ shop.metafields.rewardspro.points_name | default: 'points' }}"
       data-bonus-multiplier="{{ shop.metafields.rewardspro.bonus_multiplier | default: 1 }}"
       data-bonus-name="{{ shop.metafields.rewardspro.bonus_name | default: '' }}"
       data-tier-multiplier="{{ customer.metafields.rewardspro.tier_multiplier | default: 1 }}"
       data-show-bonus="{{ block.settings.show_bonus_indicator }}"
       data-show-tier-bonus="{{ block.settings.show_tier_bonus }}"
       style="{% if block.settings.text_color %}color: {{ block.settings.text_color }};{% endif %}">

    {% comment %} Points icon {% endcomment %}
    <span class="rp-points-preview__icon">
      {{ shop.metafields.rewardspro.points_icon | default: '' }}
    </span>

    {% comment %} Points text {% endcomment %}
    <span class="rp-points-preview__text">
      {{ block.settings.earn_text | default: 'Earn' }}
      <span class="rp-points-preview__value" data-points-value>
        {% comment %}
          Calculate initial points: (price in cents / 100) * pointsPerDollar * tierMultiplier * bonusMultiplier
          JavaScript will update this on variant change
        {% endcomment %}
        {% assign price_dollars = product.selected_or_first_available_variant.price | divided_by: 100.0 %}
        {% assign points_per_dollar = shop.metafields.rewardspro.points_per_dollar | default: 10 | times: 1.0 %}
        {% assign tier_multiplier = customer.metafields.rewardspro.tier_multiplier | default: 1 | times: 1.0 %}
        {% assign bonus_multiplier = shop.metafields.rewardspro.bonus_multiplier | default: 1 | times: 1.0 %}
        {% assign estimated_points = price_dollars | times: points_per_dollar | times: tier_multiplier | times: bonus_multiplier | floor %}
        {{ estimated_points }}
      </span>
      {{ shop.metafields.rewardspro.points_name | default: 'points' }}
    </span>

    {% comment %} Active bonus indicator {% endcomment %}
    {% if block.settings.show_bonus_indicator and shop.metafields.rewardspro.bonus_multiplier and shop.metafields.rewardspro.bonus_multiplier > 1 %}
      <span class="rp-points-preview__bonus-badge">
        {{ shop.metafields.rewardspro.bonus_multiplier }}x {{ shop.metafields.rewardspro.bonus_name | default: 'Bonus' }}!
      </span>
    {% endif %}

    {% comment %} Tier bonus indicator {% endcomment %}
    {% if block.settings.show_tier_bonus and customer and customer.metafields.rewardspro.tier_multiplier and customer.metafields.rewardspro.tier_multiplier > 1 %}
      <span class="rp-points-preview__tier-badge">
        {{ customer.metafields.rewardspro.tier_name | default: 'Member' }} {{ customer.metafields.rewardspro.tier_multiplier }}x
      </span>
    {% endif %}
  </div>
{% endif %}

{% comment %} Fallback for browsers without JavaScript {% endcomment %}
<noscript>
  <style>
    .rp-points-preview__value { display: inline; }
  </style>
</noscript>

{% schema %}
{
  "name": "Points Earning Preview",
  "target": "section",
  "stylesheet": "points-preview.css",
  "javascript": "points-preview.js",
  "settings": [
    {
      "type": "header",
      "content": "Display Settings"
    },
    {
      "type": "text",
      "id": "earn_text",
      "label": "Earn Text",
      "default": "Earn",
      "info": "Text before the points value (e.g., 'Earn' or 'Get')"
    },
    {
      "type": "checkbox",
      "id": "show_bonus_indicator",
      "label": "Show bonus event indicator",
      "default": true,
      "info": "Display a badge when promotional bonus events are active"
    },
    {
      "type": "checkbox",
      "id": "show_tier_bonus",
      "label": "Show tier bonus indicator",
      "default": false,
      "info": "Display the customer's tier multiplier bonus"
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "badge_background",
      "label": "Bonus Badge Background",
      "default": "#FFD700"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Bonus Badge Text Color",
      "default": "#000000"
    }
  ]
}
{% endschema %}
