<!-- Rewards Hub Section Block -->
{% comment %}
  Full-page rewards hub section for dedicated rewards landing pages.
  Displays all rewards features in a comprehensive layout:
  - Customer points/credit balance
  - Tier status and progress
  - Active raffles
  - Mystery boxes
  - Challenges
  - Recent activity
{% endcomment %}

<section id="rp-rewards-hub-{{ block.id }}"
         class="rp-rewards-hub"
         data-block-id="{{ block.id }}"
         data-shop-domain="{{ shop.permanent_domain }}"
         data-shop-currency="{{ shop.currency }}"
         data-membership-endpoint="/apps/rewardspro/membership"
         data-raffles-endpoint="/apps/rewardspro/raffles"
         data-mystery-boxes-endpoint="/apps/rewardspro/mystery-boxes"
         data-challenges-endpoint="/apps/rewardspro/challenges"
         data-show-balance="{{ block.settings.show_balance | default: true }}"
         data-show-tier="{{ block.settings.show_tier | default: true }}"
         data-show-raffles="{{ block.settings.show_raffles | default: true }}"
         data-show-mystery-boxes="{{ block.settings.show_mystery_boxes | default: true }}"
         data-show-challenges="{{ block.settings.show_challenges | default: true }}"
         data-max-items="{{ block.settings.max_items | default: 4 }}"
         {% if customer %}
           data-customer-id="{{ customer.id }}"
           data-authenticated="true"
         {% else %}
           data-authenticated="false"
         {% endif %}
         style="
           {% if block.settings.background_color %}--rp-hub-bg: {{ block.settings.background_color }};{% endif %}
           {% if block.settings.text_color %}--rp-hub-text: {{ block.settings.text_color }};{% endif %}
           {% if block.settings.accent_color %}--rp-hub-accent: {{ block.settings.accent_color }};{% endif %}
           {% if block.settings.card_bg_color %}--rp-hub-card-bg: {{ block.settings.card_bg_color }};{% endif %}
         ">

  {% comment %} Header Section {% endcomment %}
  <div class="rp-rewards-hub__header">
    <h1 class="rp-rewards-hub__title">{{ block.settings.title | default: 'My Rewards' }}</h1>
    {% if block.settings.subtitle %}
      <p class="rp-rewards-hub__subtitle">{{ block.settings.subtitle }}</p>
    {% endif %}
  </div>

  {% if customer %}
    {% comment %} Authenticated Customer View {% endcomment %}
    <div class="rp-rewards-hub__content" style="display: none;">

      {% comment %} Balance & Tier Card {% endcomment %}
      <div class="rp-rewards-hub__summary">
        <div class="rp-rewards-hub__summary-loading">
          <div class="rp-rewards-hub__loading-spinner"></div>
          <span>Loading your rewards...</span>
        </div>
        <div class="rp-rewards-hub__summary-content" style="display: none;">
          {% comment %} Populated by JavaScript {% endcomment %}
        </div>
      </div>

      {% comment %} Activity Grid {% endcomment %}
      <div class="rp-rewards-hub__activities">

        {% comment %} Raffles Section {% endcomment %}
        {% if block.settings.show_raffles %}
          <div class="rp-rewards-hub__section rp-rewards-hub__raffles" data-section="raffles">
            <div class="rp-rewards-hub__section-header">
              <h2 class="rp-rewards-hub__section-title">
                <span class="rp-rewards-hub__section-icon">🎟️</span>
                {{ block.settings.raffles_title | default: 'Active Raffles' }}
              </h2>
              {% if block.settings.raffles_view_all_url %}
                <a href="{{ block.settings.raffles_view_all_url }}" class="rp-rewards-hub__view-all">View All</a>
              {% endif %}
            </div>
            <div class="rp-rewards-hub__section-loading">
              <div class="rp-rewards-hub__loading-spinner"></div>
            </div>
            <div class="rp-rewards-hub__section-content" style="display: none;">
              {% comment %} Raffle cards populated by JavaScript {% endcomment %}
            </div>
            <div class="rp-rewards-hub__section-empty" style="display: none;">
              <span class="rp-rewards-hub__empty-icon">🎟️</span>
              <span class="rp-rewards-hub__empty-text">No active raffles right now</span>
            </div>
          </div>
        {% endif %}

        {% comment %} Mystery Boxes Section {% endcomment %}
        {% if block.settings.show_mystery_boxes %}
          <div class="rp-rewards-hub__section rp-rewards-hub__mystery-boxes" data-section="mystery-boxes">
            <div class="rp-rewards-hub__section-header">
              <h2 class="rp-rewards-hub__section-title">
                <span class="rp-rewards-hub__section-icon">🎁</span>
                {{ block.settings.mystery_boxes_title | default: 'Mystery Boxes' }}
              </h2>
              {% if block.settings.mystery_boxes_view_all_url %}
                <a href="{{ block.settings.mystery_boxes_view_all_url }}" class="rp-rewards-hub__view-all">View All</a>
              {% endif %}
            </div>
            <div class="rp-rewards-hub__section-loading">
              <div class="rp-rewards-hub__loading-spinner"></div>
            </div>
            <div class="rp-rewards-hub__section-content" style="display: none;">
              {% comment %} Mystery box cards populated by JavaScript {% endcomment %}
            </div>
            <div class="rp-rewards-hub__section-empty" style="display: none;">
              <span class="rp-rewards-hub__empty-icon">🎁</span>
              <span class="rp-rewards-hub__empty-text">No mystery boxes available</span>
            </div>
          </div>
        {% endif %}

        {% comment %} Challenges Section {% endcomment %}
        {% if block.settings.show_challenges %}
          <div class="rp-rewards-hub__section rp-rewards-hub__challenges" data-section="challenges">
            <div class="rp-rewards-hub__section-header">
              <h2 class="rp-rewards-hub__section-title">
                <span class="rp-rewards-hub__section-icon">🏆</span>
                {{ block.settings.challenges_title | default: 'Challenges' }}
              </h2>
              {% if block.settings.challenges_view_all_url %}
                <a href="{{ block.settings.challenges_view_all_url }}" class="rp-rewards-hub__view-all">View All</a>
              {% endif %}
            </div>
            <div class="rp-rewards-hub__section-loading">
              <div class="rp-rewards-hub__loading-spinner"></div>
            </div>
            <div class="rp-rewards-hub__section-content" style="display: none;">
              {% comment %} Challenge cards populated by JavaScript {% endcomment %}
            </div>
            <div class="rp-rewards-hub__section-empty" style="display: none;">
              <span class="rp-rewards-hub__empty-icon">🏆</span>
              <span class="rp-rewards-hub__empty-text">No active challenges</span>
            </div>
          </div>
        {% endif %}

      </div>
    </div>

    {% comment %} Loading State {% endcomment %}
    <div class="rp-rewards-hub__loading">
      <div class="rp-rewards-hub__loading-spinner"></div>
      <span>Loading your rewards...</span>
    </div>

    {% comment %} Error State {% endcomment %}
    <div class="rp-rewards-hub__error" style="display: none;">
      <span class="rp-rewards-hub__error-icon">⚠️</span>
      <span class="rp-rewards-hub__error-text">Unable to load rewards data</span>
      <button class="rp-rewards-hub__retry-btn" data-retry="true">Try Again</button>
    </div>

  {% else %}
    {% comment %} Guest View {% endcomment %}
    <div class="rp-rewards-hub__guest">
      <div class="rp-rewards-hub__guest-content">
        <span class="rp-rewards-hub__guest-icon">{{ block.settings.guest_icon | default: '🎁' }}</span>
        <h2 class="rp-rewards-hub__guest-title">{{ block.settings.guest_title | default: 'Join Our Rewards Program' }}</h2>
        <p class="rp-rewards-hub__guest-description">
          {{ block.settings.guest_description | default: 'Sign in to earn points, enter raffles, open mystery boxes, and unlock exclusive rewards.' }}
        </p>
        <div class="rp-rewards-hub__guest-benefits">
          <div class="rp-rewards-hub__benefit">
            <span class="rp-rewards-hub__benefit-icon">⭐</span>
            <span class="rp-rewards-hub__benefit-text">Earn points on purchases</span>
          </div>
          <div class="rp-rewards-hub__benefit">
            <span class="rp-rewards-hub__benefit-icon">🎟️</span>
            <span class="rp-rewards-hub__benefit-text">Enter exclusive raffles</span>
          </div>
          <div class="rp-rewards-hub__benefit">
            <span class="rp-rewards-hub__benefit-icon">🎁</span>
            <span class="rp-rewards-hub__benefit-text">Open mystery boxes</span>
          </div>
          <div class="rp-rewards-hub__benefit">
            <span class="rp-rewards-hub__benefit-icon">🏆</span>
            <span class="rp-rewards-hub__benefit-text">Complete challenges</span>
          </div>
        </div>
        <div class="rp-rewards-hub__guest-actions">
          <a href="{{ block.settings.signup_url | default: '/account/register' }}" class="rp-rewards-hub__btn rp-rewards-hub__btn--primary">
            {{ block.settings.signup_text | default: 'Create Account' }}
          </a>
          <a href="{{ block.settings.login_url | default: '/account/login' }}" class="rp-rewards-hub__btn rp-rewards-hub__btn--secondary">
            {{ block.settings.login_text | default: 'Sign In' }}
          </a>
        </div>
      </div>
    </div>
  {% endif %}
</section>

{% comment %} Fallback for browsers without JavaScript {% endcomment %}
<noscript>
  <div class="rp-rewards-hub__noscript">
    {% if customer %}
      <p>Please enable JavaScript to view your rewards.</p>
      <a href="/account">Go to Account</a>
    {% else %}
      <a href="{{ block.settings.login_url | default: '/account/login' }}">Sign in to view rewards</a>
    {% endif %}
  </div>
</noscript>

{% schema %}
{
  "name": "Rewards Hub",
  "target": "section",
  "stylesheet": "rewards-hub.css",
  "javascript": "rewards-hub.js",
  "settings": [
    {
      "type": "header",
      "content": "Page Header"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "My Rewards"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Earn points, enter raffles, and unlock exclusive rewards"
    },
    {
      "type": "header",
      "content": "Sections to Display"
    },
    {
      "type": "checkbox",
      "id": "show_balance",
      "label": "Show Points/Credit Balance",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_tier",
      "label": "Show Tier Status",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_raffles",
      "label": "Show Raffles",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_mystery_boxes",
      "label": "Show Mystery Boxes",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_challenges",
      "label": "Show Challenges",
      "default": true
    },
    {
      "type": "range",
      "id": "max_items",
      "label": "Max Items Per Section",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Section Titles"
    },
    {
      "type": "text",
      "id": "raffles_title",
      "label": "Raffles Section Title",
      "default": "Active Raffles"
    },
    {
      "type": "url",
      "id": "raffles_view_all_url",
      "label": "Raffles View All Link"
    },
    {
      "type": "text",
      "id": "mystery_boxes_title",
      "label": "Mystery Boxes Section Title",
      "default": "Mystery Boxes"
    },
    {
      "type": "url",
      "id": "mystery_boxes_view_all_url",
      "label": "Mystery Boxes View All Link"
    },
    {
      "type": "text",
      "id": "challenges_title",
      "label": "Challenges Section Title",
      "default": "Challenges"
    },
    {
      "type": "url",
      "id": "challenges_view_all_url",
      "label": "Challenges View All Link"
    },
    {
      "type": "header",
      "content": "Guest Settings"
    },
    {
      "type": "text",
      "id": "guest_icon",
      "label": "Guest Icon",
      "default": "🎁"
    },
    {
      "type": "text",
      "id": "guest_title",
      "label": "Guest Title",
      "default": "Join Our Rewards Program"
    },
    {
      "type": "textarea",
      "id": "guest_description",
      "label": "Guest Description",
      "default": "Sign in to earn points, enter raffles, open mystery boxes, and unlock exclusive rewards."
    },
    {
      "type": "text",
      "id": "signup_text",
      "label": "Sign Up Button Text",
      "default": "Create Account"
    },
    {
      "type": "url",
      "id": "signup_url",
      "label": "Sign Up Link"
    },
    {
      "type": "text",
      "id": "login_text",
      "label": "Login Button Text",
      "default": "Sign In"
    },
    {
      "type": "url",
      "id": "login_url",
      "label": "Login Link"
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background Color"
    }
  ]
}
{% endschema %}
