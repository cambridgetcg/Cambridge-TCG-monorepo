<!-- MOBILE-REVIEWED: 2026-03-22 -->
<!-- Membership Widget Block -->
{%- render 'rp_utils_loader' -%}
{%- assign guest_cta_url = block.settings.guest_cta_url -%}
{%- if guest_cta_url == blank or guest_cta_url == '/account/login' -%}
  {%- assign guest_cta_url = routes.account_login_url -%}
{%- endif -%}
{% comment %}
  Enhanced Dynamic Widget:
  - Detects customer login status automatically
  - Fetches real-time data from proxy API
  - Falls back to cached data if API unavailable
  - Shows loading/error states appropriately
{% endcomment %}

{% comment %}
  API endpoint uses relative URL to avoid CORS issues with custom domains.
  The browser will resolve this to the current domain (e.g., www.cambridgetcg.com/apps/rewardspro/membership)
  rather than forcing myshopify.com domain which triggers redirects and breaks CORS preflight.
{% endcomment %}

{%- comment -%}
  i18n: Translatable strings are resolved in Liquid via `| t` and passed to JS
  through `data-i18n-*` attributes. JS reads them at render time; if a key is
  missing, the JS falls back to its hardcoded English default. This lets us
  localize without a full client-side i18n runtime in the widget.
{%- endcomment -%}
{%- capture i18n_data -%}
  data-i18n-loading="{{ 'widget.membership.loading' | t }}"
  data-i18n-guest-fallback="{{ 'widget.membership.guestFallback' | t }}"
  data-i18n-unavailable-title="{{ 'widget.membership.unavailableTitle' | t }}"
  data-i18n-unavailable-subtitle="{{ 'widget.membership.unavailableSubtitle' | t }}"
  data-i18n-unavailable-message="{{ 'widget.membership.unavailableMessage' | t }}"
  data-i18n-retry="{{ 'widget.membership.retry' | t }}"
  data-i18n-view-account="{{ 'widget.membership.viewAccount' | t }}"
  data-i18n-collapse="{{ 'widget.membership.collapse' | t }}"
  data-i18n-expand="{{ 'widget.membership.expand' | t }}"
  data-i18n-member-benefits="{{ 'widget.membership.memberBenefits' | t }}"
  data-i18n-perk-store-credit="{{ 'widget.membership.perkStoreCredit' | t }}"
  data-i18n-perk-tier-status="{{ 'widget.membership.perkTierStatus' | t }}"
  data-i18n-perk-progress="{{ 'widget.membership.perkProgress' | t }}"
  data-i18n-store-credit-balance="{{ 'widget.membership.storeCreditBalance' | t }}"
  data-i18n-tier-label="{{ 'widget.membership.tierLabel' | t }}"
  data-i18n-cashback-label="{{ 'widget.membership.cashbackLabel' | t }}"
  data-i18n-progress-label="{{ 'widget.membership.progressLabel' | t }}"
  data-i18n-cashback-rate="{{ 'widget.membership.cashbackRate' | t }}"
  data-i18n-credit-with-rate="{{ 'widget.membership.creditWithRate' | t }}"
  data-i18n-max-tier="{{ 'widget.membership.maxTierReached' | t }}"
  data-i18n-max-tier-title="{{ 'widget.membership.maxTierTitle' | t }}"
  data-i18n-max-tier-message="{{ 'widget.membership.maxTierMessage' | t }}"
  data-i18n-progress-unlocks="{{ 'widget.membership.progressUnlocks' | t }}"
  data-i18n-notfound-title="{{ 'widget.membership.notFoundTitle' | t }}"
  data-i18n-notfound-message="{{ 'widget.membership.notFoundMessage' | t }}"
{%- endcapture -%}

{% if customer %}
  {% comment %} AUTHENTICATED STATE - Customer is logged in {% endcomment %}
  <div id="membership-widget-root"
       class="rp-widget-root"
       data-rp-utils-src="{{ 'rp-utils.js' | asset_url }}"
       data-rp-widget-src="{{ 'membership-widget.js' | asset_url }}"
       data-state="authenticated"
       data-customer-id="{{ customer.id }}"
       data-customer-email="{{ customer.email }}"
       data-customer-name="{{ customer.first_name | default: 'Member' }}"
       data-customer-tags="{{ customer.tags | join: ',' }}"
       data-shop-domain="{{ shop.permanent_domain }}"
       data-shop-currency="{{ shop.currency }}"
       data-api-endpoint="/apps/rewardspro/membership"
       data-enable-api="{{ block.settings.enable_api_calls | default: true }}"
       data-cache-duration="{{ block.settings.cache_duration | default: 30 }}"
       {{ i18n_data }}>
    {% comment %} Loading placeholder - replaced by JavaScript {% endcomment %}
    <div class="rp-widget-loading">{{ 'widget.membership.loading' | t }}</div>
  </div>
{% else %}
  {% comment %} GUEST STATE - Customer is NOT logged in {% endcomment %}
  <div id="membership-widget-root"
       class="rp-widget-root"
       data-rp-utils-src="{{ 'rp-utils.js' | asset_url }}"
       data-rp-widget-src="{{ 'membership-widget.js' | asset_url }}"
       data-state="guest"
       data-shop-domain="{{ shop.permanent_domain }}"
       data-shop-currency="{{ shop.currency }}"
       data-message="{{ block.settings.guest_message | default: 'Join our rewards program!' }}"
       data-cta-text="{{ block.settings.guest_cta_text | default: 'Sign In' }}"
       data-cta-url="{{ guest_cta_url }}"
       {{ i18n_data }}>
    {% comment %} Guest placeholder - replaced by JavaScript {% endcomment %}
    <div class="rp-widget-guest">{{ 'widget.membership.guestFallback' | t }}</div>
  </div>
{% endif %}

{% comment %} Fallback for browsers without JavaScript {% endcomment %}
<noscript>
  <div class="rp-widget-noscript">
    {% if customer %}
      {{ 'widget.membership.noscriptAuthed' | t: name: customer.first_name }}
      <a href="{{ routes.account_url }}">{{ 'widget.membership.perkStoreCredit' | t }}</a>
    {% else %}
      <a href="{{ routes.account_login_url }}">{{ 'widget.membership.guestFallback' | t }}</a>
    {% endif %}
  </div>
</noscript>

{% schema %}
{
  "name": "RewardsPro Widget",
  "target": "body",
  "stylesheet": "membership-widget.css",
  "javascript": "rp-widget-loader.js",
  "settings": [
    {
      "type": "header",
      "content": "API & Performance Settings"
    },
    {
      "type": "checkbox",
      "id": "enable_api_calls",
      "label": "Enable real-time data",
      "default": true,
      "info": "Fetch live balance and tier data from server. Disable for testing or to use static data only."
    },
    {
      "type": "range",
      "id": "cache_duration",
      "label": "Cache duration (seconds)",
      "min": 30,
      "max": 300,
      "step": 30,
      "default": 30,
      "unit": "sec",
      "info": "How long to cache customer data. Lower values = faster theme updates, higher values = better performance. 30 seconds recommended."
    },
    {
      "type": "header",
      "content": "Guest User Settings"
    },
    {
      "type": "paragraph",
      "content": "These settings apply when a customer is NOT signed in"
    },
    {
      "type": "text",
      "id": "guest_message",
      "label": "Guest Message",
      "default": "Join our rewards program!",
      "info": "Message shown to non-logged-in visitors"
    },
    {
      "type": "text",
      "id": "guest_cta_text",
      "label": "Guest Button Text",
      "default": "Sign In",
      "info": "Text on the sign-in button for guests"
    },
    {
      "type": "text",
      "id": "guest_cta_url",
      "label": "Guest Button URL",
      "info": "Optional custom URL. Leave blank to use the store's customer-account sign-in route."
    }
  ]
}
{% endschema %}
