-- DROP TABLE IF EXISTS pkm_equivalence;
-- DROP INDEX IF EXISTS card_set_cards_oracle_idx;
-- DROP INDEX IF EXISTS card_set_cards_scryfall_oracle_idx;
-- DROP INDEX IF EXISTS card_set_cards_scryfall_card_idx;
-- DROP INDEX IF EXISTS card_set_cards_cardmarket_metacard_idx;
-- DROP INDEX IF EXISTS card_set_cards_cardmarket_product_idx;
-- DROP INDEX IF EXISTS card_set_cards_tcgplayer_product_idx;
-- DROP INDEX IF EXISTS card_set_cards_ygo_passcode_idx;
-- DROP INDEX IF EXISTS card_set_cards_pokemon_tcg_api_idx;
-- ALTER TABLE card_set_cards
--   DROP COLUMN IF EXISTS oracle_id,
--   DROP COLUMN IF EXISTS oracle_source,
--   DROP COLUMN IF EXISTS oracle_resolved_at,
--   DROP COLUMN IF EXISTS scryfall_oracle_id,
--   DROP COLUMN IF EXISTS scryfall_card_id,
--   DROP COLUMN IF EXISTS cardmarket_id_metacard,
--   DROP COLUMN IF EXISTS cardmarket_id_product,
--   DROP COLUMN IF EXISTS cardmarket_id_language,
--   DROP COLUMN IF EXISTS tcgplayer_product_id,
--   DROP COLUMN IF EXISTS tcgplayer_group_id,
--   DROP COLUMN IF EXISTS ygo_passcode,
--   DROP COLUMN IF EXISTS pokemon_tcg_api_id,
--   DROP COLUMN IF EXISTS card_name_lang,
--   DROP COLUMN IF EXISTS name_transliterations;
-- COMMIT;
