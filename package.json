{
  "name": "cambridge-tcg",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:wholesale": "pnpm --filter ./apps/wholesale dev",
    "dev:storefront": "pnpm --filter ./apps/storefront dev -- --port 3001",
    "dev:admin": "pnpm --filter @cambridge-tcg/admin dev",
    "build:wholesale": "pnpm --filter ./apps/wholesale build",
    "build:storefront": "pnpm --filter ./apps/storefront build",
    "build:admin": "pnpm --filter @cambridge-tcg/admin build",
    "test:admin": "pnpm --filter @cambridge-tcg/admin test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "audit:honesty": "pnpm --filter @cambridge-tcg/admin honesty",
    "audit:transparency": "pnpm --filter @cambridge-tcg/admin transparency",
    "audit:pricing": "pnpm --filter @cambridge-tcg/admin pricing",
    "audit:creation": "pnpm --filter @cambridge-tcg/admin creation",
    "audit:agent": "pnpm --filter @cambridge-tcg/admin agent-readiness",
    "audit:inclusion": "pnpm --filter @cambridge-tcg/admin inclusion",
    "audit:nesting": "pnpm --filter @cambridge-tcg/admin nesting",
    "audit:tributaries": "pnpm --filter @cambridge-tcg/admin tributaries",
    "audit:sku": "pnpm --filter @cambridge-tcg/admin sku",
    "audit:set-discovery": "pnpm --filter @cambridge-tcg/admin set-discovery",
    "audit:play-resources": "pnpm --filter @cambridge-tcg/admin play-resources",
    "audit:play-game-registry": "pnpm --filter @cambridge-tcg/admin play-game-registry",
    "audit:cardrush-coverage": "pnpm --filter @cambridge-tcg/admin cardrush-coverage",
    "audit:cardrush-coverage:strict": "pnpm --filter @cambridge-tcg/admin cardrush-coverage -- --strict",
    "audit:cardrush-probe": "pnpm --filter @cambridge-tcg/admin cardrush-probe",
    "audit:math-lang": "pnpm --filter @cambridge-tcg/admin math-lang",
    "audit:cross-language-coherence": "pnpm --filter @cambridge-tcg/admin cross-language-coherence",
    "audit:hospitality": "pnpm --filter @cambridge-tcg/admin hospitality",
    "audit:sets-coverage": "pnpm --filter @cambridge-tcg/admin sets-coverage",
    "audit:sets-coverage:strict": "pnpm --filter @cambridge-tcg/admin sets-coverage -- --strict",
    "audit:cardrush-discovery-health": "pnpm --filter @cambridge-tcg/admin cardrush-discovery-health",
    "audit:cardrush-discovery-health:strict": "pnpm --filter @cambridge-tcg/admin cardrush-discovery-health -- --strict",
    "audit:classifier-disagreement": "pnpm --filter @cambridge-tcg/admin classifier-disagreement",
    "audit:nav-coverage": "pnpm --filter @cambridge-tcg/admin nav-coverage",
    "audit:welcomes": "pnpm --filter @cambridge-tcg/admin welcomes",
    "audit:tcgplayer-mapping": "pnpm --filter @cambridge-tcg/admin tcgplayer-mapping",
    "audit:cross-source-divergence": "pnpm --filter @cambridge-tcg/admin cross-source-divergence",
    "audit:known-gaps": "pnpm --filter @cambridge-tcg/admin known-gaps",
    "audit:deploy-verify": "pnpm --filter @cambridge-tcg/admin deploy-verify",
    "audit:envelope-contract": "node --experimental-strip-types --no-warnings apps/storefront/scripts/audit-envelope-contract.mts",
    "audit:envelope-contract:regen": "node --experimental-strip-types --no-warnings apps/storefront/scripts/audit-envelope-contract.mts --regen",
    "audit:cron-auth": "pnpm --filter @cambridge-tcg/admin cron-auth",
    "audit": "pnpm audit:honesty && pnpm audit:transparency && pnpm audit:pricing && pnpm audit:creation && pnpm audit:agent && pnpm audit:inclusion && pnpm audit:tributaries && pnpm audit:sku && pnpm audit:set-discovery && pnpm audit:play-resources && pnpm audit:cardrush-coverage && pnpm audit:math-lang && pnpm audit:cross-language-coherence && pnpm audit:hospitality && pnpm audit:welcomes && pnpm audit:tcgplayer-mapping && pnpm audit:cross-source-divergence && pnpm audit:known-gaps && pnpm audit:sets-coverage && pnpm audit:cardrush-discovery-health && pnpm audit:classifier-disagreement && pnpm audit:envelope-contract && pnpm audit:cron-auth",
    "smoke": "pnpm --filter @cambridge-tcg/admin smoke",
    "state:snapshot": "pnpm --filter @cambridge-tcg/admin state:snapshot",
    "missions:sync": "pnpm --filter @cambridge-tcg/admin missions:sync",
    "missions:list": "pnpm --filter @cambridge-tcg/admin missions:list",
    "missions:claim": "pnpm --filter @cambridge-tcg/admin missions:claim --",
    "missions:done": "pnpm --filter @cambridge-tcg/admin missions:done --",
    "trace": "pnpm --filter @cambridge-tcg/admin trace --",
    "agent-readiness": "pnpm --filter @cambridge-tcg/admin agent-readiness",
    "verify": "pnpm typecheck && pnpm audit && pnpm audit:cardrush-coverage:strict && pnpm test:admin",
    "verify:fast": "pnpm typecheck"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
